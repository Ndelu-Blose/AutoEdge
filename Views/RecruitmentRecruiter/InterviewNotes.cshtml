@model AutoEdge.Models.Entities.Interview
@{
    ViewData["Title"] = "Interview Notes";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-edit"></i> Interview Notes - @Model.Application.FirstName @Model.Application.LastName
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="UpdateInterviewNotes" method="post">
                        <input type="hidden" asp-for="InterviewId" />
                        
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <h6><i class="fas fa-user"></i> Candidate Information</h6>
                                <p><strong>Name:</strong> @Model.Application.FirstName @Model.Application.LastName</p>
                                <p><strong>Position:</strong> @Model.JobPosting.JobTitle</p>
                                <p><strong>Department:</strong> @Model.JobPosting.Department</p>
                            </div>
                            <div class="col-md-6">
                                <h6><i class="fas fa-calendar"></i> Interview Details</h6>
                                <p><strong>Date:</strong> @Model.ScheduledDateTime.ToString("MMM dd, yyyy")</p>
                                <p><strong>Time:</strong> @Model.ScheduledDateTime.ToString("HH:mm")</p>
                                <p><strong>Duration:</strong> @Model.DurationMinutes minutes</p>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="interviewRating" class="control-label">Interview Rating *</label>
                            <div class="rating-input">
                                <div class="star-rating">
                                    @for (int i = 1; i <= 10; i++)
                                    {
                                        <input type="radio" name="interviewRating" id="star@(i)" value="@i" 
                                               @(Model.InterviewRating == i ? "checked" : "") required>
                                        <label for="star@(i)" class="star-label">
                                            <i class="fas fa-star"></i>
                                        </label>
                                    }
                                </div>
                                <small class="form-text text-muted">Rate the candidate from 1 (Poor) to 10 (Excellent)</small>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="interviewNotes" class="control-label">Interview Notes *</label>
                            <textarea name="interviewNotes" id="interviewNotes" class="form-control" rows="8" 
                                      placeholder="Enter detailed notes about the interview, candidate's responses, strengths, weaknesses, and overall impression..." required>@Model.InterviewNotes</textarea>
                            <small class="form-text text-muted">Be specific and detailed in your notes. Include examples of the candidate's responses.</small>
                        </div>

                        <div class="form-group">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="markAsCompleted" id="markAsCompleted" value="true">
                                <label class="form-check-label" for="markAsCompleted">
                                    <strong>Mark this interview as completed</strong>
                                </label>
                            </div>
                            <small class="form-text text-muted">Check this box to mark the interview as completed and finalize the notes.</small>
                        </div>

                        <div class="form-group" id="assessmentGroup" style="display: none;">
                            <label for="selectedAssessment" class="control-label">Assign Assessment *</label>
                            <select name="selectedAssessment" id="selectedAssessment" class="form-control">
                                <option value="">-- Select Assessment Type --</option>
                                <option value="Mechanical Engineer">Mechanical Engineer Assessment</option>
                                <option value="Sales Representative">Sales Representative Assessment</option>
                                <option value="Driver">Driver Assessment</option>
                                <option value="Desktop Technician">Desktop Technician Assessment</option>
                                <option value="General">General Assessment</option>
                            </select>
                            <small class="form-text text-muted">Select the appropriate assessment type for this candidate based on their job position.</small>
                        </div>

                        <div class="form-group">
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-save"></i> Save Interview Notes
                            </button>
                            <a asp-action="InterviewDetails" asp-route-id="@Model.InterviewId" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Back to Interview Details
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">
                        <i class="fas fa-lightbulb"></i> Interview Guidelines
                    </h6>
                </div>
                <div class="card-body">
                    <small class="text-muted">
                        <strong>Tips for effective interview notes:</strong><br><br>
                        • Document specific examples of responses<br>
                        • Note technical skills demonstrated<br>
                        • Record communication abilities<br>
                        • Mention cultural fit observations<br>
                        • Include any concerns or red flags<br>
                        • Be objective and fair in assessment<br>
                        • Consider the role requirements<br>
                        • Note follow-up questions needed
                    </small>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header">
                    <h6 class="mb-0">
                        <i class="fas fa-star"></i> Rating Guidelines
                    </h6>
                </div>
                <div class="card-body">
                    <small class="text-muted">
                        <strong>Rating Scale:</strong><br><br>
                        <strong>9-10:</strong> Exceptional candidate<br>
                        <strong>7-8:</strong> Strong candidate<br>
                        <strong>5-6:</strong> Average candidate<br>
                        <strong>3-4:</strong> Below average<br>
                        <strong>1-2:</strong> Poor candidate
                    </small>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header">
                    <h6 class="mb-0">
                        <i class="fas fa-download"></i> Candidate Documents
                    </h6>
                </div>
                <div class="card-body">
                    <div class="list-group">
                        @if (!string.IsNullOrEmpty(Model.Application.ResumeFilePath))
                        {
                            <a href="@Model.Application.ResumeFilePath" target="_blank" class="list-group-item list-group-item-action">
                                <i class="fas fa-file-pdf text-danger"></i> Resume/CV
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(Model.Application.CoverLetterPath))
                        {
                            <a href="@Model.Application.CoverLetterPath" target="_blank" class="list-group-item list-group-item-action">
                                <i class="fas fa-file-pdf text-danger"></i> Cover Letter
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        @* .rating-input {
            margin-bottom: 1rem;
        }
        
        @* .star-rating {
            display: flex;
            flex-direction: row-reverse;
            justify-content: flex-end;
            gap: 5px;
        } 
        .star-rating {
        display: flex;
        flex-direction: row;  /* Remove row-reverse */
        justify-content: flex-start;  /* Change from flex-end */
        gap: 5px;
        }
        
        .star-rating input[type="radio"] {
            display: none;
        }
        
        .star-rating label {
            font-size: 1.5rem;
            color: #ddd;
            cursor: pointer;
            transition: color 0.2s;
        }
        
        .star-rating label:hover,
        .star-rating label:hover ~ label,
        .star-rating input[type="radio"]:checked ~ label {
            color: #ffc107;
        } *@
            .star-rating {
            display: flex;
            flex-direction: row;
            justify-content: flex-start;
            gap: 2px;
        }

        .star-rating input[type="radio"] {
            display: none;
        }

        .star-rating label {
            font-size: 1.8rem;
            color: #ddd;
            cursor: pointer;
            transition: color 0.2s;
            user-select: none;
        }

        /* Default state - all stars grey */
        .star-rating label {
            color: #ddd;
        }

        /* When a star is selected, highlight it and all stars to the left */
        .star-rating input[type="radio"]:checked ~ label {
            color: #ffc107;
        }

        /* Hover effect - highlight from hovered star to the left */
        .star-rating label:hover,
        .star-rating label:hover ~ label {
            color: #ffc107;
        }

        /* Reset other stars when hovering */
        .star-rating:hover label {
            color: #ddd;
        }

        .star-rating label:hover,
        .star-rating label:hover ~ label {
            color: #ffc107;
        }
    </style>
    
    <script>
        $(document).ready(function() {
            // Show/hide assessment dropdown when "Mark as completed" is checked
            $('#markAsCompleted').change(function() {
                if ($(this).is(':checked')) {
                    $('#assessmentGroup').show();
                    $('#selectedAssessment').prop('required', true);
                } else {
                    $('#assessmentGroup').hide();
                    $('#selectedAssessment').prop('required', false);
                    $('#selectedAssessment').val('');
                }
            });

            // Add confirmation for marking interview as completed
            $('form').on('submit', function(e) {
                var markCompleted = $('#markAsCompleted').is(':checked');
                var rating = $('input[name="interviewRating"]:checked').val();
                var notes = $('#interviewNotes').val().trim();
                var selectedAssessment = $('#selectedAssessment').val();
                
                if (markCompleted) {
                    if (!rating) {
                        alert('Please provide a rating before marking the interview as completed.');
                        e.preventDefault();
                        return;
                    }
                    
                    if (!notes) {
                        alert('Please provide interview notes before marking the interview as completed.');
                        e.preventDefault();
                        return;
                    }
                    
                    if (!selectedAssessment) {
                        alert('Please select an assessment type before marking the interview as completed.');
                        e.preventDefault();
                        return;
                    }
                    
                    if (!confirm('Are you sure you want to mark this interview as completed and assign the selected assessment? This action cannot be undone.')) {
                        e.preventDefault();
                        return;
                    }
                }
            });
        });
    </script>
}

