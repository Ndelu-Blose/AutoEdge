@model AutoEdge.Models.ViewModels.MechanicsBoardVm
@{
    ViewData["Title"] = "Mechanics Board";
}
<h2>Mechanics Board (7 days)</h2>
<div class="row g-3">
@foreach (var m in Model.Mechanics)
{
  <div class="col-md-6">
    <div class="card p-3">
      <h5>@m.Name</h5>
      <table class="table table-sm">
        <thead><tr><th>Date</th><th>Time</th><th>Ref</th><th>Service</th><th>Completed</th></tr></thead>
        <tbody>
        @{ var list = Model.JobsByMechanic.ContainsKey(m.Id)
              ? Model.JobsByMechanic[m.Id]
              : new List<AutoEdge.Models.Entities.ServiceJob>(); }
        @foreach (var j in list)
        {
          var end = j.ScheduledStart.Add(TimeSpan.FromMinutes(j.DurationMin));
          <tr>
            <td>@j.ScheduledDate.ToString("yyyy-MM-dd")</td>
            <td>@j.ScheduledStart.ToString("HH:mm") - @end.ToString("HH:mm")</td>
            <td>@j.ServiceBooking.Reference</td>
            <td>@j.ServiceBooking.ServiceType</td>
            <td>@(j.IsCompleted ? "Yes" : "No")</td>
          </tr>
        }
        </tbody>
      </table>
    </div>
  </div>
}
</div>