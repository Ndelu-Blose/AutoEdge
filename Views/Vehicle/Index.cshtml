@model IEnumerable<AutoEdge.Models.Entities.Vehicle>
@{
    ViewData["Title"] = "Vehicle Management";
}

<div class="container">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2>Vehicle Management</h2>
                <div>
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Add New Vehicle
                    </a>
                    <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to Dashboard
                    </a>
                </div>
            </div>
            <hr />
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-12">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
        </div>
    </div>

    <!-- Search and Filter Section -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5>Search & Filter</h5>
                </div>
                <div class="card-body">
                    <form method="get">
                        <div class="row">
                            <div class="col-md-8">
                                <div class="input-group">
                                    <input type="text" class="form-control" name="searchString" value="@ViewData["CurrentFilter"]" 
                                           placeholder="Search by make, model, or VIN..." />
                                    <button class="btn btn-outline-secondary" type="submit">
                                        <i class="fas fa-search"></i> Search
                                    </button>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="d-flex gap-2">
                                    <a asp-action="Index" class="btn btn-outline-info">
                                        <i class="fas fa-refresh"></i> Clear
                                    </a>
                                    <button type="button" class="btn btn-outline-success" data-bs-toggle="modal" data-bs-target="#exportModal">
                                        <i class="fas fa-download"></i> Export
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Vehicle Statistics -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4>@Model.Count()</h4>
                            <p class="mb-0">Total Vehicles</p>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-car fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4>@Model.Count(v => v.Status == "Available")</h4>
                            <p class="mb-0">Available</p>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-check-circle fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4>@Model.Count(v => v.Status == "Reserved")</h4>
                            <p class="mb-0">Reserved</p>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-clock fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4>@Model.Count(v => v.Status == "Sold")</h4>
                            <p class="mb-0">Sold</p>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-handshake fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Vehicle List -->
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5>Vehicle Inventory</h5>
                </div>
                <div class="card-body">
                    @if (Model != null && Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Image</th>
                                        <th>
                                            <a asp-action="Index" asp-route-sortOrder="@ViewData["MakeSortParm"]" 
                                               asp-route-searchString="@ViewData["CurrentFilter"]" class="text-white text-decoration-none">
                                                Make <i class="fas fa-sort"></i>
                                            </a>
                                        </th>
                                        <th>
                                            <a asp-action="Index" asp-route-sortOrder="@ViewData["ModelSortParm"]" 
                                               asp-route-searchString="@ViewData["CurrentFilter"]" class="text-white text-decoration-none">
                                                Model <i class="fas fa-sort"></i>
                                            </a>
                                        </th>
                                        <th>
                                            <a asp-action="Index" asp-route-sortOrder="@ViewData["YearSortParm"]" 
                                               asp-route-searchString="@ViewData["CurrentFilter"]" class="text-white text-decoration-none">
                                                Year <i class="fas fa-sort"></i>
                                            </a>
                                        </th>
                                        <th>
                                            <a asp-action="Index" asp-route-sortOrder="@ViewData["PriceSortParm"]" 
                                               asp-route-searchString="@ViewData["CurrentFilter"]" class="text-white text-decoration-none">
                                                Price <i class="fas fa-sort"></i>
                                            </a>
                                        </th>
                                        <th>Mileage</th>
                                        <th>
                                            <a asp-action="Index" asp-route-sortOrder="@ViewData["StatusSortParm"]" 
                                               asp-route-searchString="@ViewData["CurrentFilter"]" class="text-white text-decoration-none">
                                                Status <i class="fas fa-sort"></i>
                                            </a>
                                        </th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var vehicle in Model)
                                    {
                                        <tr>
                                            <td>
                                                @if (vehicle.VehicleImages != null && vehicle.VehicleImages.Any())
                        {
                            var firstImage = vehicle.VehicleImages.FirstOrDefault()?.ImagePath;
                                                    <img src="@firstImage" alt="@vehicle.Make @vehicle.Model" class="img-thumbnail" style="width: 60px; height: 45px; object-fit: cover;" />
                                                }
                                                else
                                                {
                                                    <div class="bg-light d-flex align-items-center justify-content-center" style="width: 60px; height: 45px;">
                                                        <i class="fas fa-car text-muted"></i>
                                                    </div>
                                                }
                                            </td>
                                            <td><strong>@vehicle.Make</strong></td>
                                            <td>@vehicle.Model</td>
                                            <td>@vehicle.Year</td>
                                            <td><strong>R @vehicle.SellingPrice.ToString("N0")</strong></td>
                                            <td>@vehicle.Mileage.ToString("N0") mi</td>
                                            <td>
                                                @switch (vehicle.Status)
                                                {
                                                    case "Available":
                                                        <span class="badge bg-success">Available</span>
                                                        break;
                                                    case "Reserved":
                                                        <span class="badge bg-warning">Reserved</span>
                                                        break;
                                                    case "Sold":
                                                        <span class="badge bg-danger">Sold</span>
                                                        break;
                                                    case "Maintenance":
                                                        <span class="badge bg-info">Maintenance</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">@vehicle.Status</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a asp-action="Details" asp-route-id="@vehicle.Id" class="btn btn-sm btn-outline-info" title="View Details">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a asp-action="Edit" asp-route-id="@vehicle.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <form asp-action="ToggleStatus" asp-route-id="@vehicle.Id" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-sm btn-outline-warning" title="Toggle Status">
                                                            <i class="fas fa-exchange-alt"></i>
                                                        </button>
                                                    </form>
                                                    <a asp-action="Delete" asp-route-id="@vehicle.Id" class="btn btn-sm btn-outline-danger" title="Delete">
                                                        <i class="fas fa-trash"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Pagination -->
                        @if (ViewBag.TotalPages > 1)
                        {
                            <nav aria-label="Vehicle pagination">
                                <ul class="pagination justify-content-center">
                                    @if (ViewBag.HasPreviousPage)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)" 
                                               asp-route-searchString="@ViewData["CurrentFilter"]">
                                                <i class="fas fa-chevron-left"></i> Previous
                                            </a>
                                        </li>
                                    }
                                    
                                    @for (int i = Math.Max(1, ViewBag.CurrentPage - 2); i <= Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2); i++)
                                    {
                                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                            <a class="page-link" asp-action="Index" asp-route-page="@i" 
                                               asp-route-searchString="@ViewData["CurrentFilter"]">@i</a>
                                        </li>
                                    }
                                    
                                    @if (ViewBag.HasNextPage)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)" 
                                               asp-route-searchString="@ViewData["CurrentFilter"]">
                                                Next <i class="fas fa-chevron-right"></i>
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-car fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">No vehicles found</h5>
                            <p class="text-muted">@(ViewData["CurrentFilter"] != null ? "Try adjusting your search criteria." : "Start by adding your first vehicle to the inventory.")</p>
                            <a asp-action="Create" class="btn btn-primary">
                                <i class="fas fa-plus"></i> Add First Vehicle
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Export Modal -->
<div class="modal fade" id="exportModal" tabindex="-1" aria-labelledby="exportModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exportModalLabel">Export Vehicle Data</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Choose the format to export vehicle data:</p>
                <div class="d-grid gap-2">
                    <button class="btn btn-outline-success" onclick="exportData('csv')">
                        <i class="fas fa-file-csv"></i> Export as CSV
                    </button>
                    <button class="btn btn-outline-danger" onclick="exportData('pdf')">
                        <i class="fas fa-file-pdf"></i> Export as PDF
                    </button>
                    <button class="btn btn-outline-primary" onclick="exportData('excel')">
                        <i class="fas fa-file-excel"></i> Export as Excel
                    </button>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function exportData(format) {
            // Placeholder for export functionality
            alert('Export to ' + format.toUpperCase() + ' functionality will be implemented.');
            $('#exportModal').modal('hide');
        }

        // Auto-hide alerts after 5 seconds
        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);
    </script>
}