@model AutoEdge.Models.Entities.Vehicle
@{
    ViewData["Title"] = "Delete Vehicle";
}

<div class="container">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="text-danger">Delete Vehicle</h2>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
            </div>
            <hr />
        </div>
    </div>

    <div class="alert alert-danger" role="alert">
        <h4 class="alert-heading"><i class="fas fa-exclamation-triangle"></i> Warning!</h4>
        <p>You are about to permanently delete this vehicle from the system. This action cannot be undone.</p>
        <hr>
        <p class="mb-0">Please review the vehicle details below and confirm your decision.</p>
    </div>

    <div class="row">
        <!-- Vehicle Summary -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h5><i class="fas fa-car"></i> Vehicle to be Deleted</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-4"><strong>Make:</strong></div>
                        <div class="col-sm-8">@Model.Make</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4"><strong>Model:</strong></div>
                        <div class="col-sm-8">@Model.Model</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4"><strong>Year:</strong></div>
                        <div class="col-sm-8">@Model.Year</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4"><strong>Price:</strong></div>
                        <div class="col-sm-8"><span class="h5 text-success">R @Model.SellingPrice.ToString("N0")</span></div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4"><strong>VIN:</strong></div>
                        <div class="col-sm-8"><code>@Model.VIN</code></div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4"><strong>Status:</strong></div>
                        <div class="col-sm-8">
                            @switch (Model.Status)
                            {
                                case "Available":
                                    <span class="badge bg-success">Available</span>
                                    break;
                                case "Reserved":
                                    <span class="badge bg-warning">Reserved</span>
                                    break;
                                case "Sold":
                                    <span class="badge bg-danger">Sold</span>
                                    break;
                                case "Maintenance":
                                    <span class="badge bg-info">Maintenance</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary">@Model.Status</span>
                                    break;
                            }
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4"><strong>Mileage:</strong></div>
                        <div class="col-sm-8">@Model.Mileage.ToString("N0") miles</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4"><strong>Added:</strong></div>
                        <div class="col-sm-8">@Model.CreatedDate.ToString("MMM dd, yyyy")</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4"><strong>Last Updated:</strong></div>
                        <div class="col-sm-8">@Model.ModifiedDate.ToString("MMM dd, yyyy")</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Vehicle Image -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5><i class="fas fa-image"></i> Vehicle Image</h5>
                </div>
                <div class="card-body">
                    @if (Model.VehicleImages != null && Model.VehicleImages.Any())
        {
            var firstImage = Model.VehicleImages.FirstOrDefault()?.ImagePath;
                        if (!string.IsNullOrEmpty(firstImage))
                        {
                            <img src="@firstImage" alt="@Model.Make @Model.Model" class="img-fluid rounded" style="max-height: 300px; width: 100%; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="fas fa-car fa-3x text-muted mb-3"></i>
                                <p class="text-muted">No image available</p>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-car fa-3x text-muted mb-3"></i>
                            <p class="text-muted">No image available</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Additional Details -->
    @if (!string.IsNullOrEmpty(Model.Features))
    {
        <div class="row mt-4">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header">
                        <h5><i class="fas fa-info-circle"></i> Additional Information</h5>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(Model.Features))
                        {
                            <div class="mb-3">
                                <strong>Features:</strong>
                                <p class="mt-2">@Model.Features</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Deletion Impact Warning -->
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card border-warning">
                <div class="card-header bg-warning text-dark">
                    <h5><i class="fas fa-exclamation-circle"></i> Deletion Impact</h5>
                </div>
                <div class="card-body">
                    <p><strong>The following data will be permanently removed:</strong></p>
                    <ul>
                        <li>All vehicle information and specifications</li>
                        <li>Vehicle images and associated files</li>
                        <li>Vehicle history and maintenance records</li>
                        <li>Any related inquiries or reservations</li>
                    </ul>
                    
                    <div class="alert alert-info mt-3" role="alert">
                        <strong>Note:</strong> If this vehicle has active reservations or is part of ongoing transactions, 
                        consider changing its status to "Sold" or "Unavailable" instead of deleting it.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Confirmation Form -->
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h5><i class="fas fa-trash"></i> Confirm Deletion</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Delete" method="post" id="deleteForm">
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="confirmDelete" required>
                                <label class="form-check-label" for="confirmDelete">
                                    <strong>I understand that this action is permanent and cannot be undone</strong>
                                </label>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label for="confirmationText" class="form-label">
                                Type <strong>DELETE</strong> to confirm:
                            </label>
                            <input type="text" class="form-control" id="confirmationText" placeholder="Type DELETE here" required>
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <button type="submit" class="btn btn-danger btn-lg" id="deleteButton" disabled>
                                    <i class="fas fa-trash"></i> Delete Vehicle Permanently
                                </button>
                            </div>
                            <div>
                                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-info me-2">
                                    <i class="fas fa-eye"></i> View Details
                                </a>
                                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning me-2">
                                    <i class="fas fa-edit"></i> Edit Instead
                                </a>
                                <a asp-action="Index" class="btn btn-secondary">
                                    <i class="fas fa-times"></i> Cancel
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const confirmCheckbox = document.getElementById('confirmDelete');
            const confirmationText = document.getElementById('confirmationText');
            const deleteButton = document.getElementById('deleteButton');
            const deleteForm = document.getElementById('deleteForm');
            
            function checkFormValidity() {
                const isChecked = confirmCheckbox.checked;
                const isTextCorrect = confirmationText.value.trim().toUpperCase() === 'DELETE';
                
                deleteButton.disabled = !(isChecked && isTextCorrect);
                
                if (isChecked && isTextCorrect) {
                    deleteButton.classList.remove('btn-danger');
                    deleteButton.classList.add('btn-outline-danger');
                } else {
                    deleteButton.classList.remove('btn-outline-danger');
                    deleteButton.classList.add('btn-danger');
                }
            }
            
            confirmCheckbox.addEventListener('change', checkFormValidity);
            confirmationText.addEventListener('input', checkFormValidity);
            
            deleteForm.addEventListener('submit', function(e) {
                if (!confirmCheckbox.checked || confirmationText.value.trim().toUpperCase() !== 'DELETE') {
                    e.preventDefault();
                    alert('Please complete all confirmation requirements before proceeding.');
                    return;
                }
                
                if (!confirm('Are you absolutely sure you want to delete this vehicle? This action cannot be undone!')) {
                    e.preventDefault();
                }
            });
        });
    </script>
    
    <style>
        .card-header {
            font-weight: 500;
        }
        
        .alert-heading {
            margin-bottom: 1rem;
        }
        
        .form-check-label {
            cursor: pointer;
        }
        
        #deleteButton:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }
        
        .border-danger {
            border-color: #dc3545 !important;
        }
        
        .border-warning {
            border-color: #ffc107 !important;
        }
    </style>
}