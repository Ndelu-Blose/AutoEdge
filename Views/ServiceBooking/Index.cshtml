@* @model IEnumerable<AutoEdge.Models.Entities.ServiceBooking>

@{
    ViewData["Title"] = "My Service Bookings";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="fas fa-calendar-check"></i> My Service Bookings</h2>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Book New Service
                </a>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (Model.Any())
            {
                <div class="row">
                    @foreach (var booking in Model)
                    {
                        <div class="col-md-6 col-lg-4 mb-4">
                            <div class="card h-100">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <h6 class="mb-0">@booking.ReferenceNumber</h6>
                                    <span class="badge bg-@GetStatusColor(booking.BookingStatus)">@booking.BookingStatus</span>
                                </div>
                                <div class="card-body">
                                    <h6 class="card-title">@booking.ServiceType</h6>
                                    <p class="card-text">
                                        <strong>Vehicle:</strong> @booking.VehicleYear @booking.VehicleMake @booking.VehicleModel<br>
                                        <strong>Date:</strong> @booking.BookingDate.ToString("MMM dd, yyyy")<br>
                                        <strong>Time:</strong> @booking.BookingTime.ToString(@"hh\:mm")<br>
                                        <strong>Estimated Cost:</strong> $@booking.EstimatedCostMin - $@booking.EstimatedCostMax
                                    </p>
                                    @if (!string.IsNullOrEmpty(booking.ServiceNotes))
                                    {
                                        <p class="card-text">
                                            <small class="text-muted">@booking.ServiceNotes</small>
                                        </p>
                                    }
                                </div>
                                <div class="card-footer">
                                    <div class="btn-group w-100" role="group">
                                        <a asp-action="Details" asp-route-id="@booking.ServiceBookingId" class="btn btn-outline-primary btn-sm">
                                            <i class="fas fa-eye"></i> Details
                                        </a>
                                        @if (booking.BookingStatus == "Scheduled" && !booking.VehiclePickups.Any())
                                        {
                                            <a asp-action="RequestPickup" asp-route-id="@booking.ServiceBookingId" class="btn btn-outline-success btn-sm">
                                                <i class="fas fa-car"></i> Request Pickup
                                            </a>
                                        }
                                        @if (booking.ServiceInvoices.Any() && booking.ServiceInvoices.First().InvoiceStatus == "Issued")
                                        {
                                            <a asp-action="Payment" asp-route-id="@booking.ServiceBookingId" class="btn btn-outline-warning btn-sm">
                                                <i class="fas fa-credit-card"></i> Pay
                                            </a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-calendar-times fa-3x text-muted mb-3"></i>
                    <h4 class="text-muted">No Service Bookings Found</h4>
                    <p class="text-muted">You haven't booked any services yet.</p>
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Book Your First Service
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@functions {
    string GetStatusColor(string status)
    {
        return status switch
        {
            "Requested" => "secondary",
            "Confirmed" => "info",
            "Scheduled" => "primary",
            "InProgress" => "warning",
            "Completed" => "success",
            "Cancelled" => "danger",
            _ => "secondary"
        };
    }
} *@
