<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AutoEdge</title>
    
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    
    <!-- Custom CSS (loads after Bootstrap to override) -->
    <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />
    
    <!-- Page-specific styles -->
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="main-layout">
        <!-- Sidebar -->
        <nav class="sidebar" id="sidebar">
            <!-- Sidebar Header -->
            <div class="sidebar-header">
                <a href="@Url.Action("Index", "Home")" class="sidebar-brand">
                    <i class="fas fa-car me-2"></i>
                    <span class="nav-text">AutoEdge</span>
                </a>
            </div>
            
            <!-- Sidebar Navigation -->
            <ul class="nav sidebar-nav">
                <!-- Dashboard -->
                <li class="nav-item" data-role="Admin,Sales,Customer,Driver">
                    <a class="nav-link" href="@GetDashboardUrl()">
                        <i class="fas fa-tachometer-alt"></i>
                        <span class="nav-text">Dashboard</span>
                    </a>
                </li>
                
                <!-- Admin & Sales Menu Items -->
                @if (User.IsInRole("Administrator") || User.IsInRole("SalesRepresentative"))
                {
                    <li class="nav-item" data-role="Admin,Sales">
                        <a class="nav-link" href="@Url.Action("Index", "Vehicle")">
                            <i class="fas fa-car"></i>
                            <span class="nav-text">Vehicles</span>
                        </a>
                    </li>
                    
                    <li class="nav-item" data-role="Admin,Sales">
                        <a class="nav-link" href="@Url.Action("Index", "Customer")">
                            <i class="fas fa-users"></i>
                            <span class="nav-text">Customers</span>
                        </a>
                    </li>
                    
                    <li class="nav-item" data-role="Admin,Sales">
                        <a class="nav-link" href="@Url.Action("Index", "Purchase")">
                            <i class="fas fa-shopping-cart"></i>
                            <span class="nav-text">Purchases</span>
                        </a>
                    </li>
                }
                
                <!-- Admin Only Menu Items -->
                @if (User.IsInRole("Administrator"))
                {
                    <li class="nav-item has-submenu" data-role="Admin">
                        <a class="nav-link" href="#">
                            <i class="fas fa-cog"></i>
                            <span class="nav-text">Administration</span>
                        </a>
                        <ul class="nav submenu">
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Index", "Admin")">
                                    <i class="fas fa-users-cog"></i>
                                    <span class="nav-text">Users</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Purchases", "Admin")">
                                    <i class="fas fa-file-invoice"></i>
                                    <span class="nav-text">All Purchases</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Index", "Reports")">
                                    <i class="fas fa-chart-bar"></i>
                                    <span class="nav-text">Reports</span>
                                </a>
                            </li>
                        </ul>
                    </li>
                    
                    <li class="nav-item has-submenu" data-role="Admin">
                        <a class="nav-link" href="#">
                            <i class="fas fa-wrench"></i>
                            <span class="nav-text">Service Management</span>
                        </a>
                        <ul class="nav submenu">
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Index", "PickupDropoff")">
                                    <i class="fas fa-truck"></i>
                                    <span class="nav-text">Pickup & Drop-off</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Index", "Scheduling")">
                                    <i class="fas fa-calendar-alt"></i>
                                    <span class="nav-text">Service Scheduling</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Index", "Bookings")">
                                    <i class="fas fa-clipboard-list"></i>
                                    <span class="nav-text">All Bookings</span>
                                </a>
                            </li>
                        </ul>
                    </li>
                    
                    <li class="nav-item" data-role="Admin">
                        <a class="nav-link" href="@Url.Action("Index", "Delivery")">
                            <i class="fas fa-truck"></i>
                            <span class="nav-text">Deliveries</span>
                        </a>
                    </li>
                    
                    <li class="nav-item has-submenu" data-role="Admin">
                        <a class="nav-link" href="#">
                            <i class="fas fa-user-tie"></i>
                            <span class="nav-text">Recruitment</span>
                        </a>
                        <ul class="nav submenu">
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Index", "RecruitmentAdmin")">
                                    <i class="fas fa-tachometer-alt"></i>
                                    <span class="nav-text">Dashboard</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("JobPostings", "RecruitmentAdmin")">
                                    <i class="fas fa-briefcase"></i>
                                    <span class="nav-text">Job Postings</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Applications", "RecruitmentAdmin")">
                                    <i class="fas fa-file-alt"></i>
                                    <span class="nav-text">Applications</span>
                                </a>
                            </li>
                        </ul>
                    </li>
                }
                
                <!-- Customer Menu Items -->
                @if (User.IsInRole("Customer"))
                {
                    <li class="nav-item" data-role="Customer">
                        <a class="nav-link" href="@Url.Action("Index", "VehicleBrowse")">
                            <i class="fas fa-search"></i>
                            <span class="nav-text">Browse Vehicles</span>
                        </a>
                    </li>
                    
                    <li class="nav-item" data-role="Customer">
                        <a class="nav-link" href="@Url.Action("MyPurchases", "Purchase")">
                            <i class="fas fa-shopping-bag"></i>
                            <span class="nav-text">My Purchases</span>
                        </a>
                    </li>
                    
                    <li class="nav-item" data-role="Customer">
                        <a class="nav-link" href="@Url.Action("Inquiries", "Customer")">
                            <i class="fas fa-question-circle"></i>
                            <span class="nav-text">My Inquiries</span>
                        </a>
                    </li>
                    
                    <li class="nav-item" data-role="Customer">
                        <a class="nav-link" href="@Url.Action("Documents", "Customer")">
                            <i class="fas fa-file-alt"></i>
                            <span class="nav-text">Documents</span>
                        </a>
                    </li>
                    
                    <li class="nav-item has-submenu" data-role="Customer">
                        <a class="nav-link" href="#">
                            <i class="fas fa-wrench"></i>
                            <span class="nav-text">Vehicle Services</span>
                        </a>
                        <ul class="nav submenu">
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("MyServices", "CustomerServicePortal")">
                                    <i class="fas fa-clipboard-list"></i>
                                    <span class="nav-text">My Services</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("PaymentHistory", "CustomerServicePortal")">
                                    <i class="fas fa-credit-card"></i>
                                    <span class="nav-text">Payment History</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("CustomerPickups", "PickupDropoff")">
                                    <i class="fas fa-truck"></i>
                                    <span class="nav-text">My Pickups</span>
                                </a>
                            </li>
                        </ul>
                    </li>
                }
                
                <!-- Service Manager Menu Items -->
                @if (User.IsInRole("ServiceManager"))
                {
                    <li class="nav-item" data-role="ServiceManager">
                        <a class="nav-link" href="@Url.Action("Index", "PickupDropoff")">
                            <i class="fas fa-truck"></i>
                            <span class="nav-text">Pickup & Drop-off</span>
                        </a>
                    </li>
                    
                    <li class="nav-item" data-role="ServiceManager">
                        <a class="nav-link" href="@Url.Action("Index", "Scheduling")">
                            <i class="fas fa-calendar-alt"></i>
                            <span class="nav-text">Service Scheduling</span>
                        </a>
                    </li>
                    
                    <li class="nav-item" data-role="ServiceManager">
                        <a class="nav-link" href="@Url.Action("Index", "Bookings")">
                            <i class="fas fa-clipboard-list"></i>
                            <span class="nav-text">All Bookings</span>
                        </a>
                    </li>
                }
                
                <!-- Mechanic Menu Items -->
                @if (User.IsInRole("Mechanic"))
                {
                    <li class="nav-item" data-role="Mechanic">
                        <a class="nav-link" href="@Url.Action("Board", "Mechanics")">
                            <i class="fas fa-tachometer-alt"></i>
                            <span class="nav-text">Service Board</span>
                        </a>
                    </li>
                    
                    <li class="nav-item" data-role="Mechanic">
                        <a class="nav-link" href="@Url.Action("MyJobs", "Mechanics")">
                            <i class="fas fa-tools"></i>
                            <span class="nav-text">My Jobs</span>
                        </a>
                    </li>
                    
                    <li class="nav-item" data-role="Mechanic">
                        <a class="nav-link" href="@Url.Action("ScanQRCode", "Mechanics")">
                            <i class="fas fa-qrcode"></i>
                            <span class="nav-text">Scan QR Code</span>
                        </a>
                    </li>
                }
                
                <!-- Driver Menu Items -->
                @if (User.IsInRole("Driver"))
                {
                    <li class="nav-item" data-role="Driver">
                        <a class="nav-link" href="@Url.Action("MyDeliveries", "Delivery")">
                            <i class="fas fa-truck"></i>
                            <span class="nav-text">My Deliveries</span>
                        </a>
                    </li>
                    
                    <li class="nav-item" data-role="Driver">
                        <a class="nav-link" href="@Url.Action("ScanQRCode", "Delivery")">
                            <i class="fas fa-qrcode"></i>
                            <span class="nav-text">Scan QR Code</span>
                        </a>
                    </li>
                }
                
                <!-- Recruiter Menu Items -->
                @if (User.IsInRole("Recruiter"))
                {
                    <li class="nav-item" data-role="Recruiter">
                        <a class="nav-link" href="@Url.Action("Dashboard", "RecruitmentRecruiter")">
                            <i class="fas fa-tachometer-alt"></i>
                            <span class="nav-text">Recruiter Dashboard</span>
                        </a>
                    </li>
                    
                    <li class="nav-item" data-role="Recruiter">
                        <a class="nav-link" href="@Url.Action("MyInterviews", "RecruitmentRecruiter")">
                            <i class="fas fa-video"></i>
                            <span class="nav-text">My Interviews</span>
                        </a>
                    </li>
                }
                
                <!-- Applicant Menu Items -->
                @if (User.IsInRole("Applicant"))
                {
                    <li class="nav-item" data-role="Applicant">
                        <a class="nav-link" href="@Url.Action("VacantPositions", "RecruitmentApplicant")">
                            <i class="fas fa-search"></i>
                            <span class="nav-text">View Jobs</span>
                        </a>
                    </li>
                    
                    <li class="nav-item" data-role="Applicant">
                        <a class="nav-link" href="@Url.Action("ApplicationStatus", "RecruitmentApplicant", new { email = User.Identity.Name })">
                            <i class="fas fa-file-alt"></i>
                            <span class="nav-text">My Applications</span>
                        </a>
                    </li>
                }
                
                <!-- Common Menu Items -->
                @if (!User.IsInRole("Driver") && !User.IsInRole("Mechanic"))
                {
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Create", "Bookings")">
                            <i class="fas fa-wrench"></i>
                            <span class="nav-text">Service Booking</span>
                        </a>
                    </li>
                }
            </ul>
        </nav>
        
        <!-- Main Content -->
        <div class="main-content" id="main-content">
            <!-- Top Navbar -->
            <nav class="top-navbar">
                <div class="d-flex justify-content-between align-items-center">
                    <!-- Mobile Sidebar Toggle -->
                    <button class="sidebar-toggle d-md-none" type="button">
                        <i class="fas fa-bars"></i>
                    </button>
                    
                    <!-- Page Title (hidden on mobile) -->
                    <h4 class="mb-0 d-none d-md-block">@ViewData["Title"]</h4>
                    
                    <!-- User Menu -->
                    <div class="d-flex align-items-center">
                        <!-- Notifications (if needed) -->
                        <div class="me-3">
                            <button class="btn btn-icon" type="button" title="Notifications">
                                <i class="fas fa-bell"></i>
                            </button>
                        </div>
                        
                        <!-- User Profile -->
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </nav>
            
            <!-- Page Content -->
            <div class="content-container">
                <!-- Alerts -->
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle me-2"></i>
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                
                @if (TempData["InfoMessage"] != null)
                {
                    <div class="alert alert-info alert-dismissible fade show" role="alert">
                        <i class="fas fa-info-circle me-2"></i>
                        @TempData["InfoMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                
                <!-- Main Content -->
                @RenderBody()
            </div>
        </div>
    </div>
    
    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/sidebar.js" asp-append-version="true"></script>
    
    <!-- Page-specific scripts -->
    @await RenderSectionAsync("Scripts", required: false)
    
    <script>
        // Initialize sidebar for current user role
        document.addEventListener('DOMContentLoaded', function() {
            @if (User.Identity.IsAuthenticated)
            {
                <text>
                var userRole = '@Html.Raw(GetUserRole())';
                if (window.AutoEdgeSidebarUtils) {
                    window.AutoEdgeSidebarUtils.updateSidebarForRole(userRole);
                }
                </text>
            }
        });
    </script>
</body>
</html>

@functions {
    private string GetDashboardUrl()
    {
        if (User.IsInRole("Administrator"))
            return Url.Action("Index", "Admin");
        else if (User.IsInRole("SalesRepresentative"))
            return Url.Action("Index", "Admin"); // or create a sales dashboard
        else if (User.IsInRole("ServiceManager"))
            return Url.Action("Index", "PickupDropoff");
        else if (User.IsInRole("Mechanic"))
            return Url.Action("Board", "Mechanics");
        else if (User.IsInRole("Driver"))
            return Url.Action("DriverApp", "PickupDropoff");
        else if (User.IsInRole("Customer"))
            return Url.Action("MyServices", "CustomerServicePortal");
        else if (User.IsInRole("Recruiter"))
            return Url.Action("Dashboard", "RecruitmentRecruiter");
        else if (User.IsInRole("Applicant"))
            return Url.Action("ApplicationStatus", "RecruitmentApplicant", new { email = User.Identity.Name });
        else
            return Url.Action("Index", "Home");
    }
    
    private string GetUserRole()
    {
        if (User.IsInRole("Administrator")) return "Admin";
        if (User.IsInRole("SalesRepresentative")) return "Sales";
        if (User.IsInRole("ServiceManager")) return "ServiceManager";
        if (User.IsInRole("Mechanic")) return "Mechanic";
        if (User.IsInRole("Driver")) return "Driver";
        if (User.IsInRole("Customer")) return "Customer";
        if (User.IsInRole("Recruiter")) return "Recruiter";
        if (User.IsInRole("Applicant")) return "Applicant";
        return "Guest";
    }
}
