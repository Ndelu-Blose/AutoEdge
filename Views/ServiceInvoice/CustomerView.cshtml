@model AutoEdge.Models.Entities.ServiceInvoice
@{
    ViewData["Title"] = "Invoice Details";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card">
                <div class="card-header">
                    <h3 class="mb-0">
                        <i class="fas fa-file-invoice-dollar text-primary"></i> Invoice #@Model.InvoiceNumber
                    </h3>
                </div>
                <div class="card-body">
                    <!-- Invoice Header -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h5><i class="fas fa-car text-primary"></i> Service Details</h5>
                            @if (Model.ServiceBooking != null)
                            {
                                <table class="table table-sm">
                                    <tr>
                                        <td><strong>Vehicle:</strong></td>
                                        <td>@Model.ServiceBooking.Year @Model.ServiceBooking.Make @Model.ServiceBooking.Model</td>
                                    </tr>
                                    <tr>
                                        <td><strong>VIN:</strong></td>
                                        <td>@Model.ServiceBooking.VIN</td>
                                    </tr>
                                    <tr>
                                        <td><strong>Service Type:</strong></td>
                                        <td>@Model.ServiceBooking.ServiceType</td>
                                    </tr>
                                    <tr>
                                        <td><strong>Service Date:</strong></td>
                                        <td>@Model.ServiceBooking.ServiceCompletedDate?.ToString("MMMM dd, yyyy")</td>
                                    </tr>
                                </table>
                            }
                        </div>
                        <div class="col-md-6">
                            <h5><i class="fas fa-user text-primary"></i> Customer Information</h5>
                            @if (Model.ServiceBooking != null)
                            {
                                <table class="table table-sm">
                                    <tr>
                                        <td><strong>Name:</strong></td>
                                        <td>@Model.ServiceBooking.CustomerName</td>
                                    </tr>
                                    <tr>
                                        <td><strong>Email:</strong></td>
                                        <td>@Model.ServiceBooking.CustomerEmail</td>
                                    </tr>
                                    <tr>
                                        <td><strong>Phone:</strong></td>
                                        <td>@Model.ServiceBooking.CustomerPhone</td>
                                    </tr>
                                </table>
                            }
                        </div>
                    </div>

                    <!-- Invoice Summary -->
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <h5><i class="fas fa-receipt text-primary"></i> Invoice Summary</h5>
                            <div class="table-responsive">
                                <table class="table table-bordered">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Description</th>
                                            <th>Amount</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.ServiceBooking != null && Model.ServiceBooking.DeliveryMethod == AutoEdge.Models.Entities.ServiceDeliveryMethod.Pickup)
                                        {
                                            <tr>
                                                <td>Service Fee</td>
                                                <td>R @((Model.SubTotal - 100.00m).ToString("F2"))</td>
                                            </tr>
                                            <tr>
                                                <td>Pickup Service</td>
                                                <td>R 100.00</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            <tr>
                                                <td>Service Fee</td>
                                                <td>R @Model.SubTotal.ToString("F2")</td>
                                            </tr>
                                        }
                                        <tr>
                                            <td>Tax</td>
                                            <td>R @Model.TaxAmount.ToString("F2")</td>
                                        </tr>
                                        <tr class="table-success">
                                            <td><strong>Total Amount</strong></td>
                                            <td><strong>R @Model.TotalAmount.ToString("F2")</strong></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Payment Status -->
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <h5><i class="fas fa-credit-card text-primary"></i> Payment Status</h5>
                            @{
                                var totalPaid = Model.ServicePayments?.Where(p => p.Status == "Completed").Sum(p => p.Amount) ?? 0;
                                var remainingAmount = Model.TotalAmount - totalPaid;
                                var isPaid = remainingAmount <= 0;
                            }
                            
                            @if (isPaid)
                            {
                                <div class="alert alert-success">
                                    <i class="fas fa-check-circle"></i> <strong>Paid in Full</strong><br>
                                    Total paid: R @totalPaid.ToString("F2")
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-warning">
                                    <i class="fas fa-exclamation-triangle"></i> <strong>Payment Pending</strong><br>
                                    Amount paid: R @totalPaid.ToString("F2")<br>
                                    Remaining: R @remainingAmount.ToString("F2")
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Payment History -->
                    @if (Model.ServicePayments != null && Model.ServicePayments.Any())
                    {
                        <div class="row mb-4">
                            <div class="col-md-12">
                                <h5><i class="fas fa-history text-primary"></i> Payment History</h5>
                                <div class="table-responsive">
                                    <table class="table table-striped">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Date</th>
                                                <th>Method</th>
                                                <th>Amount</th>
                                                <th>Status</th>
                                                <th>Transaction ID</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var payment in Model.ServicePayments.OrderByDescending(p => p.PaymentDate))
                                            {
                                                <tr>
                                                    <td>@payment.PaymentDate.ToString("MMM dd, yyyy")</td>
                                                    <td>@payment.PaymentMethod</td>
                                                    <td>R @payment.Amount.ToString("F2")</td>
                                                    <td>
                                                        @if (payment.Status == "Completed")
                                                        {
                                                            <span class="badge bg-success">Completed</span>
                                                        }
                                                        else if (payment.Status == "Pending")
                                                        {
                                                            <span class="badge bg-warning">Pending</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-danger">@payment.Status</span>
                                                        }
                                                    </td>
                                                    <td>@payment.TransactionId</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Action Buttons -->
                    <div class="row">
                        <div class="col-md-12 text-center">
                            @if (!isPaid)
                            {
                                <a asp-action="Pay" asp-route-id="@Model.Id" class="btn btn-primary btn-lg">
                                    <i class="fas fa-credit-card"></i> Pay Now
                                </a>
                            }
                            <a asp-action="DownloadPDF" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-download"></i> Download PDF
                            </a>
                            <a asp-controller="CustomerServicePortal" asp-action="MyServices" class="btn btn-outline-primary btn-lg">
                                <i class="fas fa-arrow-left"></i> Back to Services
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
