@{
    ViewData["Title"] = "Access Expired";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header bg-danger text-white text-center">
                    <h3 class="card-title mb-0">
                        <i class="fas fa-clock fa-3x mb-3"></i>
                        <br>
                        Access Expired
                    </h3>
                </div>
                <div class="card-body text-center">
                    <div class="alert alert-danger">
                        <h4 class="alert-heading">
                            <i class="fas fa-exclamation-triangle mr-2"></i>
                            Sorry, your access has expired
                        </h4>
                        <p class="mb-0">
                            The employment offer link you used has expired or is no longer valid. 
                            Employment offers are typically valid for 7 days from the date they were sent.
                        </p>
                    </div>

                    <div class="card">
                        <div class="card-body">
                            <h5>What can you do?</h5>
                            <ul class="list-unstyled">
                                <li class="mb-2">
                                    <i class="fas fa-envelope text-primary mr-2"></i>
                                    Check your email for a more recent offer link
                                </li>
                                <li class="mb-2">
                                    <i class="fas fa-phone text-primary mr-2"></i>
                                    Contact our HR team to request a new offer link
                                </li>
                                <li class="mb-2">
                                    <i class="fas fa-question-circle text-primary mr-2"></i>
                                    If you have questions, reach out to us directly
                                </li>
                            </ul>
                        </div>
                    </div>

                    <div class="mt-4">
                        <h5>Need Help?</h5>
                        <p class="text-muted">
                            If you believe this is an error or need assistance, please contact our HR team.
                        </p>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="card">
                                    <div class="card-body">
                                        <h6><i class="fas fa-envelope mr-2"></i>Email</h6>
                                        <p class="mb-0">hr@autoedge.co.za</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card">
                                    <div class="card-body">
                                        <h6><i class="fas fa-phone mr-2"></i>Phone</h6>
                                        <p class="mb-0">+27 31 123 4567</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer text-center">
                    <p class="mb-0">
                        <strong>AutoEdge HR Team</strong><br>
                        <small class="text-muted">We're here to help you with your employment journey</small>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
