@model AutoEdge.Models.Entities.PreEmploymentDocumentation

@{
    ViewData["Title"] = "Pre-Employment Documentation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3 class="card-title">
                        <i class="fas fa-clipboard-list mr-2"></i>
                        Pre-Employment Documentation
                    </h3>
                    <div class="progress mt-2" style="height: 20px;">
                        <div class="progress-bar" role="progressbar" style="width: 0%" id="progressBar">
                            <span id="progressText">Step 1 of 8</span>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle mr-2"></i>
                            @TempData["SuccessMessage"]
                            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                    }

                    <form asp-action="SaveDocumentation" method="post" id="documentationForm" enctype="multipart/form-data">
                        <input type="hidden" name="token" value="@ViewContext.HttpContext.Request.Query["token"]" />
                        
                        <!-- Section 1: Personal Information -->
                        <div class="form-section" id="section1">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title">
                                        <i class="fas fa-user mr-2"></i>
                                        Section 1: Personal Information
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label asp-for="IdNumber" class="control-label">South African ID Number <span class="text-danger">*</span></label>
                                                <input asp-for="IdNumber" class="form-control" maxlength="13" required />
                                                <span asp-validation-for="IdNumber" class="text-danger"></span>
                                                <small class="form-text text-muted">13 digits only</small>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label asp-for="DateOfBirth" class="control-label">Date of Birth <span class="text-danger">*</span></label>
                                                <input asp-for="DateOfBirth" class="form-control" type="date" required />
                                                <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="row">
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label asp-for="Gender" class="control-label">Gender <span class="text-danger">*</span></label>
                                                <select asp-for="Gender" class="form-control" required>
                                                    <option value="">Select Gender</option>
                                                    <option value="Male">Male</option>
                                                    <option value="Female">Female</option>
                                                    <option value="Other">Other</option>
                                                </select>
                                                <span asp-validation-for="Gender" class="text-danger"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label asp-for="Nationality" class="control-label">Nationality <span class="text-danger">*</span></label>
                                                <select asp-for="Nationality" class="form-control" required>
                                                    <option value="">Select Nationality</option>
                                                    <option value="South African">South African</option>
                                                    <option value="Other">Other</option>
                                                </select>
                                                <span asp-validation-for="Nationality" class="text-danger"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label asp-for="MaritalStatus" class="control-label">Marital Status <span class="text-danger">*</span></label>
                                                <select asp-for="MaritalStatus" class="form-control" required>
                                                    <option value="">Select Status</option>
                                                    <option value="Single">Single</option>
                                                    <option value="Married">Married</option>
                                                    <option value="Divorced">Divorced</option>
                                                    <option value="Widowed">Widowed</option>
                                                </select>
                                                <span asp-validation-for="MaritalStatus" class="text-danger"></span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="row">
                                        <div class="col-md-8">
                                            <div class="form-group">
                                                <label asp-for="ResidentialAddress" class="control-label">Residential Address <span class="text-danger">*</span></label>
                                                <input asp-for="ResidentialAddress" class="form-control" required />
                                                <span asp-validation-for="ResidentialAddress" class="text-danger"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label asp-for="City" class="control-label">City/Town <span class="text-danger">*</span></label>
                                                <input asp-for="City" class="form-control" required />
                                                <span asp-validation-for="City" class="text-danger"></span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="row">
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label asp-for="Province" class="control-label">Province <span class="text-danger">*</span></label>
                                                <select asp-for="Province" class="form-control" required>
                                                    <option value="">Select Province</option>
                                                    <option value="Gauteng">Gauteng</option>
                                                    <option value="KwaZulu-Natal">KwaZulu-Natal</option>
                                                    <option value="Western Cape">Western Cape</option>
                                                    <option value="Eastern Cape">Eastern Cape</option>
                                                    <option value="Free State">Free State</option>
                                                    <option value="Limpopo">Limpopo</option>
                                                    <option value="Mpumalanga">Mpumalanga</option>
                                                    <option value="Northern Cape">Northern Cape</option>
                                                    <option value="North West">North West</option>
                                                </select>
                                                <span asp-validation-for="Province" class="text-danger"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label asp-for="PostalCode" class="control-label">Postal Code <span class="text-danger">*</span></label>
                                                <input asp-for="PostalCode" class="form-control" maxlength="4" required />
                                                <span asp-validation-for="PostalCode" class="text-danger"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label asp-for="AlternativePhoneNumber" class="control-label">Alternative Phone Number</label>
                                                <input asp-for="AlternativePhoneNumber" class="form-control" />
                                                <span asp-validation-for="AlternativePhoneNumber" class="text-danger"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Section 2: Emergency Contact -->
                        <div class="form-section" id="section2" style="display: none;">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title">
                                        <i class="fas fa-phone mr-2"></i>
                                        Section 2: Emergency Contact
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <h6>Primary Emergency Contact</h6>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label asp-for="EmergencyContactName" class="control-label">Full Name <span class="text-danger">*</span></label>
                                                <input asp-for="EmergencyContactName" class="form-control" required />
                                                <span asp-validation-for="EmergencyContactName" class="text-danger"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label asp-for="EmergencyContactRelationship" class="control-label">Relationship <span class="text-danger">*</span></label>
                                                <select asp-for="EmergencyContactRelationship" class="form-control" required>
                                                    <option value="">Select Relationship</option>
                                                    <option value="Spouse">Spouse</option>
                                                    <option value="Parent">Parent</option>
                                                    <option value="Sibling">Sibling</option>
                                                    <option value="Friend">Friend</option>
                                                    <option value="Other">Other</option>
                                                </select>
                                                <span asp-validation-for="EmergencyContactRelationship" class="text-danger"></span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label asp-for="EmergencyContactPhone" class="control-label">Phone Number <span class="text-danger">*</span></label>
                                                <input asp-for="EmergencyContactPhone" class="form-control" required />
                                                <span asp-validation-for="EmergencyContactPhone" class="text-danger"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label asp-for="EmergencyContactAddress" class="control-label">Address</label>
                                                <input asp-for="EmergencyContactAddress" class="form-control" />
                                                <span asp-validation-for="EmergencyContactAddress" class="text-danger"></span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <h6 class="mt-4">Secondary Emergency Contact (Optional)</h6>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label asp-for="SecondaryEmergencyContactName" class="control-label">Full Name</label>
                                                <input asp-for="SecondaryEmergencyContactName" class="form-control" />
                                                <span asp-validation-for="SecondaryEmergencyContactName" class="text-danger"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label asp-for="SecondaryEmergencyContactRelationship" class="control-label">Relationship</label>
                                                <select asp-for="SecondaryEmergencyContactRelationship" class="form-control">
                                                    <option value="">Select Relationship</option>
                                                    <option value="Spouse">Spouse</option>
                                                    <option value="Parent">Parent</option>
                                                    <option value="Sibling">Sibling</option>
                                                    <option value="Friend">Friend</option>
                                                    <option value="Other">Other</option>
                                                </select>
                                                <span asp-validation-for="SecondaryEmergencyContactRelationship" class="text-danger"></span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label asp-for="SecondaryEmergencyContactPhone" class="control-label">Phone Number</label>
                                                <input asp-for="SecondaryEmergencyContactPhone" class="form-control" />
                                                <span asp-validation-for="SecondaryEmergencyContactPhone" class="text-danger"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label asp-for="SecondaryEmergencyContactAddress" class="control-label">Address</label>
                                                <input asp-for="SecondaryEmergencyContactAddress" class="form-control" />
                                                <span asp-validation-for="SecondaryEmergencyContactAddress" class="text-danger"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Section 3: Banking Details -->
                        <div class="form-section" id="section3" style="display: none;">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title">
                                        <i class="fas fa-university mr-2"></i>
                                        Section 3: Banking Details
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label asp-for="BankName" class="control-label">Bank Name <span class="text-danger">*</span></label>
                                                <select asp-for="BankName" class="form-control" required>
                                                    <option value="">Select Bank</option>
                                                    <option value="FNB">First National Bank (FNB)</option>
                                                    <option value="Standard Bank">Standard Bank</option>
                                                    <option value="ABSA">ABSA Bank</option>
                                                    <option value="Nedbank">Nedbank</option>
                                                    <option value="Capitec">Capitec Bank</option>
                                                    <option value="Other">Other</option>
                                                </select>
                                                <span asp-validation-for="BankName" class="text-danger"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label asp-for="AccountType" class="control-label">Account Type <span class="text-danger">*</span></label>
                                                <select asp-for="AccountType" class="form-control" required>
                                                    <option value="">Select Type</option>
                                                    <option value="Savings">Savings</option>
                                                    <option value="Cheque">Cheque/Current</option>
                                                </select>
                                                <span asp-validation-for="AccountType" class="text-danger"></span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label asp-for="AccountNumber" class="control-label">Account Number <span class="text-danger">*</span></label>
                                                <input asp-for="AccountNumber" class="form-control" required />
                                                <span asp-validation-for="AccountNumber" class="text-danger"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label asp-for="BranchCode" class="control-label">Branch Code <span class="text-danger">*</span></label>
                                                <input asp-for="BranchCode" class="form-control" maxlength="6" required />
                                                <span asp-validation-for="BranchCode" class="text-danger"></span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label asp-for="AccountHolderName" class="control-label">Account Holder Name <span class="text-danger">*</span></label>
                                        <input asp-for="AccountHolderName" class="form-control" required />
                                        <span asp-validation-for="AccountHolderName" class="text-danger"></span>
                                        <small class="form-text text-muted">Must match your full name</small>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label class="control-label">Proof of Bank Account <span class="text-danger">*</span></label>
                                        <div class="file-upload-area" id="bankStatementUpload">
                                            <div class="upload-placeholder">
                                                <i class="fas fa-cloud-upload-alt fa-3x text-muted"></i>
                                                <p class="mt-2">Drag and drop your bank statement here or click to browse</p>
                                                <p class="text-muted">PDF, JPG, PNG (Max 5MB)</p>
                                            </div>
                                            <input type="file" id="bankStatementFile" name="bankStatementFile" accept=".pdf,.jpg,.jpeg,.png" style="display: none;" />
                                        </div>
                                        <div id="bankStatementPreview" class="mt-2" style="display: none;">
                                            <div class="alert alert-success">
                                                <i class="fas fa-check-circle mr-2"></i>
                                                <span id="bankStatementFileName"></span>
                                                <button type="button" class="btn btn-sm btn-outline-danger ml-2" onclick="removeFile('bankStatement')">Remove</button>
                                            </div>
                                        </div>
                                        <input type="hidden" asp-for="BankStatementPath" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Section 4: Tax Information -->
                        <div class="form-section" id="section4" style="display: none;">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title">
                                        <i class="fas fa-receipt mr-2"></i>
                                        Section 4: Tax Information
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label asp-for="TaxNumber" class="control-label">Tax Number</label>
                                                <input asp-for="TaxNumber" class="form-control" />
                                                <span asp-validation-for="TaxNumber" class="text-danger"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label class="control-label">Registered for Tax?</label>
                                                <div class="form-check">
                                                    <input class="form-check-input" type="radio" name="RegisteredForTax" id="taxYes" value="true" asp-for="RegisteredForTax">
                                                    <label class="form-check-label" for="taxYes">Yes</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input" type="radio" name="RegisteredForTax" id="taxNo" value="false" asp-for="RegisteredForTax">
                                                    <label class="form-check-label" for="taxNo">No</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label asp-for="TaxDirectiveNumber" class="control-label">Tax Directive Number</label>
                                        <input asp-for="TaxDirectiveNumber" class="form-control" />
                                        <span asp-validation-for="TaxDirectiveNumber" class="text-danger"></span>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label class="control-label">Tax Clearance Certificate (Optional)</label>
                                        <div class="file-upload-area" id="taxClearanceUpload">
                                            <div class="upload-placeholder">
                                                <i class="fas fa-cloud-upload-alt fa-3x text-muted"></i>
                                                <p class="mt-2">Upload tax clearance certificate</p>
                                                <p class="text-muted">PDF only (Max 5MB)</p>
                                            </div>
                                            <input type="file" id="taxClearanceFile" name="taxClearanceFile" accept=".pdf" style="display: none;" />
                                        </div>
                                        <div id="taxClearancePreview" class="mt-2" style="display: none;">
                                            <div class="alert alert-success">
                                                <i class="fas fa-check-circle mr-2"></i>
                                                <span id="taxClearanceFileName"></span>
                                                <button type="button" class="btn btn-sm btn-outline-danger ml-2" onclick="removeFile('taxClearance')">Remove</button>
                                            </div>
                                        </div>
                                        <input type="hidden" asp-for="TaxClearancePath" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Section 5: Medical Information -->
                        <div class="form-section" id="section5" style="display: none;">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title">
                                        <i class="fas fa-heartbeat mr-2"></i>
                                        Section 5: Medical Information
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <h6>Medical Aid Information</h6>
                                    <div class="form-group">
                                        <label class="control-label">Do you have medical aid?</label>
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="HasMedicalAid" id="medicalAidYes" value="true" asp-for="HasMedicalAid">
                                            <label class="form-check-label" for="medicalAidYes">Yes</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="HasMedicalAid" id="medicalAidNo" value="false" asp-for="HasMedicalAid">
                                            <label class="form-check-label" for="medicalAidNo">No</label>
                                        </div>
                                    </div>
                                    
                                    <div id="medicalAidDetails" style="display: none;">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label asp-for="MedicalAidProvider" class="control-label">Medical Aid Provider</label>
                                                    <input asp-for="MedicalAidProvider" class="form-control" />
                                                    <span asp-validation-for="MedicalAidProvider" class="text-danger"></span>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label asp-for="MedicalAidNumber" class="control-label">Medical Aid Number</label>
                                                    <input asp-for="MedicalAidNumber" class="form-control" />
                                                    <span asp-validation-for="MedicalAidNumber" class="text-danger"></span>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div class="form-group">
                                            <label asp-for="MedicalAidMemberType" class="control-label">Member Type</label>
                                            <select asp-for="MedicalAidMemberType" class="form-control">
                                                <option value="">Select Type</option>
                                                <option value="Main Member">Main Member</option>
                                                <option value="Dependant">Dependant</option>
                                            </select>
                                            <span asp-validation-for="MedicalAidMemberType" class="text-danger"></span>
                                        </div>
                                    </div>
                                    
                                    <h6 class="mt-4">Health Declaration</h6>
                                    <div class="form-group">
                                        <label class="control-label">Do you have any chronic medical conditions?</label>
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="HasChronicConditions" id="chronicYes" value="true" asp-for="HasChronicConditions">
                                            <label class="form-check-label" for="chronicYes">Yes</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="HasChronicConditions" id="chronicNo" value="false" asp-for="HasChronicConditions">
                                            <label class="form-check-label" for="chronicNo">No</label>
                                        </div>
                                    </div>
                                    
                                    <div id="chronicConditionsDetails" style="display: none;">
                                        <div class="form-group">
                                            <label asp-for="ChronicConditionsDetails" class="control-label">Please provide details</label>
                                            <textarea asp-for="ChronicConditionsDetails" class="form-control" rows="3" maxlength="500"></textarea>
                                            <span asp-validation-for="ChronicConditionsDetails" class="text-danger"></span>
                                        </div>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label class="control-label">Are you on any chronic medication?</label>
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="OnChronicMedication" id="medicationYes" value="true" asp-for="OnChronicMedication">
                                            <label class="form-check-label" for="medicationYes">Yes</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="OnChronicMedication" id="medicationNo" value="false" asp-for="OnChronicMedication">
                                            <label class="form-check-label" for="medicationNo">No</label>
                                        </div>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label class="control-label">Do you have any disabilities requiring workplace accommodation?</label>
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="HasDisabilities" id="disabilitiesYes" value="true" asp-for="HasDisabilities">
                                            <label class="form-check-label" for="disabilitiesYes">Yes</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="HasDisabilities" id="disabilitiesNo" value="false" asp-for="HasDisabilities">
                                            <label class="form-check-label" for="disabilitiesNo">No</label>
                                        </div>
                                    </div>
                                    
                                    <div id="disabilitiesDetails" style="display: none;">
                                        <div class="form-group">
                                            <label asp-for="DisabilitiesDetails" class="control-label">Please provide details</label>
                                            <textarea asp-for="DisabilitiesDetails" class="form-control" rows="3" maxlength="500"></textarea>
                                            <span asp-validation-for="DisabilitiesDetails" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Section 6: Dependents Information -->
                        <div class="form-section" id="section6" style="display: none;">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title">
                                        <i class="fas fa-users mr-2"></i>
                                        Section 6: Dependents Information
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="form-group">
                                        <label asp-for="NumberOfDependents" class="control-label">Number of Dependents <span class="text-danger">*</span></label>
                                        <select asp-for="NumberOfDependents" class="form-control" required onchange="toggleDependentsSection()">
                                            <option value="">Select Number</option>
                                            <option value="0">0</option>
                                            <option value="1">1</option>
                                            <option value="2">2</option>
                                            <option value="3">3</option>
                                            <option value="4">4</option>
                                            <option value="5">5</option>
                                            <option value="6">6</option>
                                            <option value="7">7</option>
                                            <option value="8">8</option>
                                            <option value="9">9</option>
                                            <option value="10">10+</option>
                                        </select>
                                        <span asp-validation-for="NumberOfDependents" class="text-danger"></span>
                                    </div>
                                    
                                    <div id="dependentsSection" style="display: none;">
                                        <h6>Dependents Details</h6>
                                        <div id="dependentsList">
                                            <!-- Dependents will be added dynamically here -->
                                        </div>
                                        <button type="button" class="btn btn-outline-primary btn-sm" onclick="addDependent()">
                                            <i class="fas fa-plus mr-1"></i>
                                            Add Another Dependent
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Section 7: Required Documents Upload -->
                        <div class="form-section" id="section7" style="display: none;">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title">
                                        <i class="fas fa-file-upload mr-2"></i>
                                        Section 7: Required Documents Upload
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="alert alert-info">
                                        <i class="fas fa-info-circle mr-2"></i>
                                        <strong>Important:</strong> All documents must be clear, legible, and dated within the last 3 months (where applicable).
                                    </div>
                                    
                                    <h6>Mandatory Documents</h6>
                                    
                                    <div class="form-group">
                                        <label class="control-label">1. Certified Copy of ID Document <span class="text-danger">*</span></label>
                                        <div class="file-upload-area" id="certifiedIdUpload">
                                            <div class="upload-placeholder">
                                                <i class="fas fa-cloud-upload-alt fa-3x text-muted"></i>
                                                <p class="mt-2">Upload certified copy of ID</p>
                                                <p class="text-muted">PDF, JPG, PNG (Max 5MB)</p>
                                            </div>
                                            <input type="file" id="certifiedIdFile" name="certifiedIdFile" accept=".pdf,.jpg,.jpeg,.png" style="display: none;" />
                                        </div>
                                        <div id="certifiedIdPreview" class="mt-2" style="display: none;">
                                            <div class="alert alert-success">
                                                <i class="fas fa-check-circle mr-2"></i>
                                                <span id="certifiedIdFileName"></span>
                                                <button type="button" class="btn btn-sm btn-outline-danger ml-2" onclick="removeFile('certifiedId')">Remove</button>
                                            </div>
                                        </div>
                                        <input type="hidden" asp-for="CertifiedIdPath" />
                                        <small class="form-text text-muted">Must be certified within the last 3 months</small>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label class="control-label">2. Proof of Residential Address <span class="text-danger">*</span></label>
                                        <div class="file-upload-area" id="proofOfAddressUpload">
                                            <div class="upload-placeholder">
                                                <i class="fas fa-cloud-upload-alt fa-3x text-muted"></i>
                                                <p class="mt-2">Upload utility bill, bank statement, or municipal account</p>
                                                <p class="text-muted">PDF, JPG, PNG (Max 5MB)</p>
                                            </div>
                                            <input type="file" id="proofOfAddressFile" name="proofOfAddressFile" accept=".pdf,.jpg,.jpeg,.png" style="display: none;" />
                                        </div>
                                        <div id="proofOfAddressPreview" class="mt-2" style="display: none;">
                                            <div class="alert alert-success">
                                                <i class="fas fa-check-circle mr-2"></i>
                                                <span id="proofOfAddressFileName"></span>
                                                <button type="button" class="btn btn-sm btn-outline-danger ml-2" onclick="removeFile('proofOfAddress')">Remove</button>
                                            </div>
