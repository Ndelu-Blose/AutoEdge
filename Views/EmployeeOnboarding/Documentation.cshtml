                                    <div class="form-group">
                                        <label class="control-label">3. Certified Qualification Certificates <span class="text-danger">*</span></label>
                                        <div class="file-upload-area" id="qualificationCertificatesUpload">
                                            <div class="upload-placeholder">
                                                <i class="fas fa-cloud-upload-alt fa-3x text-muted"></i>
