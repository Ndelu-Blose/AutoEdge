@model AutoEdge.Models.Entities.ServiceBooking
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Service Complete - @Model.Reference</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { background-color: #007bff; color: white; padding: 20px; text-align: center; }
        .content { padding: 20px; background-color: #f8f9fa; }
        .invoice-section { background-color: white; padding: 20px; margin: 20px 0; border-radius: 5px; }
        .button { display: inline-block; background-color: #28a745; color: white; padding: 12px 24px; text-decoration: none; border-radius: 5px; margin: 10px 0; }
        .footer { background-color: #6c757d; color: white; padding: 20px; text-align: center; }
        .table { width: 100%; border-collapse: collapse; margin: 10px 0; }
        .table th, .table td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        .table th { background-color: #f2f2f2; }
        .highlight { background-color: #fff3cd; padding: 15px; border-radius: 5px; margin: 15px 0; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🎉 Your Vehicle Service is Complete!</h1>
            <p>Service Reference: @Model.Reference</p>
        </div>
        
        <div class="content">
            <h2>Dear @Model.CustomerName,</h2>
            
            <p>Great news! The service work on your <strong>@Model.Make @Model.Model (@Model.Year)</strong> has been completed and your vehicle is ready for pickup.</p>
            
            <div class="highlight">
                <h3>📋 Service Summary</h3>
                <ul>
                    <li><strong>Service Type:</strong> @Model.ServiceType</li>
                    <li><strong>Vehicle:</strong> @Model.Make @Model.Model (@Model.Year)</li>
                    <li><strong>Service Reference:</strong> @Model.Reference</li>
                    <li><strong>Completion Date:</strong> @DateTime.Now.ToString("MMMM dd, yyyy 'at' h:mm tt")</li>
                </ul>
            </div>

            <div class="invoice-section">
                <h3>💰 Invoice Details</h3>
                <p><strong>Invoice Number:</strong> INV-@DateTime.Now.ToString("yyyyMMdd")-@Model.Id.ToString("D4")</p>
                <p><strong>Total Amount Due:</strong> $@(Model.EstimatedCost.ToString("F2"))</p>
                <p><strong>Payment Due:</strong> Within 7 days</p>
                
                <div style="text-align: center; margin: 20px 0;">
                    <a href="@ViewBag.PaymentUrl" class="button">💳 Pay Now Online</a>
                </div>
                
                <p><small>You can also pay in person when you collect your vehicle.</small></p>
            </div>

            <div class="highlight">
                <h3>🚗 Vehicle Pickup Information</h3>
                <p><strong>Pickup Location:</strong> AutoEdge Service Center</p>
                <p><strong>Address:</strong> 123 Service Street, City, State 12345</p>
                <p><strong>Business Hours:</strong></p>
                <ul>
                    <li>Monday - Friday: 8:00 AM - 6:00 PM</li>
                    <li>Saturday: 9:00 AM - 4:00 PM</li>
                    <li>Sunday: Closed</li>
                </ul>
                <p><strong>Please bring:</strong> Valid ID and payment method (if paying in person)</p>
            </div>

            <div style="background-color: #e7f3ff; padding: 15px; border-radius: 5px; margin: 15px 0;">
                <h3>📞 Need Help?</h3>
                <p>If you have any questions about your service or need to reschedule pickup, please contact us:</p>
                <ul>
                    <li><strong>Phone:</strong> (555) 123-4567</li>
                    <li><strong>Email:</strong> service@autoedge.com</li>
                    <li><strong>Service Hours:</strong> Monday-Friday 8AM-6PM, Saturday 9AM-4PM</li>
                </ul>
            </div>

            <p>Thank you for choosing AutoEdge for your vehicle service needs. We appreciate your business!</p>
            
            <p>Best regards,<br>
            <strong>AutoEdge Service Team</strong></p>
        </div>
        
        <div class="footer">
            <p>AutoEdge Vehicle Service Center</p>
            <p>123 Service Street, City, State 12345 | (555) 123-4567 | service@autoedge.com</p>
            <p><small>This is an automated message. Please do not reply to this email.</small></p>
        </div>
    </div>
</body>
</html>
