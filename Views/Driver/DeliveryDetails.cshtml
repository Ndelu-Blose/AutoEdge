@model AutoEdge.Models.Entities.Delivery
@{
    ViewData["Title"] = "Delivery Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="fas fa-truck"></i> Delivery Details #@Model.Id</h2>
                <a href="@Url.Action("Dashboard")" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Delivery Information -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-info-circle"></i> Delivery Information
                    </h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Delivery ID:</dt>
                        <dd class="col-sm-8">#@Model.Id</dd>

                        <dt class="col-sm-4">Status:</dt>
                        <dd class="col-sm-8">
                            @switch (Model.Status)
                            {
                                case "Pending":
                                    <span class="badge bg-warning">Pending</span>
                                    break;
                                case "In Transit":
                                    <span class="badge bg-info">In Transit</span>
                                    break;
                                case "Delivered":
                                    <span class="badge bg-success">Delivered</span>
                                    break;
                                case "Cancelled":
                                    <span class="badge bg-danger">Cancelled</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary">@Model.Status</span>
                                    break;
                            }
                        </dd>

                        <dt class="col-sm-4">Scheduled Date:</dt>
                        <dd class="col-sm-8">
                            <strong>@Model.ScheduledDate.ToString("MMMM dd, yyyy")</strong><br>
                            <small class="text-muted">@Model.ScheduledDate.ToString("hh:mm tt")</small>
                        </dd>

                        @if (Model.CompletedDate.HasValue)
                        {
                            <dt class="col-sm-4">Delivered On:</dt>
                            <dd class="col-sm-8">
                                <strong>@Model.CompletedDate.Value.ToString("MMMM dd, yyyy")</strong><br>
                                <small class="text-muted">@Model.CompletedDate.Value.ToString("hh:mm tt")</small>
                            </dd>
                        }

                        <dt class="col-sm-4">Delivery Address:</dt>
                        <dd class="col-sm-8">
                            @if (!string.IsNullOrEmpty(Model.DeliveryAddress))
                            {
                                @Model.DeliveryAddress
                            }
                            else
                            {
                                <span class="text-muted">Address not provided</span>
                            }
                        </dd>

                        @if (!string.IsNullOrEmpty(Model.Notes))
                        {
                            <dt class="col-sm-4">Notes:</dt>
                            <dd class="col-sm-8">@Model.Notes</dd>
                        }
                    </dl>
                </div>
            </div>
        </div>

        <!-- Customer Information -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-user"></i> Customer Information
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.Contract?.Customer != null)
                    {
                        <dl class="row">
                            <dt class="col-sm-4">Name:</dt>
                            <dd class="col-sm-8">@Model.Contract.Customer.User.FirstName @Model.Contract.Customer.User.LastName</dd>

                            <dt class="col-sm-4">Email:</dt>
                            <dd class="col-sm-8">
                                <a href="mailto:@Model.Contract.Customer.User.Email">@Model.Contract.Customer.User.Email</a>
                            </dd>

                            @if (!string.IsNullOrEmpty(Model.Contract.Customer.User?.PhoneNumber))
                            {
                                <dt class="col-sm-4">Phone:</dt>
                                <dd class="col-sm-8">
                                    <a href="tel:@Model.Contract.Customer.User.PhoneNumber">@Model.Contract.Customer.User.PhoneNumber</a>
                                </dd>
                            }

                            @if (!string.IsNullOrEmpty(Model.Contract.Customer.DeliveryAddress))
                            {
                                <dt class="col-sm-4">Address:</dt>
                                <dd class="col-sm-8">@Model.Contract.Customer.DeliveryAddress</dd>
                            }
                        </dl>
                    }
                    else
                    {
                        <p class="text-muted">Customer information not available</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Vehicle Information -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-car"></i> Vehicle Information
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.Contract?.Vehicle != null)
                    {
                        <div class="row">
                            <div class="col-md-6">
                                <dl class="row">
                                    <dt class="col-sm-4">Make:</dt>
                                    <dd class="col-sm-8">@Model.Contract.Vehicle.Make</dd>

                                    <dt class="col-sm-4">Model:</dt>
                                    <dd class="col-sm-8">@Model.Contract.Vehicle.Model</dd>

                                    <dt class="col-sm-4">Year:</dt>
                                    <dd class="col-sm-8">@Model.Contract.Vehicle.Year</dd>

                                    <dt class="col-sm-4">Color:</dt>
                                    <dd class="col-sm-8">@Model.Contract.Vehicle.ExteriorColor</dd>
                                </dl>
                            </div>
                            <div class="col-md-6">
                                <dl class="row">
                                    <dt class="col-sm-4">VIN:</dt>
                                    <dd class="col-sm-8"><code>@Model.Contract.Vehicle.VIN</code></dd>

                                    <dt class="col-sm-4">Mileage:</dt>
                                    <dd class="col-sm-8">@Model.Contract.Vehicle.Mileage.ToString("N0") miles</dd>

                                    <dt class="col-sm-4">Price:</dt>
                                    <dd class="col-sm-8">@Model.Contract.Vehicle.SellingPrice.ToString("C")</dd>

                                    <dt class="col-sm-4">Condition:</dt>
                                    <dd class="col-sm-8">
                                        <span class="badge bg-info">@Model.Contract.Vehicle.Condition</span>
                                    </dd>
                                </dl>
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Vehicle information not available</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    @if (Model.Status != "Delivered" && Model.Status != "Cancelled")
    {
        <div class="row mt-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="fas fa-cogs"></i> Actions
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex gap-2">
                            @if (Model.Status == "Scheduled")
                            {
                                <form method="post" action="@Url.Action("UpdateDeliveryStatus")" class="d-inline">
                                    <input type="hidden" name="deliveryId" value="@Model.Id" />
                                    <input type="hidden" name="status" value="In Transit" />
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-truck"></i> Start Delivery
                                    </button>
                                </form>
                            }
                            @if (Model.Status == "In Transit")
                            {
                                <form method="post" action="@Url.Action("UpdateDeliveryStatus")" class="d-inline">
                                    <input type="hidden" name="deliveryId" value="@Model.Id" />
                                    <input type="hidden" name="status" value="Delivered" />
                                    <button type="submit" class="btn btn-success">
                                        <i class="fas fa-check"></i> Mark as Delivered
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>