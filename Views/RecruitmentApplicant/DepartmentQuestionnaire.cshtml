@{
    ViewData["Title"] = "Department Questionnaire";
    var department = ViewBag.Department as string;
    var jobPosting = ViewBag.JobPosting as AutoEdge.Models.Entities.JobPosting;
    var questions = ViewBag.Questions as List<object>;
    var instructions = ViewBag.Instructions as string;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <!-- Header -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h2 class="mb-0">
                        <i class="fas fa-clipboard-list"></i> @department Questionnaire
                    </h2>
                </div>
                <div class="card-body">
                    @if (jobPosting != null)
                    {
                        <h4 class="text-primary">@jobPosting.JobTitle</h4>
                        <p class="text-muted mb-3">Department: <strong>@jobPosting.Department</strong></p>
                    }
                    else
                    {
                        <h4 class="text-primary">@department Position</h4>
                    }
                    
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle"></i> @instructions
                    </div>
                </div>
            </div>

            <!-- Questionnaire Form -->
            <div class="card shadow-sm">
                <div class="card-header">
                    <h4 class="mb-0">
                        <i class="fas fa-question-circle"></i> Assessment Questions
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="SubmitDepartmentQuestionnaire" method="post" id="questionnaireForm">
                        <input type="hidden" name="department" value="@department" />
                        @if (jobPosting != null)
                        {
                            <input type="hidden" name="jobId" value="@jobPosting.JobId" />
                        }

                        @if (questions != null && questions.Any())
                        {
                            @for (int i = 0; i < questions.Count; i++)
                            {
                                var question = questions[i];
                                var questionId = ((dynamic)question).Id;
                                var questionType = ((dynamic)question).Type;
                                var questionText = ((dynamic)question).Question;
                                var isRequired = ((dynamic)question).Required;

                                <div class="question-item mb-4 p-3 border rounded">
                                    <div class="question-header mb-3">
                                        <h5 class="question-number text-primary">
                                            Question @(i + 1) 
                                            @if (isRequired)
                                            {
                                                <span class="text-danger">*</span>
                                            }
                                        </h5>
                                        <p class="question-text mb-0">@questionText</p>
                                    </div>

                                    @if (questionType == "multiplechoice")
                                    {
                                        var options = ((dynamic)question).Options as string[];
                                        <div class="answer-options">
                                            @foreach (var option in options)
                                            {
                                                <div class="form-check mb-2">
                                                    <input class="form-check-input" type="radio" 
                                                           name="answers[@questionId]" 
                                                           id="@questionId@option" 
                                                           value="@option"
                                                           @(isRequired ? "required" : "")>
                                                    <label class="form-check-label" for="@questionId@option">
                                                        @option
                                                    </label>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else if (questionType == "shortanswer")
                                    {
                                        <div class="answer-input">
                                            <textarea class="form-control" 
                                                      name="answers[@questionId]" 
                                                      id="@questionId"
                                                      rows="3" 
                                                      placeholder="Enter your answer here..."
                                                      @(isRequired ? "required" : "")></textarea>
                                        </div>
                                    }
                                    else if (questionType == "essay")
                                    {
                                        <div class="answer-input">
                                            <textarea class="form-control" 
                                                      name="answers[@questionId]" 
                                                      id="@questionId"
                                                      rows="5" 
                                                      placeholder="Please provide a detailed response..."
                                                      @(isRequired ? "required" : "")></textarea>
                                            <small class="form-text text-muted">
                                                <i class="fas fa-info-circle"></i> 
                                                Please provide a comprehensive answer (minimum 50 words recommended).
                                            </small>
                                        </div>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <div class="alert alert-warning">
                                <i class="fas fa-exclamation-triangle"></i> 
                                No questions available for this department.
                            </div>
                        }

                        <!-- Submit Button -->
                        <div class="form-actions mt-4">
                            <div class="d-flex justify-content-between">
                                <a href="@Url.Action("VacantPositions")" class="btn btn-secondary">
                                    <i class="fas fa-arrow-left"></i> Back to Job Listings
                                </a>
                                <button type="submit" class="btn btn-success btn-lg" id="submitBtn">
                                    <i class="fas fa-paper-plane"></i> Submit Assessment
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Instructions Card -->
            <div class="card shadow-sm mt-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-lightbulb"></i> Assessment Guidelines
                    </h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <i class="fas fa-check text-success"></i> 
                            <strong>Answer all required questions</strong> (marked with *)
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-check text-success"></i> 
                            <strong>Be honest and accurate</strong> in your responses
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-check text-success"></i> 
                            <strong>Take your time</strong> to provide thoughtful answers
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-check text-success"></i> 
                            <strong>For essay questions</strong>, provide detailed responses
                        </li>
                        <li class="mb-0">
                            <i class="fas fa-check text-success"></i> 
                            <strong>Review your answers</strong> before submitting
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Form validation
            $('#questionnaireForm').on('submit', function(e) {
                var isValid = true;
                var requiredFields = $(this).find('[required]');
                
                requiredFields.each(function() {
                    if ($(this).is(':radio')) {
                        var name = $(this).attr('name');
                        if (!$('input[name="' + name + '"]:checked').length) {
                            isValid = false;
                            $(this).closest('.question-item').addClass('border-danger');
                        } else {
                            $(this).closest('.question-item').removeClass('border-danger');
                        }
                    } else if ($(this).is('textarea')) {
                        if ($(this).val().trim() === '') {
                            isValid = false;
                            $(this).closest('.question-item').addClass('border-danger');
                        } else {
                            $(this).closest('.question-item').removeClass('border-danger');
                        }
                    }
                });
                
                if (!isValid) {
                    e.preventDefault();
                    alert('Please answer all required questions before submitting.');
                    $('html, body').animate({
                        scrollTop: $('.border-danger').first().offset().top - 100
                    }, 500);
                } else {
                    // Show loading state
                    $('#submitBtn').prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Submitting...');
                }
            });

            // Real-time validation feedback
            $('input[type="radio"], textarea').on('change', function() {
                $(this).closest('.question-item').removeClass('border-danger');
            });

            // Character count for essay questions
            $('textarea').on('input', function() {
                var length = $(this).val().length;
                var questionItem = $(this).closest('.question-item');
                
                // Remove existing counter
                questionItem.find('.char-counter').remove();
                
                // Add character counter
                if (length > 0) {
                    $(this).after('<small class="form-text text-muted char-counter">Characters: ' + length + '</small>');
                }
            });
        });
    </script>
}

<style>
    .question-item {
        transition: border-color 0.3s ease;
    }
    
    .question-item.border-danger {
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25);
    }
    
    .question-number {
        font-weight: 600;
    }
    
    .question-text {
        font-size: 1.1rem;
        line-height: 1.5;
    }
    
    .form-check-input:checked {
        background-color: #0d6efd;
        border-color: #0d6efd;
    }
    
    .btn-success {
        background-color: #198754;
        border-color: #198754;
    }
    
    .btn-success:hover {
        background-color: #157347;
        border-color: #146c43;
    }
    
    .card-header {
        background-color: #f8f9fa;
        border-bottom: 1px solid #dee2e6;
    }
    
    .alert-info {
        background-color: #d1ecf1;
        border-color: #bee5eb;
        color: #0c5460;
    }
</style>
