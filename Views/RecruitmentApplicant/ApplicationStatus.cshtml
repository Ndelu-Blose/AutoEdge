@model IEnumerable<AutoEdge.Models.Entities.Application>

@{
    ViewData["Title"] = "My Applications";
}

<style>
    .modern-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }
    .modern-table thead th {
        background: linear-gradient(135deg, var(--primary-color) 0%, #34495e 100%);
        color: white;
        font-weight: 600;
        padding: 1rem;
        border: none;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .modern-table tbody tr {
        background: white;
        transition: all 0.2s ease;
        border-bottom: 1px solid var(--border-color);
    }
    .modern-table tbody tr:hover {
        background: #f8f9fa;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .modern-table tbody td {
        padding: 1.25rem 1rem;
        vertical-align: middle;
        color: var(--text-color);
    }
    /* Ensure table cells have proper width constraints */
    .modern-table th, .modern-table td {
        max-width: none;
    }
    .status-badge-app {
        display: inline-block;
        padding: 0.4rem 0.8rem;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.3px;
        white-space: nowrap;
        position: relative;
        vertical-align: middle;
    }
    .status-submitted { background: rgba(108, 117, 125, 0.15); color: #6c757d; }
    .status-review { background: rgba(243, 156, 18, 0.15); color: #f39c12; }
    .status-shortlisted { background: rgba(39, 174, 96, 0.15); color: #27ae60; }
    .status-interview { background: rgba(52, 152, 219, 0.15); color: #3498db; }
    .status-assessment { background: rgba(142, 68, 173, 0.15); color: #8e44ad; }
    .status-decision { background: rgba(44, 62, 80, 0.15); color: #2c3e50; }
    .status-rejected { background: rgba(231, 76, 60, 0.15); color: #e74c3c; }
</style>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-file-alt mr-2"></i>
                        My Job Applications
                    </h3>
                </div>
                <div class="card-body">
                    @if (Model.Any())
                    {
                        <div class="row">
                            <div class="col-lg-3 col-6">
                                <div class="small-box bg-info">
                                    <div class="inner">
                                        <h3>@Model.Count()</h3>
                                        <p>Total Applications</p>
                                    </div>
                                    <div class="icon">
                                        <i class="fas fa-file-alt"></i>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-3 col-6">
                                <div class="small-box bg-success">
                                    <div class="inner">
                                        <h3>@Model.Count(a => a.Status == "Shortlisted")</h3>
                                        <p>Shortlisted</p>
                                    </div>
                                    <div class="icon">
                                        <i class="fas fa-check-circle"></i>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-3 col-6">
                                <div class="small-box bg-warning">
                                    <div class="inner">
                                        <h3>@Model.Count(a => a.Status == "Interview Scheduled")</h3>
                                        <p>Interviews Scheduled</p>
                                    </div>
                                    <div class="icon">
                                        <i class="fas fa-video"></i>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-3 col-6">
                                <div class="small-box bg-primary">
                                    <div class="inner">
                                        <h3>@Model.Count(a => a.Status == "Assessment Sent")</h3>
                                        <p>Assessments Pending</p>
                                    </div>
                                    <div class="icon">
                                        <i class="fas fa-clipboard-check"></i>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h3 class="card-title">
                                            <i class="fas fa-history mr-2"></i>Application History
                                        </h3>
                                    </div>
                                    <div class="card-body">
                                        <div class="table-responsive">
                                            <table class="modern-table">
                                                <thead>
                                                    <tr>
                                                        <th><i class="fas fa-briefcase mr-2"></i>Position</th>
                                                        <th><i class="fas fa-building mr-2"></i>Department</th>
                                                        <th><i class="fas fa-calendar mr-2"></i>Applied Date</th>
                                                        <th><i class="fas fa-info-circle mr-2"></i>Status</th>
                                                        <th><i class="fas fa-chart-line mr-2"></i>Match Score</th>
                                                        <th><i class="fas fa-cogs mr-2"></i>Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var application in Model.OrderByDescending(a => a.SubmittedDate))
                                                    {
                                                        <tr>
                                                            <td>
                                                                <div class="font-weight-bold">@application.JobPosting?.JobTitle</div>
                                                            </td>
                                                            <td>
                                                                <span class="badge bg-info" style="padding: 0.35rem 0.75rem;">
                                                                    <i class="fas fa-building mr-1"></i>@application.JobPosting?.Department
                                                                </span>
                                                            </td>
                                                            <td>
                                                                <i class="fas fa-calendar-alt text-muted mr-1"></i>
                                                                @application.SubmittedDate.ToString("MMM dd, yyyy")
                                                            </td>
                                                            <td>
                                                                @switch (application.Status)
                                                                {
                                                                    case "Submitted":
                                                                        <span class="status-badge-app status-submitted">
                                                                            <i class="fas fa-paper-plane mr-1"></i>@application.Status
                                                                        </span>
                                                                        break;
                                                                    case "Under Review":
                                                                        <span class="status-badge-app status-review">
                                                                            <i class="fas fa-search mr-1"></i>Review
                                                                        </span>
                                                                        break;
                                                                    case "Shortlisted":
                                                                        <span class="status-badge-app status-shortlisted">
                                                                            <i class="fas fa-check-circle mr-1"></i>@application.Status
                                                                        </span>
                                                                        break;
                                                                    case "Interview Scheduled":
                                                                        <span class="status-badge-app status-interview">
                                                                            <i class="fas fa-video mr-1"></i>Interview
                                                                        </span>
                                                                        break;
                                                                    case "Assessment Sent":
                                                                        <span class="status-badge-app status-assessment">
                                                                            <i class="fas fa-clipboard-check mr-1"></i>Assessment
                                                                        </span>
                                                                        break;
                                                                    case "Final Decision":
                                                                        <span class="status-badge-app status-decision">
                                                                            <i class="fas fa-gavel mr-1"></i>Decision
                                                                        </span>
                                                                        break;
                                                                    case "Rejected":
                                                                        <span class="status-badge-app status-rejected">
                                                                            <i class="fas fa-times-circle mr-1"></i>@application.Status
                                                                        </span>
                                                                        break;
                                                                    default:
                                                                        <span class="status-badge-app status-submitted">
                                                                            @application.Status
                                                                        </span>
                                                                        break;
                                                                }
                                                            </td>
                                                            <td>
                                                                @if (application.MatchScore > 0)
                                                                {
                                                                    var scoreColor = application.MatchScore >= 70 ? "text-success" : application.MatchScore >= 50 ? "text-warning" : "text-danger";
                                                                    <div class="@scoreColor font-weight-bold">
                                                                        <i class="fas fa-chart-line mr-1"></i>@application.MatchScore.ToString("F1")%
                                                                    </div>
                                                                }
                                                                else
                                                                {
                                                                    <span class="text-muted">Pending</span>
                                                                }
                                                            </td>
                                                            <td>
                                                                <div class="d-flex gap-2 flex-wrap">
                                                                    <a href="@Url.Action("JobDetails", new { id = application.JobId })" class="btn btn-outline-primary btn-sm">
                                                                        <i class="fas fa-eye"></i>
                                                                    </a>
                                                                    @if (application.Status == "Interview Scheduled")
                                                                    {
                                                                        <a href="@Url.Action("JoinInterview", "RecruitmentApplicant", new { applicationId = application.ApplicationId })" class="btn btn-outline-success btn-sm">
                                                                            <i class="fas fa-video"></i>
                                                                        </a>
                                                                    }
                                                                    @if (application.Status == "Assessment Sent")
                                                                    {
                                                                        <a href="@Url.Action("Assessment", "RecruitmentApplicant", new { token = application.Assessments?.FirstOrDefault()?.AccessToken })" class="btn btn-outline-info btn-sm">
                                                                            <i class="fas fa-clipboard-check"></i>
                                                                        </a>
                                                                    }
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-file-alt fa-3x text-muted mb-3"></i>
                            <h4 class="text-muted">No Applications Found</h4>
                            <p class="text-muted">You haven't submitted any job applications yet.</p>
                            <a href="@Url.Action("VacantPositions")" class="btn btn-primary">
                                <i class="fas fa-search mr-2"></i>Browse Available Positions
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
