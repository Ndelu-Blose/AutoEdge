@model AutoEdge.Models.Entities.JobPosting
@{
    ViewData["Title"] = "Job Details";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-briefcase"></i> @Model.JobTitle
                    </h4>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong><i class="fas fa-building"></i> Department:</strong>
                            <span class="badge badge-info">@Model.Department</span>
                        </div>
                        <div class="col-md-6">
                            <strong><i class="fas fa-users"></i> Positions Available:</strong>
                            <span class="badge badge-success">@Model.PositionsAvailable</span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong><i class="fas fa-calendar"></i> Posted Date:</strong>
                            @Model.PostedDate.ToString("MMM dd, yyyy")
                        </div>
                        <div class="col-md-6">
                            <strong><i class="fas fa-clock"></i> Closing Date:</strong>
                            @Model.ClosingDate.ToString("MMM dd, yyyy")
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong><i class="fas fa-chart-line"></i> Experience Required:</strong>
                            @Model.MinYearsExperience+ years
                        </div>
                        <div class="col-md-6">
                            <strong><i class="fas fa-info-circle"></i> Status:</strong>
                            <span class="badge badge-@(Model.Status == "Active" ? "success" : "secondary")">@Model.Status</span>
                        </div>
                    </div>

                    <hr>

                    <h5><i class="fas fa-file-alt"></i> Job Description</h5>
                    <p class="text-justify">@Model.JobDescription</p>

                    <h5><i class="fas fa-tasks"></i> Responsibilities</h5>
                    <ul>
                        @foreach (var responsibility in Model.Responsibilities.Split(','))
                        {
                            <li>@responsibility.Trim()</li>
                        }
                    </ul>

                    <h5><i class="fas fa-requirements"></i> Requirements</h5>
                    <ul>
                        @foreach (var requirement in Model.Requirements.Split(','))
                        {
                            <li>@requirement.Trim()</li>
                        }
                    </ul>

                    <h5><i class="fas fa-graduation-cap"></i> Required Qualifications</h5>
                    <ul>
                        @foreach (var qualification in Model.RequiredQualifications.Split(','))
                        {
                            <li>@qualification.Trim()</li>
                        }
                    </ul>

                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <h5><i class="fas fa-sticky-note"></i> Additional Notes</h5>
                        <p class="text-justify">@Model.Notes</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-paper-plane"></i> Apply for this Position
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.Status == "Active" && Model.ClosingDate > DateTime.Now)
                    {
                        <p class="text-muted mb-3">
                            Ready to join our team? Click the button below to start your application.
                        </p>
                        <a asp-controller="RecruitmentApplicant" asp-action="Apply" asp-route-id="@Model.JobId" 
                           class="btn btn-success btn-lg btn-block">
                            <i class="fas fa-paper-plane"></i> Apply Now
                        </a>
                    }
                    else if (Model.Status != "Active")
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle"></i>
                            <strong>Position Closed</strong><br>
                            This position is no longer accepting applications.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-calendar-times"></i>
                            <strong>Application Deadline Passed</strong><br>
                            The application deadline for this position has passed.
                        </div>
                    }

                    <hr>

                    <div class="text-center">
                        <a asp-controller="RecruitmentApplicant" asp-action="VacantPositions" 
                           class="btn btn-outline-primary">
                            <i class="fas fa-arrow-left"></i> Back to All Positions
                        </a>
                    </div>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header">
                    <h6 class="mb-0">
                        <i class="fas fa-info-circle"></i> Application Information
                    </h6>
                </div>
                <div class="card-body">
                    <small class="text-muted">
                        <strong>Application Process:</strong><br>
                        1. Complete the online application form<br>
                        2. Upload your resume and documents<br>
                        3. Our team will review your application<br>
                        4. Shortlisted candidates will be contacted<br>
                        5. Interview and assessment process<br>
                        6. Final decision and offer
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Add any JavaScript functionality here if needed
        $(document).ready(function() {
            // Example: Add smooth scrolling or other interactions
        });
    </script>
}

