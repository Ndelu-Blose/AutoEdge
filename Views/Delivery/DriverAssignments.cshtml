@model IEnumerable<AutoEdge.Models.Entities.Delivery>
@{
    ViewData["Title"] = "Driver Assignments";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-clipboard-list"></i> Driver Assignments</h2>
        <div>
            <button class="btn btn-outline-primary" onclick="refreshAssignments()">
                <i class="fas fa-sync-alt"></i> Refresh
            </button>
            @if (User.IsInRole("Admin"))
            {
                <a href="@Url.Action("Index", "Admin")" class="btn btn-outline-secondary">
                    <i class="fas fa-tachometer-alt"></i> Admin Dashboard
                </a>
            }
        </div>
    </div>

    <!-- Status Filter Tabs -->
    <ul class="nav nav-tabs mb-4" id="statusTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="all-tab" data-bs-toggle="tab" data-bs-target="#all" type="button" role="tab">
                All <span class="badge bg-secondary ms-1">@Model.Count()</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="scheduled-tab" data-bs-toggle="tab" data-bs-target="#scheduled" type="button" role="tab">
                Scheduled <span class="badge bg-info ms-1">@Model.Count(d => d.Status == "Scheduled")</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="intransit-tab" data-bs-toggle="tab" data-bs-target="#intransit" type="button" role="tab">
                In Transit <span class="badge bg-warning ms-1">@Model.Count(d => d.Status == "InTransit")</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="delivered-tab" data-bs-toggle="tab" data-bs-target="#delivered" type="button" role="tab">
                Delivered <span class="badge bg-success ms-1">@Model.Count(d => d.Status == "Delivered")</span>
            </button>
        </li>
    </ul>

    <div class="tab-content" id="statusTabContent">
        <!-- All Deliveries -->
        <div class="tab-pane fade show active" id="all" role="tabpanel">
            @await Html.PartialAsync("_DeliveryAssignmentsList", Model)
        </div>
        
        <!-- Scheduled Deliveries -->
        <div class="tab-pane fade" id="scheduled" role="tabpanel">
            @await Html.PartialAsync("_DeliveryAssignmentsList", Model.Where(d => d.Status == "Scheduled"))
        </div>
        
        <!-- In Transit Deliveries -->
        <div class="tab-pane fade" id="intransit" role="tabpanel">
            @await Html.PartialAsync("_DeliveryAssignmentsList", Model.Where(d => d.Status == "InTransit"))
        </div>
        
        <!-- Delivered Deliveries -->
        <div class="tab-pane fade" id="delivered" role="tabpanel">
            @await Html.PartialAsync("_DeliveryAssignmentsList", Model.Where(d => d.Status == "Delivered"))
        </div>
    </div>
</div>

<!-- Quick Status Update Modal -->
<div class="modal fade" id="statusUpdateModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Update Delivery Status</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="deliveryInfo" class="mb-3"></div>
                <div class="mb-3">
                    <label for="newStatus" class="form-label">New Status</label>
                    <select class="form-select" id="newStatus" required>
                        <option value="">Select status...</option>
                        <option value="Scheduled">Scheduled</option>
                        <option value="InTransit">In Transit</option>
                        <option value="Delivered">Delivered</option>
                        <option value="Failed">Failed</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
                <div class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="updateLocation">
                        <label class="form-check-label" for="updateLocation">
                            Update my current location
                        </label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="submitStatusUpdate()">Update Status</button>
            </div>
        </div>
    </div>
</div>

<script>
let currentDeliveryId = null;

// Refresh assignments
function refreshAssignments() {
    location.reload();
}

// Show status update modal
function showStatusModal(deliveryId, trackingNumber, vehicleInfo, currentStatus) {
    currentDeliveryId = deliveryId;
    
    document.getElementById('deliveryInfo').innerHTML = `
        <strong>Tracking:</strong> ${trackingNumber}<br>
        <strong>Vehicle:</strong> ${vehicleInfo}<br>
        <strong>Current Status:</strong> <span class="badge bg-secondary">${currentStatus}</span>
    `;
    
    document.getElementById('newStatus').value = currentStatus;
    
    const modal = new bootstrap.Modal(document.getElementById('statusUpdateModal'));
    modal.show();
}

// Submit status update
function submitStatusUpdate() {
    const newStatus = document.getElementById('newStatus').value;
    const updateLocation = document.getElementById('updateLocation').checked;
    
    if (!newStatus) {
        alert('Please select a status');
        return;
    }
    
    if (updateLocation && navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(
            position => updateDeliveryStatus(currentDeliveryId, newStatus, position.coords.latitude, position.coords.longitude),
            () => updateDeliveryStatus(currentDeliveryId, newStatus, null, null)
        );
    } else {
        updateDeliveryStatus(currentDeliveryId, newStatus, null, null);
    }
}

// Update delivery status
function updateDeliveryStatus(deliveryId, status, latitude, longitude) {
    const formData = new FormData();
    formData.append('id', deliveryId);
    formData.append('status', status);
    if (latitude && longitude) {
        formData.append('latitude', latitude);
        formData.append('longitude', longitude);
    }
    
    fetch('@Url.Action("UpdateStatus")', {
        method: 'POST',
        headers: {
            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
        },
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('statusUpdateModal')).hide();
            location.reload();
        } else {
            alert('Error updating status: ' + data.message);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('Error updating status');
    });
}

// Quick status update buttons
function quickStatusUpdate(deliveryId, status) {
    if (confirm(`Are you sure you want to update status to "${status}"?`)) {
        updateDeliveryStatus(deliveryId, status, null, null);
    }
}

// Auto-refresh every 5 minutes
setInterval(refreshAssignments, 300000);
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}