@model IEnumerable<AutoEdge.Models.Entities.Interview>
@{
    ViewData["Title"] = "Interview Schedule";
}

<style>
    .modern-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }
    .modern-table thead th {
        background: linear-gradient(135deg, var(--primary-color) 0%, #34495e 100%);
        color: white;
        font-weight: 600;
        padding: 1rem;
        border: none;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .modern-table tbody tr {
        background: white;
        transition: all 0.2s ease;
        border-bottom: 1px solid var(--border-color);
    }
    .modern-table tbody tr:hover {
        background: #f8f9fa;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .modern-table tbody td {
        padding: 1.25rem 1rem;
        vertical-align: middle;
        color: #333 !important;
        font-size: 0.95rem;
    }
</style>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-calendar-alt"></i> Interview Schedule
                    </h4>
                </div>
                <div class="card-body">
                    @if (Model != null && Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="modern-table">
                                <thead>
                                    <tr>
                                        <th><i class="fas fa-user mr-2"></i>Candidate</th>
                                        <th><i class="fas fa-briefcase mr-2"></i>Job Position</th>
                                        <th><i class="fas fa-calendar-alt mr-2"></i>Interview Date & Time</th>
                                        <th><i class="fas fa-clock mr-2"></i>Duration</th>
                                        <th><i class="fas fa-user-tie mr-2"></i>Recruiter</th>
                                        <th><i class="fas fa-info-circle mr-2"></i>Status</th>
                                        <th><i class="fas fa-cogs mr-2"></i>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var interview in Model.OrderBy(i => i.ScheduledDateTime))
                                    {
                                        <tr>
                                            <td style="font-weight: 500;">
                                                @interview.Application.FirstName @interview.Application.LastName<br>
                                                <small class="text-muted">@interview.Application.Email</small>
                                            </td>
                                            <td>
                                                <span class="badge bg-primary" style="padding: 0.35rem 0.75rem;">
                                                    @interview.JobPosting.JobTitle
                                                </span><br>
                                                <small class="text-muted">@interview.JobPosting.Department</small>
                                            </td>
                                            <td>
                                                <i class="fas fa-calendar-alt text-muted mr-1"></i>
                                                @interview.ScheduledDateTime.ToString("MMM dd, yyyy")<br>
                                                <i class="fas fa-clock text-muted mr-1"></i>
                                                @interview.ScheduledDateTime.ToString("HH:mm")
                                            </td>
                                            <td>
                                                <span class="badge bg-info" style="padding: 0.35rem 0.75rem;">
                                                    @interview.DurationMinutes min
                                                </span>
                                            </td>
                                            <td>
                                                <strong>@interview.RecruiterName</strong><br>
                                                <small class="text-muted">@interview.RecruiterEmail</small>
                                            </td>
                                            <td>
                                                @if (interview.IsCompleted)
                                                {
                                                    <span class="badge bg-success" style="padding: 0.35rem 0.75rem;">
                                                        <i class="fas fa-check mr-1"></i>Completed
                                                    </span>
                                                }
                                                else if (interview.ScheduledDateTime > DateTime.Now)
                                                {
                                                    <span class="badge bg-warning text-dark" style="padding: 0.35rem 0.75rem;">
                                                        <i class="fas fa-clock mr-1"></i>Upcoming
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger" style="padding: 0.35rem 0.75rem;">
                                                        <i class="fas fa-exclamation mr-1"></i>Overdue
                                                    </span>
                                                }
                                            </td>
                                            <td>
                                                <div class="d-flex gap-2">
                                                    @if (!string.IsNullOrEmpty(interview.MeetingLink))
                                                    {
                                                        <a href="@interview.MeetingLink" target="_blank" class="btn btn-outline-primary btn-sm" title="Join Meeting">
                                                            <i class="fas fa-video"></i>
                                                        </a>
                                                    }
                                                    <a asp-controller="RecruitmentAdmin" asp-action="ViewApplication" asp-route-id="@interview.ApplicationId" 
                                                       class="btn btn-outline-info btn-sm" title="View Application">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    @if (!interview.IsCompleted)
                                                    {
                                                        <a asp-controller="RecruitmentAdmin" asp-action="MarkInterviewComplete" asp-route-id="@interview.InterviewId" 
                                                           class="btn btn-outline-success btn-sm" title="Mark Complete">
                                                            <i class="fas fa-check"></i>
                                                        </a>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-calendar-times fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">No interviews scheduled</h5>
                            <p class="text-muted">There are currently no interviews scheduled.</p>
                            <a asp-controller="RecruitmentAdmin" asp-action="Applications" class="btn btn-primary">
                                <i class="fas fa-users"></i> View Applications
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row mt-4">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h6 class="mb-0">
                            <i class="fas fa-chart-pie"></i> Interview Statistics
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-4">
                                <h4 class="text-warning">@Model.Count(i => !i.IsCompleted && i.ScheduledDateTime > DateTime.Now)</h4>
                                <small class="text-muted">Upcoming</small>
                            </div>
                            <div class="col-4">
                                <h4 class="text-success">@Model.Count(i => i.IsCompleted)</h4>
                                <small class="text-muted">Completed</small>
                            </div>
                            <div class="col-4">
                                <h4 class="text-danger">@Model.Count(i => !i.IsCompleted && i.ScheduledDateTime <= DateTime.Now)</h4>
                                <small class="text-muted">Overdue</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h6 class="mb-0">
                            <i class="fas fa-calendar-week"></i> This Week's Interviews
                        </h6>
                    </div>
                    <div class="card-body">
                        @{
                            var thisWeekInterviews = Model.Where(i => i.ScheduledDateTime >= DateTime.Now.AddDays(-(int)DateTime.Now.DayOfWeek) 
                                                                   && i.ScheduledDateTime < DateTime.Now.AddDays(-(int)DateTime.Now.DayOfWeek + 7))
                                                          .OrderBy(i => i.ScheduledDateTime);
                        }
                        @if (thisWeekInterviews.Any())
                        {
                            <ul class="list-unstyled">
                                @foreach (var interview in thisWeekInterviews.Take(5))
                                {
                                    <li class="mb-2">
                                        <strong>@interview.ScheduledDateTime.ToString("ddd, MMM dd")</strong><br>
                                        <small class="text-muted">
                                            @interview.ScheduledDateTime.ToString("HH:mm") - 
                                            @interview.Application.FirstName @interview.Application.LastName
                                        </small>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-muted">No interviews scheduled for this week.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Add any JavaScript functionality here
        });
    </script>
}

