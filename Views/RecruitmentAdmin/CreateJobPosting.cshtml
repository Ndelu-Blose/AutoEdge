@model AutoEdge.Models.Entities.JobPosting

@{
    ViewData["Title"] = "Create Job Posting";
    var departments = ViewBag.Departments as List<string>;
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-plus mr-2"></i>
                        Create New Job Posting
                    </h3>
                </div>
                <div class="card-body">
                    <form asp-action="CreateJobPosting" method="post">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="JobTitle" class="control-label">Job Title *</label>
                                    <input asp-for="JobTitle" class="form-control" placeholder="e.g., Senior Mechanical Engineer" />
                                    <span asp-validation-for="JobTitle" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Department" class="control-label">Department *</label>
                                    <select asp-for="Department" class="form-control">
                                        <option value="">Select Department</option>
                                        @foreach (var dept in departments)
                                        {
                                            <option value="@dept">@dept</option>
                                        }
                                    </select>
                                    <span asp-validation-for="Department" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="MinYearsExperience" class="control-label">Minimum Years of Experience *</label>
                                    <input asp-for="MinYearsExperience" type="number" class="form-control" min="0" max="20" />
                                    <span asp-validation-for="MinYearsExperience" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="PositionsAvailable" class="control-label">Number of Positions *</label>
                                    <input asp-for="PositionsAvailable" type="number" class="form-control" min="1" max="100" />
                                    <span asp-validation-for="PositionsAvailable" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="ClosingDate" class="control-label">Closing Date *</label>
                                    <input asp-for="ClosingDate" type="datetime-local" class="form-control" />
                                    <span asp-validation-for="ClosingDate" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Status" class="control-label">Status *</label>
                                    <select asp-for="Status" class="form-control">
                                        <option value="Draft">Draft</option>
                                        <option value="Active">Active</option>
                                        <option value="Closed">Closed</option>
                                    </select>
                                    <span asp-validation-for="Status" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="JobDescription" class="control-label">Job Description *</label>
                            <textarea asp-for="JobDescription" class="form-control" rows="6" placeholder="Describe the role, responsibilities, and what the candidate will be doing..."></textarea>
                            <span asp-validation-for="JobDescription" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Requirements" class="control-label">Requirements *</label>
                            <textarea asp-for="Requirements" class="form-control" rows="6" placeholder="List the required skills, qualifications, and experience..."></textarea>
                            <span asp-validation-for="Requirements" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Responsibilities" class="control-label">Key Responsibilities *</label>
                            <textarea asp-for="Responsibilities" class="form-control" rows="6" placeholder="List the main responsibilities and duties..."></textarea>
                            <span asp-validation-for="Responsibilities" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="RequiredQualifications" class="control-label">Required Qualifications *</label>
                            <textarea asp-for="RequiredQualifications" class="form-control" rows="4" placeholder="List required education, certifications, licenses..."></textarea>
                            <span asp-validation-for="RequiredQualifications" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Notes" class="control-label">Additional Notes</label>
                            <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Any additional information or special requirements..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save mr-2"></i>Create Job Posting
                            </button>
                            <a href="@Url.Action("JobPostings")" class="btn btn-secondary ml-2">
                                <i class="fas fa-arrow-left mr-2"></i>Back to Job Postings
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
