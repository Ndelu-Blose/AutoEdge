@model IEnumerable<AutoEdge.Models.Entities.JobPosting>

@{
    ViewData["Title"] = "Job Postings Management";
}

<style>
    .modern-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }
    .modern-table thead th {
        background: linear-gradient(135deg, var(--primary-color) 0%, #34495e 100%);
        color: white;
        font-weight: 600;
        padding: 1rem;
        border: none;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .modern-table tbody tr {
        background: white;
        transition: all 0.2s ease;
        border-bottom: 1px solid var(--border-color);
    }
    .modern-table tbody tr:hover {
        background: #f8f9fa;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .modern-table tbody td {
        padding: 1.25rem 1rem;
        vertical-align: middle;
        color: #333 !important;
        font-size: 0.95rem;
    }
</style>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-briefcase mr-2"></i>
                        Job Postings Management
                    </h3>
                    <div class="card-tools">
                        <a href="@Url.Action("CreateJobPosting")" class="btn btn-primary btn-sm">
                            <i class="fas fa-plus mr-1"></i>Create New Job Posting
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="modern-table">
                                <thead>
                                    <tr>
                                        <th><i class="fas fa-briefcase mr-2"></i>Job Title</th>
                                        <th><i class="fas fa-building mr-2"></i>Department</th>
                                        <th><i class="fas fa-info-circle mr-2"></i>Status</th>
                                        <th><i class="fas fa-users mr-2"></i>Applications</th>
                                        <th><i class="fas fa-calendar mr-2"></i>Posted Date</th>
                                        <th><i class="fas fa-calendar-times mr-2"></i>Closing Date</th>
                                        <th><i class="fas fa-user mr-2"></i>Created By</th>
                                        <th><i class="fas fa-cogs mr-2"></i>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var job in Model)
                                    {
                                        <tr>
                                            <td style="font-weight: 500;">@job.JobTitle</td>
                                            <td>
                                                <span class="badge bg-info" style="padding: 0.35rem 0.75rem;">
                                                    <i class="fas fa-building mr-1"></i>@job.Department
                                                </span>
                                            </td>
                                            <td>
                                                @if (job.Status == "Active")
                                                {
                                                    <span class="badge bg-success" style="padding: 0.35rem 0.75rem;">@job.Status</span>
                                                }
                                                else if (job.Status == "Closed")
                                                {
                                                    <span class="badge bg-danger" style="padding: 0.35rem 0.75rem;">@job.Status</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning text-dark" style="padding: 0.35rem 0.75rem;">@job.Status</span>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge bg-primary" style="padding: 0.35rem 0.75rem;">
                                                    <i class="fas fa-users mr-1"></i>@job.Applications.Count
                                                </span>
                                            </td>
                                            <td>
                                                <i class="fas fa-calendar-alt text-muted mr-1"></i>
                                                @job.PostedDate.ToString("MMM dd, yyyy")
                                            </td>
                                            <td>
                                                <i class="fas fa-calendar-times text-muted mr-1"></i>
                                                @job.ClosingDate.ToString("MMM dd, yyyy")
                                            </td>
                                            <td>
                                                <i class="fas fa-user text-muted mr-1"></i>
                                                @job.CreatedBy?.FirstName @job.CreatedBy?.LastName
                                            </td>
                                            <td>
                                                <div class="d-flex gap-2">
                                                    <a href="@Url.Action("EditJobPosting", new { id = job.JobId })" class="btn btn-outline-primary btn-sm">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a href="@Url.Action("Applications", new { jobId = job.JobId })" class="btn btn-outline-info btn-sm">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a href="@Url.Action("ShortlistCandidates", new { jobId = job.JobId })" class="btn btn-outline-success btn-sm">
                                                        <i class="fas fa-users"></i>
                                                    </a>
                                                    <a href="@Url.Action("VacantPositions", "RecruitmentApplicant", new { id = job.JobId })" class="btn btn-outline-secondary btn-sm" target="_blank">
                                                        <i class="fas fa-external-link-alt"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-briefcase fa-3x text-muted mb-3"></i>
                            <h4 class="text-muted">No Job Postings Found</h4>
                            <p class="text-muted">Create your first job posting to start recruiting.</p>
                            <a href="@Url.Action("CreateJobPosting")" class="btn btn-primary">
                                <i class="fas fa-plus mr-2"></i>Create Job Posting
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
