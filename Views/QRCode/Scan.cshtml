@{
    ViewData["Title"] = "QR Code Scanner";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0"><i class="fas fa-qrcode me-2"></i>Service Booking QR Code Scanner</h3>
                </div>
                <div class="card-body">
                    <div id="scanner-section">
                        <div class="text-center mb-4">
                            <h5>Scan Service Booking QR Code</h5>
                            <p class="text-muted">Scan the QR code from the customer's email to verify and check in their service booking.</p>
                        </div>

                        <!-- QR Code Input -->
                        <div class="mb-4">
                            <label for="qrCodeInput" class="form-label">QR Code Data:</label>
                            <div class="input-group">
                                <input type="text" id="qrCodeInput" class="form-control" placeholder="Enter QR code data or scan with device camera" />
                                <button class="btn btn-outline-secondary" type="button" id="scanButton">
                                    <i class="fas fa-camera me-2"></i>Scan
                                </button>
                            </div>
                            <small class="form-text text-muted">You can manually enter QR code data or use your device camera to scan.</small>
                        </div>

                        <!-- Camera Section -->
                        <div id="camera-section" class="text-center mb-4" style="display: none;">
                            <video id="video" width="300" height="200" style="border: 2px solid #007bff;"></video>
                            <div class="mt-2">
                                <button class="btn btn-success" id="captureButton">
                                    <i class="fas fa-camera me-2"></i>Capture QR Code
                                </button>
                                <button class="btn btn-secondary" id="stopCameraButton">
                                    <i class="fas fa-stop me-2"></i>Stop Camera
                                </button>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="text-center">
                            <button class="btn btn-primary btn-lg" id="verifyButton" disabled>
                                <i class="fas fa-search me-2"></i>Verify QR Code
                            </button>
                        </div>
                    </div>

                    <!-- Loading -->
                    <div id="loading-section" class="text-center" style="display: none;">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="mt-2">Processing QR code...</p>
                    </div>

                    <!-- Results -->
                    <div id="results-section" style="display: none;">
                        <!-- Booking verification results will be displayed here -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bootstrap Modal for QR Code Verification -->
<div class="modal fade" id="verificationModal" tabindex="-1" aria-labelledby="verificationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="verificationModalLabel">Booking Verification</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="verificationModalBody">
                <!-- Booking details will be loaded here -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success" id="confirmCheckInButton">
                    <i class="fas fa-check me-2"></i>Confirm Check-In
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Success Modal -->
<div class="modal fade" id="successModal" tabindex="-1" aria-labelledby="successModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="successModalLabel">
                    <i class="fas fa-check-circle me-2"></i>Check-In Successful!
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="successModalBody">
                <!-- Success details will be loaded here -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">OK</button>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const qrCodeInput = document.getElementById('qrCodeInput');
    const scanButton = document.getElementById('scanButton');
    const verifyButton = document.getElementById('verifyButton');
    const captureButton = document.getElementById('captureButton');
    const stopCameraButton = document.getElementById('stopCameraButton');
    const confirmCheckInButton = document.getElementById('confirmCheckInButton');
    
    let currentStream = null;
    let currentQRCodeData = null;

    // Enable verify button when QR code is entered
    qrCodeInput.addEventListener('input', function() {
        verifyButton.disabled = !this.value.trim();
    });

    // Scan button - show camera
    scanButton.addEventListener('click', function() {
        document.getElementById('camera-section').style.display = 'block';
        startCamera();
    });

    // Stop camera button
    stopCameraButton.addEventListener('click', function() {
        stopCamera();
        document.getElementById('camera-section').style.display = 'none';
    });

    // Verify button
    verifyButton.addEventListener('click', function() {
        const qrData = qrCodeInput.value.trim();
        if (qrData) {
            verifyQRCode(qrData);
        }
    });

    // Capture button
    captureButton.addEventListener('click', function() {
        // In a real implementation, you would use a QR code library to decode from video
        // For now, we'll just show an alert
        alert('QR code capture functionality requires a QR code scanning library. Please enter the QR code data manually.');
    });

    // Confirm check-in button
    confirmCheckInButton.addEventListener('click', function() {
        if (currentQRCodeData) {
            checkInBooking(currentQRCodeData);
        }
    });

    function startCamera() {
        navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } })
            .then(function(stream) {
                currentStream = stream;
                const video = document.getElementById('video');
                video.srcObject = stream;
                video.play();
            })
            .catch(function(err) {
                console.error('Error accessing camera:', err);
                alert('Unable to access camera. Please enter QR code data manually.');
            });
    }

    function stopCamera() {
        if (currentStream) {
            currentStream.getTracks().forEach(track => track.stop());
            currentStream = null;
            const video = document.getElementById('video');
            video.srcObject = null;
        }
    }

    function verifyQRCode(qrData) {
        showLoading();
        
        fetch('/QRCode/Scan', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            },
            body: JSON.stringify(qrData)
        })
        .then(response => response.json())
        .then(data => {
            hideLoading();
            
            if (data.success) {
                currentQRCodeData = qrData;
                showBookingDetails(data.booking);
            } else {
                showError(data.message);
            }
        })
        .catch(error => {
            hideLoading();
            console.error('Error:', error);
            showError('Error verifying QR code. Please try again.');
        });
    }

    function checkInBooking(qrData) {
        showLoading();
        
        fetch('/QRCode/CheckIn', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            },
            body: JSON.stringify(qrData)
        })
        .then(response => response.json())
        .then(data => {
            hideLoading();
            
            if (data.success) {
                // Close verification modal
                const verificationModal = bootstrap.Modal.getInstance(document.getElementById('verificationModal'));
                verificationModal.hide();
                
                // Show success modal
                showSuccess(data);
            } else {
                showError(data.message);
            }
        })
        .catch(error => {
            hideLoading();
            console.error('Error:', error);
            showError('Error checking in booking. Please try again.');
        });
    }

    function showBookingDetails(booking) {
        const modalBody = document.getElementById('verificationModalBody');
        modalBody.innerHTML = `
            <div class="alert alert-info">
                <h6><i class="fas fa-info-circle me-2"></i>Please verify the booking details below:</h6>
            </div>
            
            <div class="row">
                <div class="col-md-6">
                    <h6>Customer Information</h6>
                    <p><strong>Name:</strong> ${booking.customerName}</p>
                    <p><strong>Email:</strong> ${booking.customerEmail}</p>
                </div>
                <div class="col-md-6">
                    <h6>Vehicle Information</h6>
                    <p><strong>Vehicle:</strong> ${booking.vehicle}</p>
                    <p><strong>Service Type:</strong> <span class="badge bg-primary">${booking.serviceType}</span></p>
                </div>
            </div>
            
            <hr>
            
            <div class="row">
                <div class="col-md-6">
                    <h6>Service Details</h6>
                    <p><strong>Booking Reference:</strong> <code>${booking.reference}</code></p>
                    <p><strong>Scheduled Date:</strong> ${booking.scheduledDate}</p>
                    <p><strong>Scheduled Time:</strong> ${booking.scheduledTime}</p>
                    <p><strong>Delivery Method:</strong> ${booking.deliveryMethod}</p>
                </div>
                <div class="col-md-6">
                    <h6>Service Information</h6>
                    <p><strong>Duration:</strong> ${booking.estimatedDuration} minutes</p>
                    <p><strong>Estimated Cost:</strong> $${booking.estimatedCost.toFixed(2)}</p>
                    ${booking.notes ? `<p><strong>Notes:</strong> ${booking.notes}</p>` : ''}
                </div>
            </div>
        `;
        
        const modal = new bootstrap.Modal(document.getElementById('verificationModal'));
        modal.show();
    }

    function showSuccess(data) {
        const modalBody = document.getElementById('successModalBody');
        modalBody.innerHTML = `
            <div class="alert alert-success">
                <h6><i class="fas fa-check-circle me-2"></i>Booking Successfully Checked In!</h6>
            </div>
            
            <div class="text-center">
                <h5>${data.booking.customerName}</h5>
                <p class="text-muted">${data.booking.vehicle}</p>
                <p><strong>Reference:</strong> <code>${data.booking.reference}</code></p>
                <p><strong>Check-in Time:</strong> ${data.booking.checkInTime}</p>
                <p><strong>Service Type:</strong> <span class="badge bg-success">${data.booking.serviceType}</span></p>
            </div>
            
            <div class="alert alert-info mt-3">
                <small>The customer has been successfully checked in and can now proceed with their service appointment.</small>
            </div>
        `;
        
        const modal = new bootstrap.Modal(document.getElementById('successModal'));
        modal.show();
        
        // Reset form after successful check-in
        setTimeout(() => {
            qrCodeInput.value = '';
            verifyButton.disabled = true;
            currentQRCodeData = null;
        }, 3000);
    }

    function showError(message) {
        const resultsSection = document.getElementById('results-section');
        resultsSection.innerHTML = `
            <div class="alert alert-danger">
                <h6><i class="fas fa-exclamation-triangle me-2"></i>Error</h6>
                <p>${message}</p>
            </div>
        `;
        resultsSection.style.display = 'block';
        
        // Hide after 5 seconds
        setTimeout(() => {
            resultsSection.style.display = 'none';
        }, 5000);
    }

    function showLoading() {
        document.getElementById('scanner-section').style.display = 'none';
        document.getElementById('results-section').style.display = 'none';
        document.getElementById('loading-section').style.display = 'block';
    }

    function hideLoading() {
        document.getElementById('loading-section').style.display = 'none';
        document.getElementById('scanner-section').style.display = 'block';
    }

    // Clean up camera when page is unloaded
    window.addEventListener('beforeunload', function() {
        stopCamera();
    });
});
</script>
