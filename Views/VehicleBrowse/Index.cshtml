@model IEnumerable<AutoEdge.Models.Entities.Vehicle>

@{
    ViewData["Title"] = "Browse Vehicles";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 mb-0">Browse Vehicles</h1>
                    <p class="text-muted">Find your perfect vehicle from our inventory</p>
                </div>
                <div class="text-end">
                    <span class="badge bg-primary fs-6">@ViewBag.TotalCount vehicles available</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filter Section -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="fas fa-search me-2"></i>Search & Filter
                        <button class="btn btn-sm btn-outline-secondary float-end" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse">
                            <i class="fas fa-filter"></i> Advanced Filters
                        </button>
                    </h5>
                </div>
                <div class="card-body">
                    <form method="get" id="searchForm">
                        <!-- Basic Search -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                                    <input type="text" class="form-control" name="searchTerm" value="@ViewBag.CurrentSearchTerm" placeholder="Search by make, model, or features...">
                                </div>
                            </div>
                            <div class="col-md-3">
                                <select class="form-select" name="sortBy">
                                    <option value="price_asc" selected="@(ViewBag.CurrentSortBy == "price_asc")">Price: Low to High</option>
                                    <option value="price_desc" selected="@(ViewBag.CurrentSortBy == "price_desc")">Price: High to Low</option>
                                    <option value="year_desc" selected="@(ViewBag.CurrentSortBy == "year_desc")">Year: Newest First</option>
                                    <option value="year_asc" selected="@(ViewBag.CurrentSortBy == "year_asc")">Year: Oldest First</option>
                                    <option value="mileage_asc" selected="@(ViewBag.CurrentSortBy == "mileage_asc")">Mileage: Low to High</option>
                                    <option value="mileage_desc" selected="@(ViewBag.CurrentSortBy == "mileage_desc")">Mileage: High to Low</option>
                                    <option value="make_asc" selected="@(ViewBag.CurrentSortBy == "make_asc")">Make: A to Z</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="fas fa-search"></i> Search
                                </button>
                            </div>
                        </div>

                        <!-- Advanced Filters -->
                        <div class="collapse" id="filterCollapse">
                            <div class="row">
                                <div class="col-md-3">
                                    <label class="form-label">Make</label>
                                    <select class="form-select" name="make">
                                        <option value="">All Makes</option>
                                        @foreach (var make in ViewBag.Makes)
                                        {
                                            <option value="@make" selected="@(ViewBag.CurrentMake == make)">@make</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Body Type</label>
                                    <select class="form-select" name="bodyType">
                                        <option value="">All Body Types</option>
                                        @foreach (var bodyType in ViewBag.BodyTypes)
                                        {
                                            <option value="@bodyType" selected="@(ViewBag.CurrentBodyType == bodyType)">@bodyType</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Fuel Type</label>
                                    <select class="form-select" name="fuelType">
                                        <option value="">All Fuel Types</option>
                                        @foreach (var fuelType in ViewBag.FuelTypes)
                                        {
                                            <option value="@fuelType" selected="@(ViewBag.CurrentFuelType == fuelType)">@fuelType</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Transmission</label>
                                    <select class="form-select" name="transmission">
                                        <option value="">All Transmissions</option>
                                        @foreach (var transmission in ViewBag.Transmissions)
                                        {
                                            <option value="@transmission" selected="@(ViewBag.CurrentTransmission == transmission)">@transmission</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="row mt-3">
                                <div class="col-md-3">
                                    <label class="form-label">Min Price</label>
                                    <input type="number" class="form-control" name="minPrice" value="@ViewBag.CurrentMinPrice" placeholder="$0">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Max Price</label>
                                    <input type="number" class="form-control" name="maxPrice" value="@ViewBag.CurrentMaxPrice" placeholder="$999,999">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Min Year</label>
                                    <input type="number" class="form-control" name="minYear" value="@ViewBag.CurrentMinYear" placeholder="1990">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Max Year</label>
                                    <input type="number" class="form-control" name="maxYear" value="@ViewBag.CurrentMaxYear" placeholder="@DateTime.Now.Year">
                                </div>
                            </div>
                            <div class="row mt-3">
                                <div class="col-12">
                                    <button type="submit" class="btn btn-primary me-2">
                                        <i class="fas fa-filter"></i> Apply Filters
                                    </button>
                                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                                        <i class="fas fa-times"></i> Clear All
                                    </a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

        <!-- Vehicle Grid -->
        <div class="row">
            @if (Model.Any())
            {
                @foreach (var vehicle in Model)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                        <div class="vehicle-card">
                            <div class="vehicle-image-container">
                                @if (vehicle.VehicleImages != null && vehicle.VehicleImages.Any())
                                {
                                    var firstImage = vehicle.VehicleImages.First().ImagePath;
                                    <img src="@firstImage" class="vehicle-image" alt="@vehicle.Make @vehicle.Model">
                                }
                                else
                                {
                                    <div class="no-image-placeholder">
                                        <i class="fas fa-car fa-3x"></i>
                                        <span class="mt-2">No Image Available</span>
                                    </div>
                                }
                                <div class="status-badge">
                                    <span class="badge bg-success">Available</span>
                                </div>
                                <div class="quick-actions">
                                    <button class="btn btn-icon" title="Add to Favorites">
                                        <i class="fas fa-heart"></i>
                                    </button>
                                    <button class="btn btn-icon" title="Share">
                                        <i class="fas fa-share"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="vehicle-card-body">
                                <h5 class="vehicle-title">
                                    <a href="@Url.Action("Details", new { id = vehicle.Id })">@vehicle.Year @vehicle.Make @vehicle.Model</a>
                                </h5>
                                <div class="vehicle-details">
                                    <small>
                                        <i class="fas fa-road me-1"></i><span class="fw-semibold">@vehicle.Mileage.ToString("N0")</span> miles
                                        <span class="mx-2">•</span>
                                        <i class="fas fa-cogs me-1"></i><span class="fw-semibold">@vehicle.Transmission</span>
                                    </small>
                                </div>
                                <p class="text-muted small">@(vehicle.Features?.Length > 100 ? vehicle.Features.Substring(0, 100) + "..." : vehicle.Features)</p>
                                <div class="price-section">
                                    <div class="vehicle-price">@vehicle.SellingPrice.ToString("C")</div>
                                </div>
                                <div class="vehicle-actions">
                                    <div class="d-grid gap-2">
                                        <a href="@Url.Action("Details", new { id = vehicle.Id })" class="btn btn-primary">
                                            <i class="fas fa-eye"></i> View Details
                                        </a>
                                        @if (User.Identity.IsAuthenticated)
                                        {
                                            <div class="btn-group" role="group">
                                                <button type="button" class="btn btn-outline-success btn-sm" onclick="inquireVehicle(@vehicle.Id)">
                                                    <i class="fas fa-question-circle"></i> Inquire
                                                </button>
                                                <button type="button" class="btn btn-outline-warning btn-sm" onclick="reserveVehicle(@vehicle.Id)">
                                                    <i class="fas fa-bookmark"></i> Reserve
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <a href="@Url.Action("Login", "Account")" class="btn btn-outline-secondary btn-sm">
                                                <i class="fas fa-sign-in-alt"></i> Login to Inquire/Reserve
                                            </a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        else
        {
            <div class="col-12">
                <div class="text-center py-5">
                    <i class="fas fa-search fa-3x text-muted mb-3"></i>
                    <h4>No vehicles found</h4>
                    <p class="text-muted">Try adjusting your search criteria or filters.</p>
                    <a href="@Url.Action("Index")" class="btn btn-primary">
                        <i class="fas fa-refresh"></i> View All Vehicles
                    </a>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="row mt-4">
            <div class="col-12">
                <nav aria-label="Vehicle pagination">
                    <ul class="pagination justify-content-center">
                        @if (ViewBag.HasPreviousPage)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", new { 
                                    page = ViewBag.CurrentPage - 1,
                                    searchTerm = ViewBag.CurrentSearchTerm,
                                    make = ViewBag.CurrentMake,
                                    bodyType = ViewBag.CurrentBodyType,
                                    minPrice = ViewBag.CurrentMinPrice,
                                    maxPrice = ViewBag.CurrentMaxPrice,
                                    minYear = ViewBag.CurrentMinYear,
                                    maxYear = ViewBag.CurrentMaxYear,
                                    fuelType = ViewBag.CurrentFuelType,
                                    transmission = ViewBag.CurrentTransmission,
                                    sortBy = ViewBag.CurrentSortBy
                                })">
                                    <i class="fas fa-chevron-left"></i> Previous
                                </a>
                            </li>
                        }

                        @for (int i = Math.Max(1, ViewBag.CurrentPage - 2); i <= Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2); i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { 
                                    page = i,
                                    searchTerm = ViewBag.CurrentSearchTerm,
                                    make = ViewBag.CurrentMake,
                                    bodyType = ViewBag.CurrentBodyType,
                                    minPrice = ViewBag.CurrentMinPrice,
                                    maxPrice = ViewBag.CurrentMaxPrice,
                                    minYear = ViewBag.CurrentMinYear,
                                    maxYear = ViewBag.CurrentMaxYear,
                                    fuelType = ViewBag.CurrentFuelType,
                                    transmission = ViewBag.CurrentTransmission,
                                    sortBy = ViewBag.CurrentSortBy
                                })">@i</a>
                            </li>
                        }

                        @if (ViewBag.HasNextPage)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", new { 
                                    page = ViewBag.CurrentPage + 1,
                                    searchTerm = ViewBag.CurrentSearchTerm,
                                    make = ViewBag.CurrentMake,
                                    bodyType = ViewBag.CurrentBodyType,
                                    minPrice = ViewBag.CurrentMinPrice,
                                    maxPrice = ViewBag.CurrentMaxPrice,
                                    minYear = ViewBag.CurrentMinYear,
                                    maxYear = ViewBag.CurrentMaxYear,
                                    fuelType = ViewBag.CurrentFuelType,
                                    transmission = ViewBag.CurrentTransmission,
                                    sortBy = ViewBag.CurrentSortBy
                                })">
                                    Next <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>

<!-- Inquiry Modal -->
<div class="modal fade" id="inquiryModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Vehicle Inquiry</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="inquiryForm">
                    <input type="hidden" id="inquiryVehicleId" name="vehicleId">
                    
                    <!-- Contact Information -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="inquiryName" class="form-label">Full Name *</label>
                            <input type="text" class="form-control" id="inquiryName" name="customerName" required>
                        </div>
                        <div class="col-md-6">
                            <label for="inquiryEmail" class="form-label">Email Address *</label>
                            <input type="email" class="form-control" id="inquiryEmail" name="customerEmail" required>
                        </div>
                    </div>
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="inquiryPhone" class="form-label">Phone Number</label>
                            <input type="tel" class="form-control" id="inquiryPhone" name="customerPhone">
                        </div>
                        <div class="col-md-6">
                            <label for="preferredContact" class="form-label">Preferred Contact Method</label>
                            <select class="form-select" id="preferredContact" name="preferredContactMethod">
                                <option value="Email">Email</option>
                                <option value="Phone">Phone</option>
                                <option value="SMS">SMS</option>
                            </select>
                        </div>
                    </div>
                    
                    <!-- Best Time to Contact -->
                    <div class="mb-3">
                        <label for="preferredTime" class="form-label">Best Time to Contact</label>
                        <input type="datetime-local" class="form-control" id="preferredTime" name="preferredContactTime">
                    </div>
                    
                    <!-- Inquiry Type -->
                    <div class="mb-3">
                        <label for="inquiryType" class="form-label">Inquiry Type</label>
                        <select class="form-select" id="inquiryType" name="inquiryType">
                            <option value="Information">General Information</option>
                            <option value="TestDrive">Schedule Test Drive</option>
                            <option value="Financing">Financing Options</option>
                            <option value="Purchase">Purchase Inquiry</option>
                        </select>
                    </div>
                    
                    <!-- Special Requests -->
                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="requestBrochure" name="requestBrochure">
                            <label class="form-check-label" for="requestBrochure">
                                Request vehicle brochure and additional photos
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="requestTestDrive" name="isTestDriveRequested">
                            <label class="form-check-label" for="requestTestDrive">
                                I'm interested in scheduling a test drive
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="requestFinancing" name="isFinancingInquiry">
                            <label class="form-check-label" for="requestFinancing">
                                I need information about financing options
                            </label>
                        </div>
                    </div>
                    
                    <!-- Message -->
                    <div class="mb-3">
                        <label for="inquiryMessage" class="form-label">Your Message *</label>
                        <textarea class="form-control" id="inquiryMessage" name="message" rows="4" 
                                  placeholder="Please let us know what you'd like to know about this vehicle..." required></textarea>
                    </div>
                    
                    <!-- Special Requests -->
                    <div class="mb-3">
                        <label for="specialRequests" class="form-label">Special Requests or Notes</label>
                        <textarea class="form-control" id="specialRequests" name="specialRequests" rows="2" 
                                  placeholder="Any special requirements or additional information..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="submitInquiry()">Send Inquiry</button>
            </div>
        </div>
    </div>
</div>

<!-- Reservation Modal -->
<div class="modal fade" id="reservationModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Reserve Vehicle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="reservationForm">
                    <input type="hidden" id="reservationVehicleId" name="vehicleId">
                    
                    <!-- Customer Information -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="reservationName" class="form-label">Full Name *</label>
                            <input type="text" class="form-control" id="reservationName" name="customerName" required>
                        </div>
                        <div class="col-md-6">
                            <label for="reservationEmail" class="form-label">Email Address *</label>
                            <input type="email" class="form-control" id="reservationEmail" name="customerEmail" required>
                        </div>
                    </div>
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="reservationPhone" class="form-label">Phone Number *</label>
                            <input type="tel" class="form-control" id="reservationPhone" name="customerPhone" required>
                        </div>
                        <div class="col-md-6">
                            <label for="reservationDuration" class="form-label">Reservation Duration</label>
                            <select class="form-select" id="reservationDuration" name="reservationDuration">
                                <option value="3">3 Days</option>
                                <option value="7" selected>7 Days (Standard)</option>
                                <option value="14">14 Days</option>
                                <option value="30">30 Days</option>
                            </select>
                        </div>
                    </div>
                    
                    <!-- Deposit Information -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="depositAmount" class="form-label">Deposit Amount *</label>
                            <select class="form-select" id="depositAmount" name="depositAmount" required>
                                <option value="500">$500 (Minimum)</option>
                                <option value="1000" selected>$1,000 (Standard)</option>
                                <option value="2000">$2,000</option>
                                <option value="5000">$5,000</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="paymentMethod" class="form-label">Payment Method *</label>
                            <select class="form-select" id="paymentMethod" name="paymentMethod" required>
                                <option value="CreditCard">Credit Card</option>
                                <option value="DebitCard">Debit Card</option>
                                <option value="BankTransfer">Bank Transfer</option>
                                <option value="Check">Check</option>
                            </select>
                        </div>
                    </div>
                    
                    <!-- Payment Details (for Credit/Debit Card) -->
                    <div id="cardPaymentSection" class="mb-3">
                        <h6>Payment Information</h6>
                        <div class="row mb-2">
                            <div class="col-md-8">
                                <label for="cardNumber" class="form-label">Card Number</label>
                                <input type="text" class="form-control" id="cardNumber" name="cardNumber" placeholder="1234 5678 9012 3456">
                            </div>
                            <div class="col-md-4">
                                <label for="cvv" class="form-label">CVV</label>
                                <input type="text" class="form-control" id="cvv" name="cvv" placeholder="123">
                            </div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-md-6">
                                <label for="expiryMonth" class="form-label">Expiry Month</label>
                                <select class="form-select" id="expiryMonth" name="expiryMonth">
                                    <option value="01">01 - January</option>
                                    <option value="02">02 - February</option>
                                    <option value="03">03 - March</option>
                                    <option value="04">04 - April</option>
                                    <option value="05">05 - May</option>
                                    <option value="06">06 - June</option>
                                    <option value="07">07 - July</option>
                                    <option value="08">08 - August</option>
                                    <option value="09">09 - September</option>
                                    <option value="10">10 - October</option>
                                    <option value="11">11 - November</option>
                                    <option value="12">12 - December</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="expiryYear" class="form-label">Expiry Year</label>
                                <select class="form-select" id="expiryYear" name="expiryYear">
                                    <option value="2024">2024</option>
                                    <option value="2025">2025</option>
                                    <option value="2026">2026</option>
                                    <option value="2027">2027</option>
                                    <option value="2028">2028</option>
                                    <option value="2029">2029</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-2">
                            <label for="cardholderName" class="form-label">Cardholder Name</label>
                            <input type="text" class="form-control" id="cardholderName" name="cardholderName" placeholder="Name as it appears on card">
                        </div>
                    </div>
                    
                    <!-- Special Instructions -->
                    <div class="mb-3">
                        <label for="reservationNotes" class="form-label">Special Instructions or Notes</label>
                        <textarea class="form-control" id="reservationNotes" name="notes" rows="3" 
                                  placeholder="Any special requirements or instructions..."></textarea>
                    </div>
                    
                    <!-- Terms and Conditions -->
                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="agreeTerms" name="agreeTerms" required>
                            <label class="form-check-label" for="agreeTerms">
                                I agree to the <a href="#" target="_blank">Terms and Conditions</a> and understand that:
                            </label>
                        </div>
                        <ul class="small text-muted mt-2">
                            <li>The deposit is refundable if I cancel within 24 hours</li>
                            <li>After 24 hours, cancellation fees may apply</li>
                            <li>The reservation expires on the selected date</li>
                            <li>The vehicle price may change during the reservation period</li>
                        </ul>
                    </div>
                    
                    <!-- Reservation Summary -->
                    <div class="alert alert-info">
                        <h6>Reservation Summary:</h6>
                        <p class="mb-1"><strong>Duration:</strong> <span id="summaryDuration">7 days</span></p>
                        <p class="mb-1"><strong>Deposit:</strong> $<span id="summaryDeposit">1,000</span></p>
                        <p class="mb-0"><strong>Expiry Date:</strong> <span id="summaryExpiry"></span></p>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning" onclick="submitReservation()">Complete Reservation</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function inquireVehicle(vehicleId) {
            document.getElementById('inquiryVehicleId').value = vehicleId;
            document.getElementById('inquiryMessage').value = '';
            new bootstrap.Modal(document.getElementById('inquiryModal')).show();
        }

        function submitInquiry() {
            const form = document.getElementById('inquiryForm');
            const formData = new FormData(form);
            
            // Validate required fields
            const customerName = document.getElementById('inquiryName').value;
            const customerEmail = document.getElementById('inquiryEmail').value;
            const message = document.getElementById('inquiryMessage').value;

            if (!customerName.trim()) {
                alert('Please enter your full name.');
                return;
            }
            
            if (!customerEmail.trim()) {
                alert('Please enter your email address.');
                return;
            }
            
            if (!message.trim()) {
                alert('Please enter a message.');
                return;
            }

            // Convert FormData to JSON object
            const inquiryData = {
                vehicleId: formData.get('vehicleId'),
                customerName: formData.get('customerName'),
                customerEmail: formData.get('customerEmail'),
                customerPhone: formData.get('customerPhone'),
                preferredContactMethod: formData.get('preferredContactMethod'),
                preferredContactTime: formData.get('preferredContactTime'),
                inquiryType: formData.get('inquiryType'),
                message: formData.get('message'),
                specialRequests: formData.get('specialRequests'),
                isTestDriveRequested: document.getElementById('requestTestDrive').checked,
                isFinancingInquiry: document.getElementById('requestFinancing').checked,
                requestBrochure: document.getElementById('requestBrochure').checked
            };

            fetch('@Url.Action("Inquire")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                },
                body: JSON.stringify(inquiryData)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    bootstrap.Modal.getInstance(document.getElementById('inquiryModal')).hide();
                    alert('Inquiry sent successfully! We will contact you soon.');
                    document.getElementById('inquiryForm').reset();
                } else {
                    alert('Error: ' + data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('An error occurred while sending the inquiry.');
            });
        }

        function reserveVehicle(vehicleId) {
            document.getElementById('reservationVehicleId').value = vehicleId;
            updateReservationSummary();
            new bootstrap.Modal(document.getElementById('reservationModal')).show();
        }

        function updateReservationSummary() {
            const duration = document.getElementById('reservationDuration').value;
            const deposit = document.getElementById('depositAmount').value;
            
            document.getElementById('summaryDuration').textContent = duration + ' days';
            document.getElementById('summaryDeposit').textContent = deposit;
            
            // Calculate expiry date
            const expiryDate = new Date();
            expiryDate.setDate(expiryDate.getDate() + parseInt(duration));
            document.getElementById('summaryExpiry').textContent = expiryDate.toLocaleDateString();
        }

        function submitReservation() {
            const form = document.getElementById('reservationForm');
            const formData = new FormData(form);
            
            // Validate required fields
            const customerName = document.getElementById('reservationName').value;
            const customerEmail = document.getElementById('reservationEmail').value;
            const customerPhone = document.getElementById('reservationPhone').value;
            const agreeTerms = document.getElementById('agreeTerms').checked;
            const paymentMethod = document.getElementById('paymentMethod').value;

            if (!customerName.trim()) {
                alert('Please enter your full name.');
                return;
            }
            
            if (!customerEmail.trim()) {
                alert('Please enter your email address.');
                return;
            }
            
            if (!customerPhone.trim()) {
                alert('Please enter your phone number.');
                return;
            }
            
            if (!agreeTerms) {
                alert('Please agree to the terms and conditions.');
                return;
            }

            // Validate card details if credit/debit card is selected
            if (paymentMethod === 'CreditCard' || paymentMethod === 'DebitCard') {
                const cardNumber = document.getElementById('cardNumber').value;
                const cvv = document.getElementById('cvv').value;
                const cardholderName = document.getElementById('cardholderName').value;
                
                if (!cardNumber.trim()) {
                    alert('Please enter your card number.');
                    return;
                }
                
                if (!cvv.trim()) {
                    alert('Please enter your CVV.');
                    return;
                }
                
                if (!cardholderName.trim()) {
                    alert('Please enter the cardholder name.');
                    return;
                }
            }

            // Convert FormData to JSON object
            const reservationData = {
                vehicleId: formData.get('vehicleId'),
                customerName: formData.get('customerName'),
                customerEmail: formData.get('customerEmail'),
                customerPhone: formData.get('customerPhone'),
                reservationDuration: parseInt(formData.get('reservationDuration')),
                depositAmount: parseFloat(formData.get('depositAmount')),
                paymentMethod: formData.get('paymentMethod'),
                notes: formData.get('notes'),
                cardNumber: formData.get('cardNumber'),
                cvv: formData.get('cvv'),
                expiryMonth: formData.get('expiryMonth'),
                expiryYear: formData.get('expiryYear'),
                cardholderName: formData.get('cardholderName')
            };

            fetch('@Url.Action("Reserve")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                },
                body: JSON.stringify(reservationData)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Vehicle reserved successfully! You will receive a confirmation email shortly.');
                    bootstrap.Modal.getInstance(document.getElementById('reservationModal')).hide();
                    document.getElementById('reservationForm').reset();
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('An error occurred while processing your reservation.');
            });
        }

        // Update summary when duration or deposit changes
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('reservationDuration').addEventListener('change', updateReservationSummary);
            document.getElementById('depositAmount').addEventListener('change', updateReservationSummary);
            
            // Show/hide card payment section based on payment method
            document.getElementById('paymentMethod').addEventListener('change', function() {
                const cardSection = document.getElementById('cardPaymentSection');
                const paymentMethod = this.value;
                
                if (paymentMethod === 'CreditCard' || paymentMethod === 'DebitCard') {
                    cardSection.style.display = 'block';
                    // Make card fields required
                    document.getElementById('cardNumber').required = true;
                    document.getElementById('cvv').required = true;
                    document.getElementById('cardholderName').required = true;
                } else {
                    cardSection.style.display = 'none';
                    // Remove required attribute
                    document.getElementById('cardNumber').required = false;
                    document.getElementById('cvv').required = false;
                    document.getElementById('cardholderName').required = false;
                }
            });
        });

        // Auto-submit form when sort changes
        document.querySelector('select[name="sortBy"]').addEventListener('change', function() {
            document.getElementById('searchForm').submit();
        });
    </script>

    <style>
        .vehicle-card {
            transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
        }

        .vehicle-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important;
        }

        .vehicle-image {
            transition: transform 0.3s ease;
        }

        .vehicle-card:hover .vehicle-image {
            transform: scale(1.05);
        }
    </style>
}