@model IEnumerable<AutoEdge.Models.Entities.Application>

@{
    ViewData["Title"] = "Select Hired Candidate for Employment Offer";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-user-check mr-2"></i>
                        Select Hired Candidate for Employment Offer
                    </h3>
                    <div class="card-tools">
                        <a asp-action="Index" class="btn btn-secondary btn-sm">
                            <i class="fas fa-arrow-left mr-1"></i>
                            Back to Offers
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (ViewBag.Applications != null && ((List<AutoEdge.Models.Entities.Application>)ViewBag.Applications).Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="thead-dark">
                                    <tr>
                                        <th>Applicant Name</th>
                                        <th>Job Title</th>
                                        <th>Department</th>
                                        <th>Application Date</th>
                                        <th>Email</th>
                                        <th>Phone</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var application in (List<AutoEdge.Models.Entities.Application>)ViewBag.Applications)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@application.FirstName @application.LastName</strong>
                                            </td>
                                            <td>
                                                <span class="badge badge-primary">@application.JobPosting.JobTitle</span>
                                            </td>
                                            <td>@application.JobPosting.Department</td>
                                            <td>@application.SubmittedDate.ToString("MMM dd, yyyy")</td>
                                            <td>@application.Email</td>
                                            <td>@application.PhoneNumber</td>
                                            <td>
                                                <a asp-action="Create" asp-route-applicationId="@application.ApplicationId" 
                                                   class="btn btn-success btn-sm">
                                                    <i class="fas fa-paper-plane mr-1"></i>
                                                    Send Offer
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info text-center">
                            <i class="fas fa-info-circle fa-3x mb-3"></i>
                            <h4>No Hired Candidates Found</h4>
                            <p class="mb-0">
                                There are currently no hired candidates available for employment offers.
                                <br>
                                Please ensure applications are reviewed and marked as "Hire" before sending offers.
                            </p>
                            <div class="mt-3">
                                <a asp-controller="RecruitmentAdmin" asp-action="Applications" class="btn btn-primary">
                                    <i class="fas fa-eye mr-1"></i>
                                    Review Applications
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Simple table styling without DataTable dependency
            $('.table').addClass('table-hover');
        });
    </script>
}
