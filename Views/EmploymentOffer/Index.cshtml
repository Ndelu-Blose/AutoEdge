@model IEnumerable<AutoEdge.Models.Entities.EmploymentOffer>

@{
    ViewData["Title"] = "Employment Offers";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-briefcase mr-2"></i>
                        Employment Offers Management
                    </h3>
                    <div class="card-tools">
                        <a asp-action="Create" class="btn btn-primary btn-sm">
                            <i class="fas fa-plus mr-1"></i>
                            Send New Offer
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle mr-2"></i>
                            @TempData["SuccessMessage"]
                            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                    }

                    <div class="table-responsive">
                        <table class="table table-bordered table-striped" id="offersTable">
                            <thead class="thead-dark">
                                <tr>
                                    <th>Applicant</th>
                                    <th>Position</th>
                                    <th>Department</th>
                                    <th>Salary</th>
                                    <th>Start Date</th>
                                    <th>Status</th>
                                    <th>Sent Date</th>
                                    <th>Expiry Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var offer in Model)
                                {
                                    <tr>
                                        <td>
                                            <strong>@offer.Application.FirstName @offer.Application.LastName</strong><br>
                                            <small class="text-muted">@offer.Application.Email</small>
                                        </td>
                                        <td>@offer.JobTitle</td>
                                        <td>@offer.Department</td>
                                        <td>R@(offer.SalaryOffered.ToString("N0"))</td>
                                        <td>@offer.StartDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            @switch (offer.Status)
                                            {
                                                case "Pending":
                                                    <span class="badge badge-warning">Pending</span>
                                                    break;
                                                case "ContractAccepted":
                                                    <span class="badge badge-info">Contract Accepted</span>
                                                    break;
                                                case "ContractRejected":
                                                    <span class="badge badge-danger">Contract Rejected</span>
                                                    break;
                                                case "DocumentationCompleted":
                                                    <span class="badge badge-primary">Documentation Completed</span>
                                                    break;
                                                case "Approved":
                                                    <span class="badge badge-success">Approved</span>
                                                    break;
                                                case "Rejected":
                                                    <span class="badge badge-danger">Rejected</span>
                                                    break;
                                                default:
                                                    <span class="badge badge-secondary">@offer.Status</span>
                                                    break;
                                            }
                                        </td>
                                        <td>@offer.OfferSentDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            @if (offer.OfferExpiryDate < DateTime.UtcNow)
                                            {
                                                <span class="text-danger">@offer.OfferExpiryDate.ToString("dd MMM yyyy")</span>
                                                <br><small class="text-danger">Expired</small>
                                            }
                                            else
                                            {
                                                @offer.OfferExpiryDate.ToString("dd MMM yyyy")
                                            }
                                        </td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <a asp-action="Details" asp-route-id="@offer.OfferId" 
                                                   class="btn btn-info btn-sm" title="View Details">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                @if (offer.Status == "Pending")
                                                {
                                                    <a asp-action="ResendEmail" asp-route-id="@offer.OfferId" 
                                                       class="btn btn-warning btn-sm" title="Resend Email"
                                                       onclick="return confirm('Are you sure you want to resend the employment offer email?')">
                                                        <i class="fas fa-envelope"></i>
                                                    </a>
                                                }
                                                @if (offer.Status == "DocumentationCompleted")
                                                {
                                                    <a asp-controller="EmploymentReview" asp-action="Details" asp-route-id="@offer.PreEmploymentDocumentation?.DocumentationId" 
                                                       class="btn btn-success btn-sm" title="Review Documentation">
                                                        <i class="fas fa-clipboard-check"></i>
                                                    </a>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#offersTable').DataTable({
                "responsive": true,
                "lengthChange": false,
                "autoWidth": false,
                "order": [[6, "desc"]], // Sort by sent date descending
                "pageLength": 25
            });
        });
    </script>
}
