@model AutoEdge.Models.Entities.EmploymentOffer

@{
    ViewData["Title"] = "Send Employment Offer";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-paper-plane mr-2"></i>
                        Send Employment Offer
                    </h3>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="JobTitle" class="control-label">Job Title</label>
                                    <input asp-for="JobTitle" class="form-control" readonly />
                                    <span asp-validation-for="JobTitle" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Department" class="control-label">Department</label>
                                    <input asp-for="Department" class="form-control" readonly />
                                    <span asp-validation-for="Department" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="SalaryOffered" class="control-label">Salary Offered (R)</label>
                                    <input asp-for="SalaryOffered" class="form-control" type="number" step="0.01" />
                                    <span asp-validation-for="SalaryOffered" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="EmploymentType" class="control-label">Employment Type</label>
                                    <select asp-for="EmploymentType" class="form-control">
                                        <option value="Full-time">Full-time</option>
                                        <option value="Part-time">Part-time</option>
                                        <option value="Contract">Contract</option>
                                        <option value="Temporary">Temporary</option>
                                    </select>
                                    <span asp-validation-for="EmploymentType" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="StartDate" class="control-label">Start Date</label>
                                    <input asp-for="StartDate" class="form-control" type="date" />
                                    <span asp-validation-for="StartDate" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="WorkLocation" class="control-label">Work Location</label>
                                    <input asp-for="WorkLocation" class="form-control" />
                                    <span asp-validation-for="WorkLocation" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="OfferExpiryDate" class="control-label">Offer Expiry Date</label>
                                    <input asp-for="OfferExpiryDate" class="form-control" type="date" />
                                    <small class="form-text text-muted">The offer will expire on this date (typically 7 days from now)</small>
                                    <span asp-validation-for="OfferExpiryDate" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <input asp-for="ApplicationId" type="hidden" />
                        <input asp-for="AccessToken" type="hidden" />

                        <div class="form-group">
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle mr-2"></i>
                                <strong>Important:</strong> Once you send this offer, the applicant will receive an email with a secure link to review and accept the employment contract. The offer will expire on the specified date.
                            </div>
                        </div>

                        <div class="form-group">
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-paper-plane mr-2"></i>
                                Send Employment Offer
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left mr-2"></i>
                                Back to List
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function() {
            // Set default expiry date to 7 days from now
            var today = new Date();
            var expiryDate = new Date(today.getTime() + (7 * 24 * 60 * 60 * 1000));
            $('#OfferExpiryDate').val(expiryDate.toISOString().split('T')[0]);
        });
    </script>
}
