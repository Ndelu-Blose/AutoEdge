@model AutoEdge.Models.Entities.EmploymentOffer

@{
    ViewData["Title"] = "Employment Offer Details";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-briefcase mr-2"></i>
                        Employment Offer Details
                    </h3>
                    <div class="card-tools">
                        <a asp-action="Edit" asp-route-id="@Model.OfferId" class="btn btn-warning btn-sm">
                            <i class="fas fa-edit mr-1"></i>
                            Edit
                        </a>
                        <a asp-action="Index" class="btn btn-secondary btn-sm">
                            <i class="fas fa-arrow-left mr-1"></i>
                            Back to List
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle mr-2"></i>
                            @TempData["SuccessMessage"]
                            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                    }

                    <div class="row">
                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title">Applicant Information</h5>
                                </div>
                                <div class="card-body">
                                    <table class="table table-borderless">
                                        <tr>
                                            <td><strong>Name:</strong></td>
                                            <td>@Model.Application.FirstName @Model.Application.LastName</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Email:</strong></td>
                                            <td>@Model.Application.Email</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Phone:</strong></td>
                                            <td>@Model.Application.PhoneNumber</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Application Date:</strong></td>
                                            <td>@Model.Application.SubmittedDate.ToString("dd MMMM yyyy")</td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title">Offer Details</h5>
                                </div>
                                <div class="card-body">
                                    <table class="table table-borderless">
                                        <tr>
                                            <td><strong>Job Title:</strong></td>
                                            <td>@Model.JobTitle</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Department:</strong></td>
                                            <td>@Model.Department</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Salary:</strong></td>
                                            <td>R@(Model.SalaryOffered.ToString("N0")) per month</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Employment Type:</strong></td>
                                            <td>@Model.EmploymentType</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Start Date:</strong></td>
                                            <td>@Model.StartDate.ToString("dd MMMM yyyy")</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Work Location:</strong></td>
                                            <td>@Model.WorkLocation</td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row mt-4">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title">Offer Status & Timeline</h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-3">
                                            <div class="info-box">
                                                <span class="info-box-icon bg-info">
                                                    <i class="fas fa-paper-plane"></i>
                                                </span>
                                                <div class="info-box-content">
                                                    <span class="info-box-text">Sent Date</span>
                                                    <span class="info-box-number">@Model.OfferSentDate.ToString("dd MMM yyyy")</span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="info-box">
                                                <span class="info-box-icon @(Model.OfferExpiryDate < DateTime.UtcNow ? "bg-danger" : "bg-warning")">
                                                    <i class="fas fa-clock"></i>
                                                </span>
                                                <div class="info-box-content">
                                                    <span class="info-box-text">Expiry Date</span>
                                                    <span class="info-box-number">@Model.OfferExpiryDate.ToString("dd MMM yyyy")</span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="info-box">
                                                <span class="info-box-icon bg-primary">
                                                    <i class="fas fa-tag"></i>
                                                </span>
                                                <div class="info-box-content">
                                                    <span class="info-box-text">Status</span>
                                                    <span class="info-box-number">
                                                        @switch (Model.Status)
                                                        {
                                                            case "Pending":
                                                                <span class="badge badge-warning">Pending</span>
                                                                break;
                                                            case "ContractAccepted":
                                                                <span class="badge badge-info">Contract Accepted</span>
                                                                break;
                                                            case "ContractRejected":
                                                                <span class="badge badge-danger">Contract Rejected</span>
                                                                break;
                                                            case "DocumentationCompleted":
                                                                <span class="badge badge-primary">Documentation Completed</span>
                                                                break;
                                                            case "Approved":
                                                                <span class="badge badge-success">Approved</span>
                                                                break;
                                                            case "Rejected":
                                                                <span class="badge badge-danger">Rejected</span>
                                                                break;
                                                            default:
                                                                <span class="badge badge-secondary">@Model.Status</span>
                                                                break;
                                                        }
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="info-box">
                                                <span class="info-box-icon bg-success">
                                                    <i class="fas fa-check"></i>
                                                </span>
                                                <div class="info-box-content">
                                                    <span class="info-box-text">Contract Accepted</span>
                                                    <span class="info-box-number">
                                                        @if (Model.ContractAccepted)
                                                        {
                                                            <span class="badge badge-success">Yes</span>
                                                            <br><small>@Model.ContractAcceptedDate?.ToString("dd MMM yyyy")</small>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge badge-secondary">No</span>
                                                        }
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (Model.ContractAccepted)
                    {
                        <div class="row mt-4">
                            <div class="col-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="card-title">Contract Acceptance Details</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <p><strong>Accepted Date:</strong> @Model.ContractAcceptedDate?.ToString("dd MMMM yyyy HH:mm")</p>
                                            </div>
                                            <div class="col-md-6">
                                                <p><strong>Digital Signature:</strong> 
                                                    @if (!string.IsNullOrEmpty(Model.ContractSignature))
                                                    {
                                                        <span class="badge badge-success">Captured</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-warning">Not Available</span>
                                                    }
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.RejectionReason))
                    {
                        <div class="row mt-4">
                            <div class="col-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="card-title">Rejection Details</h5>
                                    </div>
                                    <div class="card-body">
                                        <p><strong>Reason for Rejection:</strong></p>
                                        <p class="text-muted">@Model.RejectionReason</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    @if (Model.PreEmploymentDocumentation != null)
                    {
                        <div class="row mt-4">
                            <div class="col-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="card-title">Pre-Employment Documentation</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <p><strong>Status:</strong> 
                                                    @if (Model.PreEmploymentDocumentation.IsCompleted)
                                                    {
                                                        <span class="badge badge-success">Completed</span>
                                                        <br><small>@Model.PreEmploymentDocumentation.CompletedDate?.ToString("dd MMM yyyy HH:mm")</small>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-warning">In Progress</span>
                                                    }
                                                </p>
                                            </div>
                                            <div class="col-md-6">
                                                <p><strong>Admin Review:</strong> 
                                                    @if (Model.PreEmploymentDocumentation.AdminReviewed)
                                                    {
                                                        @if (Model.PreEmploymentDocumentation.Approved)
                                                        {
                                                            <span class="badge badge-success">Approved</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge badge-danger">Rejected</span>
                                                        }
                                                        <br><small>@Model.PreEmploymentDocumentation.AdminReviewedDate?.ToString("dd MMM yyyy")</small>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-warning">Pending Review</span>
                                                    }
                                                </p>
                                            </div>
                                        </div>
                                        
                                        @if (Model.PreEmploymentDocumentation.IsCompleted)
                                        {
                                            <div class="mt-3">
                                                <a asp-controller="EmploymentReview" asp-action="Details" asp-route-id="@Model.PreEmploymentDocumentation.DocumentationId" 
                                                   class="btn btn-primary">
                                                    <i class="fas fa-clipboard-check mr-2"></i>
                                                    Review Documentation
                                                </a>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="row mt-4">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title">Actions</h5>
                                </div>
                                <div class="card-body">
                                    <div class="btn-group" role="group">
                                        @if (Model.Status == "Pending")
                                        {
                                            <a asp-action="ResendEmail" asp-route-id="@Model.OfferId" 
                                               class="btn btn-warning"
                                               onclick="return confirm('Are you sure you want to resend the employment offer email?')">
                                                <i class="fas fa-envelope mr-2"></i>
                                                Resend Email
                                            </a>
                                        }
                                        
                                        @if (Model.Status == "DocumentationCompleted")
                                        {
                                            <a asp-controller="EmploymentReview" asp-action="Details" asp-route-id="@Model.PreEmploymentDocumentation?.DocumentationId" 
                                               class="btn btn-success">
                                                <i class="fas fa-clipboard-check mr-2"></i>
                                                Review Documentation
                                            </a>
                                        }
                                        
                                        <a asp-action="Edit" asp-route-id="@Model.OfferId" class="btn btn-info">
                                            <i class="fas fa-edit mr-2"></i>
                                            Edit Offer
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
