@model IEnumerable<AutoEdge.Models.Entities.ServiceBooking>
@using AutoEdge.Models.Entities
@{
    ViewData["Title"] = "Service Bookings Management";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="fas fa-calendar-check me-2"></i>Service Bookings Management</h2>
                <div class="btn-group">
                    <button type="button" class="btn btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown">
                        <i class="fas fa-filter me-2"></i>Filter
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#" onclick="filterBookings('all')">All Bookings</a></li>
                        <li><a class="dropdown-item" href="#" onclick="filterBookings('checked-in')">Checked In</a></li>
                        <li><a class="dropdown-item" href="#" onclick="filterBookings('pending')">Pending</a></li>
                        <li><a class="dropdown-item" href="#" onclick="filterBookings('confirmed')">Confirmed</a></li>
                        <li><a class="dropdown-item" href="#" onclick="filterBookings('completed')">Completed</a></li>
                    </ul>
                </div>
            </div>

            <!-- Statistics Cards -->
            <div class="row mb-4">
                <div class="col-md-3">
                    <div class="card bg-primary text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <h4 class="mb-0">@Model.Count()</h4>
                                    <p class="mb-0">Total Bookings</p>
                                </div>
                                <div class="align-self-center">
                                    <i class="fas fa-calendar fa-2x"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-success text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <h4 class="mb-0">@Model.Count(b => b.IsCheckedIn)</h4>
                                    <p class="mb-0">Checked In</p>
                                </div>
                                <div class="align-self-center">
                                    <i class="fas fa-check-circle fa-2x"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-warning text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <h4 class="mb-0">@Model.Count(b => b.Status == ServiceBookingStatus.Pending)</h4>
                                    <p class="mb-0">Pending</p>
                                </div>
                                <div class="align-self-center">
                                    <i class="fas fa-clock fa-2x"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-info text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <h4 class="mb-0">@Model.Count(b => b.Status == ServiceBookingStatus.Completed)</h4>
                                    <p class="mb-0">Completed</p>
                                </div>
                                <div class="align-self-center">
                                    <i class="fas fa-tools fa-2x"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">All Service Bookings</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Reference</th>
                                        <th>Customer</th>
                                        <th>Vehicle</th>
                                        <th>Service Type</th>
                                        <th>Scheduled Date</th>
                                        <th>Status</th>
                                        <th>Check-In</th>
                                        <th>Mechanic</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var booking in Model)
                                    {
                                        <tr data-status="@booking.Status.ToString().ToLower()" 
                                            data-checked-in="@booking.IsCheckedIn.ToString().ToLower()">
                                            <td>
                                                <code>@booking.Reference</code>
                                            </td>
                                            <td>
                                                <div>
                                                    <strong>@booking.CustomerName</strong><br/>
                                                    <small class="text-muted">@booking.CustomerEmail</small>
                                                </div>
                                            </td>
                                            <td>
                                                @booking.Make @booking.Model (@booking.Year)
                                            </td>
                                            <td>
                                                <span class="badge bg-secondary">@booking.ServiceType</span>
                                            </td>
                                            <td>
                                                <div>
                                                    @booking.PreferredDate.ToString("MMM dd, yyyy")<br/>
                                                    <small class="text-muted">@booking.PreferredStart.ToString("HH:mm")</small>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge @GetStatusBadgeClass(booking.Status)">
                                                    @booking.Status
                                                </span>
                                            </td>
                                            <td>
                                                @if (booking.IsCheckedIn)
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="fas fa-check me-1"></i>Checked In
                                                    </span>
                                                    <br/>
                                                    <small class="text-muted">@booking.CheckedInDate?.ToString("MMM dd HH:mm")</small>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">
                                                        <i class="fas fa-times me-1"></i>Not Checked In
                                                    </span>
                                                }
                                            </td>
                                            <td>
                                                @if (booking.ServiceJob?.Mechanic != null)
                                                {
                                                    <span class="badge bg-info">@booking.ServiceJob.Mechanic.Name</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning">Unassigned</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <a href="/Admin/ServiceBookingDetails/@booking.Id" class="btn btn-outline-primary">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    @if (booking.ServiceJob?.Mechanic != null)
                                                    {
                                                        <button class="btn btn-outline-warning" onclick="showReassignModal(@booking.Id, '@booking.ServiceJob.Mechanic.Name')">
                                                            <i class="fas fa-user-edit"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-calendar-times fa-3x text-muted mb-3"></i>
                    <h4 class="text-muted">No Service Bookings Found</h4>
                    <p class="text-muted">No service bookings have been created yet.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Reassign Mechanic Modal -->
<div class="modal fade" id="reassignModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Reassign Mechanic</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="reassignForm">
                    <input type="hidden" id="bookingId" />
                    <div class="mb-3">
                        <label class="form-label">Current Mechanic:</label>
                        <input type="text" class="form-control" id="currentMechanic" readonly />
                    </div>
                    <div class="mb-3">
                        <label for="newMechanic" class="form-label">New Mechanic:</label>
                        <select class="form-select" id="newMechanic" required>
                            <option value="">Select a mechanic...</option>
                            <!-- This would be populated with available mechanics -->
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="reassignMechanic()">Reassign</button>
            </div>
        </div>
    </div>
</div>

<script>
function filterBookings(filter) {
    const rows = document.querySelectorAll('tbody tr');
    
    rows.forEach(row => {
        let show = true;
        
        switch(filter) {
            case 'checked-in':
                show = row.dataset.checkedIn === 'true';
                break;
            case 'pending':
                show = row.dataset.status === 'pending';
                break;
            case 'confirmed':
                show = row.dataset.status === 'confirmed';
                break;
            case 'completed':
                show = row.dataset.status === 'completed';
                break;
            default:
                show = true;
        }
        
        row.style.display = show ? '' : 'none';
    });
}

function showReassignModal(bookingId, currentMechanic) {
    document.getElementById('bookingId').value = bookingId;
    document.getElementById('currentMechanic').value = currentMechanic;
    
    // TODO: Load available mechanics
    const modal = new bootstrap.Modal(document.getElementById('reassignModal'));
    modal.show();
}

function reassignMechanic() {
    const bookingId = document.getElementById('bookingId').value;
    const mechanicId = document.getElementById('newMechanic').value;
    
    if (!mechanicId) {
        alert('Please select a mechanic.');
        return;
    }
    
    // Create form and submit
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/Admin/ReassignServiceBooking';
    
    const bookingIdInput = document.createElement('input');
    bookingIdInput.type = 'hidden';
    bookingIdInput.name = 'id';
    bookingIdInput.value = bookingId;
    
    const mechanicIdInput = document.createElement('input');
    mechanicIdInput.type = 'hidden';
    mechanicIdInput.name = 'mechanicId';
    mechanicIdInput.value = mechanicId;
    
    form.appendChild(bookingIdInput);
    form.appendChild(mechanicIdInput);
    
    document.body.appendChild(form);
    form.submit();
}
</script>

@functions {
    string GetStatusBadgeClass(ServiceBookingStatus status)
    {
        return status switch
        {
            ServiceBookingStatus.Confirmed => "bg-success",
            ServiceBookingStatus.Pending => "bg-warning",
            ServiceBookingStatus.Completed => "bg-info",
            ServiceBookingStatus.Canceled => "bg-danger",
            _ => "bg-secondary"
        };
    }
}
