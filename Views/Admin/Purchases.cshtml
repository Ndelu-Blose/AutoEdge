@model IEnumerable<AutoEdge.Models.Entities.Purchase>
@{
    ViewData["Title"] = "Purchase Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h3 class="card-title mb-0">
                        <i class="fas fa-shopping-cart me-2"></i>
                        Purchase Management
                    </h3>
                    <span class="badge bg-primary">@ViewBag.TotalPurchases Total Purchases</span>
                </div>
                <div class="card-body">
                    <!-- Status Filter -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="btn-group" role="group">
                                <a href="@Url.Action("Purchases", new { status = "All" })" 
                                   class="btn @(ViewBag.CurrentStatus == "All" ? "btn-primary" : "btn-outline-primary")">All</a>
                                <a href="@Url.Action("Purchases", new { status = "Initiated" })" 
                                   class="btn @(ViewBag.CurrentStatus == "Initiated" ? "btn-primary" : "btn-outline-primary")">Initiated</a>
                                <a href="@Url.Action("Purchases", new { status = "DocumentsUploaded" })" 
                                   class="btn @(ViewBag.CurrentStatus == "DocumentsUploaded" ? "btn-primary" : "btn-outline-primary")">Documents Uploaded</a>
                                <a href="@Url.Action("Purchases", new { status = "DocumentsReview" })" 
                                   class="btn @(ViewBag.CurrentStatus == "DocumentsReview" ? "btn-primary" : "btn-outline-primary")">Under Review</a>
                                <a href="@Url.Action("Purchases", new { status = "DocumentsApproved" })" 
                                   class="btn @(ViewBag.CurrentStatus == "DocumentsApproved" ? "btn-primary" : "btn-outline-primary")">Approved</a>
                                <a href="@Url.Action("Purchases", new { status = "DocumentsRejected" })" 
                                   class="btn @(ViewBag.CurrentStatus == "DocumentsRejected" ? "btn-primary" : "btn-outline-primary")">Rejected</a>
                                <a href="@Url.Action("Purchases", new { status = "Completed" })" 
                                   class="btn @(ViewBag.CurrentStatus == "Completed" ? "btn-primary" : "btn-outline-primary")">Completed</a>
                                <a href="@Url.Action("Purchases", new { status = "Cancelled" })" 
                                   class="btn @(ViewBag.CurrentStatus == "Cancelled" ? "btn-primary" : "btn-outline-primary")">Cancelled</a>
                            </div>
                        </div>
                    </div>

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Purchase ID</th>
                                        <th>Customer</th>
                                        <th>Vehicle</th>
                                        <th>Status</th>
                                        <th>Created Date</th>
                                        <th>Total Amount</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var purchase in Model)
                                    {
                                        <tr>
                                            <td>
                                                <strong>#@purchase.Id</strong>
                                            </td>
                                            <td>
                                                <div>
                                                    <strong>@purchase.Customer.User.FirstName @purchase.Customer.User.LastName</strong>
                                                    <br>
                                                    <small class="text-muted">@purchase.Customer.User.Email</small>
                                                </div>
                                            </td>
                                            <td>
                                                <div>
                                                    <strong>@purchase.Vehicle.Year @purchase.Vehicle.Make @purchase.Vehicle.Model</strong>
                                                    <br>
                                                    <small class="text-muted">VIN: @purchase.Vehicle.VIN</small>
                                                </div>
                                            </td>
                                            <td>
                                                @switch (purchase.Status)
                                                {
                                                    case "Initiated":
                                                        <span class="badge bg-secondary">@purchase.Status</span>
                                                        break;
                                                    case "DocumentsUploaded":
                                                        <span class="badge bg-info">Documents Uploaded</span>
                                                        break;
                                                    case "DocumentsReview":
                                                        <span class="badge bg-warning">Under Review</span>
                                                        break;
                                                    case "DocumentsApproved":
                                                        <span class="badge bg-success">Documents Approved</span>
                                                        break;
                                                    case "DocumentsRejected":
                                                        <span class="badge bg-danger">Documents Rejected</span>
                                                        break;
                                                    case "ContractReview":
                                                        <span class="badge bg-primary">Contract Review</span>
                                                        break;
                                                    case "PaymentPending":
                                                        <span class="badge bg-warning">Payment Pending</span>
                                                        break;
                                                    case "Completed":
                                                        <span class="badge bg-success">Completed</span>
                                                        break;
                                                    case "Cancelled":
                                                        <span class="badge bg-dark">Cancelled</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">@purchase.Status</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                @purchase.CreatedDate.ToString("MMM dd, yyyy")
                                                <br>
                                                <small class="text-muted">@purchase.CreatedDate.ToString("hh:mm tt")</small>
                                            </td>
                                            <td>
                                                <strong>@purchase.PurchasePrice.ToString("C")</strong>
                                            </td>
                                            <td>
                                                <a href="@Url.Action("PurchaseDetails", new { id = purchase.Id })" 
                                                   class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-eye"></i> View Details
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Pagination -->
                        @if (ViewBag.TotalPages > 1)
                        {
                            <nav aria-label="Purchase pagination">
                                <ul class="pagination justify-content-center">
                                    @if (ViewBag.CurrentPage > 1)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="@Url.Action("Purchases", new { status = ViewBag.CurrentStatus, page = ViewBag.CurrentPage - 1 })">
                                                <i class="fas fa-chevron-left"></i> Previous
                                            </a>
                                        </li>
                                    }

                                    @for (int i = Math.Max(1, ViewBag.CurrentPage - 2); i <= Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2); i++)
                                    {
                                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                            <a class="page-link" href="@Url.Action("Purchases", new { status = ViewBag.CurrentStatus, page = i })">
                                                @i
                                            </a>
                                        </li>
                                    }

                                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="@Url.Action("Purchases", new { status = ViewBag.CurrentStatus, page = ViewBag.CurrentPage + 1 })">
                                                Next <i class="fas fa-chevron-right"></i>
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-shopping-cart fa-3x text-muted mb-3"></i>
                            <h4 class="text-muted">No purchases found</h4>
                            <p class="text-muted">@(ViewBag.CurrentStatus == "All" ? "There are no purchases in the system yet." : $"No purchases with status '{ViewBag.CurrentStatus}' found.")</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.btn-group .btn {
    border-radius: 0;
}

.btn-group .btn:first-child {
    border-top-left-radius: 0.375rem;
    border-bottom-left-radius: 0.375rem;
}

.btn-group .btn:last-child {
    border-top-right-radius: 0.375rem;
    border-bottom-right-radius: 0.375rem;
}

.table th {
    border-top: none;
    font-weight: 600;
}

.badge {
    font-size: 0.75em;
}
</style>