@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>
@{
    ViewData["Title"] = "Manage Roles";
}

<div class="container">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2>Manage Roles</h2>
                <div>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createRoleModal">
                        <i class="fas fa-plus"></i> Create New Role
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to Dashboard
                    </a>
                </div>
            </div>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card">
                <div class="card-header">
                    <h5>System Roles</h5>
                </div>
                <div class="card-body">
                    @if (Model != null && Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Role Name</th>
                                        <th>Role ID</th>
                                        <th>Users Count</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var role in Model)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@role.Name</strong>
                                                @if (role.Name == "Administrator")
                                                {
                                                    <span class="badge bg-danger ms-2">System Role</span>
                                                }
                                                else if (role.Name == "Customer")
                                                {
                                                    <span class="badge bg-primary ms-2">Default Role</span>
                                                }
                                            </td>
                                            <td>
                                                <small class="text-muted">@role.Id</small>
                                            </td>
                                            <td>
                                                @if (ViewBag.RoleUserCounts != null && ViewBag.RoleUserCounts.ContainsKey(role.Id))
                                                {
                                                    <span class="badge bg-info">@ViewBag.RoleUserCounts[role.Id] users</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">0 users</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <button class="btn btn-sm btn-outline-info" 
                                                            data-bs-toggle="modal" 
                                                            data-bs-target="#viewRoleModal" 
                                                            data-role-id="@role.Id" 
                                                            data-role-name="@role.Name">
                                                        <i class="fas fa-eye"></i> View
                                                    </button>
                                                    
                                                    @if (role.Name != "Administrator" && role.Name != "Customer")
                                                    {
                                                        <form asp-action="DeleteRole" asp-route-id="@role.Id" method="post" class="d-inline">
                                                            @Html.AntiForgeryToken()
                                                            <button type="submit" class="btn btn-sm btn-outline-danger" 
                                                                    onclick="return confirm('Are you sure you want to delete the role: @role.Name?')">
                                                                <i class="fas fa-trash"></i> Delete
                                                            </button>
                                                        </form>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-sm btn-outline-secondary" disabled>
                                                            <i class="fas fa-lock"></i> Protected
                                                        </button>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-users-cog fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">No roles found</h5>
                            <p class="text-muted">Create your first role to get started.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5>Role Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="text-center">
                                <i class="fas fa-user-shield fa-2x text-danger mb-2"></i>
                                <h6>Administrator</h6>
                                <p class="small text-muted">Full system access and user management</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <i class="fas fa-user fa-2x text-primary mb-2"></i>
                                <h6>Customer</h6>
                                <p class="small text-muted">Browse vehicles and make inquiries</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <i class="fas fa-handshake fa-2x text-success mb-2"></i>
                                <h6>Sales Representative</h6>
                                <p class="small text-muted">Manage sales and customer relationships</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <i class="fas fa-headset fa-2x text-info mb-2"></i>
                                <h6>Support Staff</h6>
                                <p class="small text-muted">Provide customer support and assistance</p>
                            </div>
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-md-3">
                            <div class="text-center">
                                <i class="fas fa-truck fa-2x text-warning mb-2"></i>
                                <h6>Driver</h6>
                                <p class="small text-muted">Vehicle delivery and logistics</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Role Modal -->
<div class="modal fade" id="createRoleModal" tabindex="-1" aria-labelledby="createRoleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="CreateRole" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="createRoleModalLabel">Create New Role</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="roleName" class="form-label">Role Name</label>
                        <input type="text" class="form-control" id="roleName" name="roleName" required 
                               placeholder="Enter role name (e.g., Manager, Supervisor)">
                        <div class="form-text">Role names should be descriptive and unique.</div>
                    </div>
                    <div class="mb-3">
                        <label for="roleDescription" class="form-label">Description (Optional)</label>
                        <textarea class="form-control" id="roleDescription" name="roleDescription" rows="3" 
                                  placeholder="Describe the role's responsibilities and permissions"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Create Role
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- View Role Modal -->
<div class="modal fade" id="viewRoleModal" tabindex="-1" aria-labelledby="viewRoleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewRoleModalLabel">Role Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="roleDetailsContent">
                    <!-- Role details will be loaded here via JavaScript -->
                    <div class="text-center">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Handle view role modal
        document.getElementById('viewRoleModal').addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var roleId = button.getAttribute('data-role-id');
            var roleName = button.getAttribute('data-role-name');
            
            var modalTitle = this.querySelector('.modal-title');
            modalTitle.textContent = 'Role Details: ' + roleName;
            
            var content = this.querySelector('#roleDetailsContent');
            content.innerHTML = `
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Role Name:</strong> ${roleName}</p>
                        <p><strong>Role ID:</strong> <small class="text-muted">${roleId}</small></p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>System Role:</strong> ${(roleName === 'Administrator' || roleName === 'Customer') ? 'Yes' : 'No'}</p>
                        <p><strong>Can be Deleted:</strong> ${(roleName === 'Administrator' || roleName === 'Customer') ? 'No' : 'Yes'}</p>
                    </div>
                </div>
                <hr>
                <h6>Role Permissions:</h6>
                <div class="role-permissions">
                    ${getRolePermissions(roleName)}
                </div>
            `;
        });
        
        function getRolePermissions(roleName) {
            const permissions = {
                'Administrator': [
                    'Full system access',
                    'User management',
                    'Role management',
                    'Vehicle management',
                    'Document management',
                    'Contract management',
                    'Payment processing',
                    'System configuration'
                ],
                'Customer': [
                    'Browse vehicles',
                    'Submit inquiries',
                    'Make reservations',
                    'View own documents',
                    'Update profile'
                ],
                'SalesRepresentative': [
                    'Manage customer inquiries',
                    'Process reservations',
                    'Generate contracts',
                    'Access sales reports',
                    'Manage assigned customers'
                ],
                'SupportStaff': [
                    'View customer information',
                    'Respond to inquiries',
                    'Access support tickets',
                    'Generate support reports'
                ],
                'Driver': [
                    'View delivery schedules',
                    'Update delivery status',
                    'Access vehicle information',
                    'Report vehicle issues',
                    'Confirm deliveries'
                ]
            };
            
            const rolePerms = permissions[roleName] || ['Custom role - permissions not defined'];
            return rolePerms.map(perm => `<span class="badge bg-light text-dark me-1 mb-1">${perm}</span>`).join('');
        }
    </script>
}