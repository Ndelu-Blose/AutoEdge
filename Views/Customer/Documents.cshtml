@model List<AutoEdge.Models.Entities.Document>
@{
    ViewData["Title"] = "My Documents";
    var documentTypes = ViewBag.DocumentTypes as List<AutoEdge.Models.Entities.DocumentType>;
}

<div class="container-fluid">
    @if (ViewBag.Purchase != null)
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="alert alert-info border-0">
                    <div class="d-flex align-items-center">
                        <i class="fas fa-car me-3 fa-2x"></i>
                        <div>
                            <h6 class="mb-1">Purchase Documents - @ViewBag.Purchase.Vehicle.Make @ViewBag.Purchase.Vehicle.Model</h6>
                            <p class="mb-0 text-muted">Upload documents required for Purchase #@ViewBag.Purchase.Id</p>
                        </div>
                        <div class="ms-auto">
                            <a href="@Url.Action("PurchaseWorkflow", "Purchase", new { id = ViewBag.Purchase.Id })" class="btn btn-outline-primary btn-sm">
                                <i class="fas fa-arrow-left me-1"></i>Back to Purchase
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2><i class="fas fa-file-alt me-2"></i>@(ViewBag.Purchase != null ? "Purchase Documents" : "My Documents")</h2>
                    <p class="text-muted mb-0">@(ViewBag.Purchase != null ? "Documents for your vehicle purchase" : "Upload and manage your verification documents")</p>
                </div>
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal">
                    <i class="fas fa-upload me-2"></i>Upload Document
                </button>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card">
                <div class="card-body">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Document Type</th>
                                        <th>File Name</th>
                                        <th>Status</th>
                                        <th>Upload Date</th>
                                        <th>Review Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var document in Model)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@document.DocumentType.Name</strong>
                                                @if (!string.IsNullOrEmpty(document.Description))
                                                {
                                                    <br><small class="text-muted">@document.Description</small>
                                                }
                                            </td>
                                            <td>
                                                <i class="fas fa-file me-2"></i>@document.FileName
                                                <br><small class="text-muted">@((document.FileSizeBytes / 1024.0 / 1024.0).ToString("F2")) MB</small>
                                            </td>
                                            <td>
                                                @switch (document.Status)
                                                {
                                                    case "Pending":
                                                        <span class="badge bg-warning text-dark"><i class="fas fa-clock me-1"></i>Pending Review</span>
                                                        break;
                                                    case "Approved":
                                                        <span class="badge bg-success"><i class="fas fa-check me-1"></i>Approved</span>
                                                        break;
                                                    case "Rejected":
                                                        <span class="badge bg-danger"><i class="fas fa-times me-1"></i>Rejected</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">@document.Status</span>
                                                        break;
                                                }
                                                @if (document.IsOcrProcessed)
                                                {
                                                    <br><small class="text-success"><i class="fas fa-robot me-1"></i>OCR Processed</small>
                                                }
                                                else if (document.OcrProcessedDate == null && document.CreatedDate > DateTime.Now.AddMinutes(-5))
                                                {
                                                    <br><small class="text-info"><i class="fas fa-spinner fa-spin me-1"></i>Processing...</small>
                                                }
                                            </td>
                                            <td>@document.CreatedDate.ToString("MMM dd, yyyy")</td>
                                            <td>
                                                @if (document.ReviewDate.HasValue)
                                                {
                                                    @document.ReviewDate.Value.ToString("MMM dd, yyyy")
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a href="@Url.Action("DocumentDetails", new { id = document.Id })" class="btn btn-sm btn-outline-primary">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a href="@document.FilePath" target="_blank" class="btn btn-sm btn-outline-secondary">
                                                        <i class="fas fa-download"></i>
                                                    </a>
                                                    @if (document.Status != "Approved")
                                                    {
                                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteDocument(@document.Id)">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-file-upload fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">No documents uploaded yet</h5>
                            <p class="text-muted">Upload your verification documents to get started with your vehicle purchase process.</p>
                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal">
                                <i class="fas fa-upload me-2"></i>Upload Your First Document
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Upload Modal -->
<div class="modal fade" id="uploadModal" tabindex="-1" aria-labelledby="uploadModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="uploadModalLabel">Upload Document</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="uploadForm" enctype="multipart/form-data">
                @if (ViewBag.PurchaseId != null)
                {
                    <input type="hidden" id="purchaseId" name="purchaseId" value="@ViewBag.PurchaseId" />
                }
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="documentTypeId" class="form-label">Document Type <span class="text-danger">*</span></label>
                        <select class="form-select" id="documentTypeId" name="documentTypeId" required>
                            <option value="">Select document type...</option>
                            @if (documentTypes != null)
                            {
                                @foreach (var docType in documentTypes)
                                {
                                    <option value="@docType.Id" data-description="@docType.Description" data-requirements="@docType.Requirements" data-allowed-types="@docType.AllowedFileTypes" data-max-size="@(docType.MaxFileSizeBytes / 1024 / 1024)">
                                        @docType.Name
                                    </option>
                                }
                            }
                        </select>
                        <div id="documentTypeInfo" class="mt-2" style="display: none;">
                            <div class="alert alert-info mb-0">
                                <div id="documentDescription"></div>
                                <div id="documentRequirements"></div>
                                <div id="documentConstraints"></div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="file" class="form-label">Choose File <span class="text-danger">*</span></label>
                        <input type="file" class="form-control" id="file" name="file" required>
                        <div class="form-text">Maximum file size: <span id="maxFileSize">5 MB</span></div>
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label">Description (Optional)</label>
                        <textarea class="form-control" id="description" name="description" rows="3" placeholder="Add any additional notes about this document..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-upload me-2"></i>Upload Document
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Handle document type selection
        $('#documentTypeId').change(function() {
            var selectedOption = $(this).find('option:selected');
            var description = selectedOption.data('description');
            var requirements = selectedOption.data('requirements');
            var allowedTypes = selectedOption.data('allowed-types');
            var maxSize = selectedOption.data('max-size');
            
            if (selectedOption.val()) {
                $('#documentDescription').html('<strong>Description:</strong> ' + description);
                $('#documentRequirements').html('<strong>Requirements:</strong> ' + requirements);
                $('#documentConstraints').html('<strong>Allowed file types:</strong> ' + allowedTypes + '<br><strong>Maximum size:</strong> ' + maxSize + ' MB');
                $('#maxFileSize').text(maxSize + ' MB');
                $('#documentTypeInfo').show();
            } else {
                $('#documentTypeInfo').hide();
            }
        });

        // Handle form submission
        $('#uploadForm').submit(function(e) {
            e.preventDefault();
            
            var formData = new FormData(this);
            var submitBtn = $(this).find('button[type="submit"]');
            var originalText = submitBtn.html();
            
            submitBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i>Uploading...');
            
            $.ajax({
                url: '@Url.Action("UploadDocument")',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function(response) {
                    if (response.success) {
                        $('#uploadModal').modal('hide');
                        location.reload();
                    } else {
                        alert('Error: ' + response.message);
                    }
                },
                error: function() {
                    alert('An error occurred while uploading the document.');
                },
                complete: function() {
                    submitBtn.prop('disabled', false).html(originalText);
                }
            });
        });

        // Reset form when modal is hidden
        $('#uploadModal').on('hidden.bs.modal', function() {
            $('#uploadForm')[0].reset();
            $('#documentTypeInfo').hide();
        });

        // Delete document function
        function deleteDocument(documentId) {
            if (confirm('Are you sure you want to delete this document? This action cannot be undone.')) {
                $.ajax({
                    url: '@Url.Action("DeleteDocument")',
                    type: 'POST',
                    data: { id: documentId },
                    success: function(response) {
                        if (response.success) {
                            location.reload();
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function() {
                        alert('An error occurred while deleting the document.');
                    }
                });
            }
        }
    </script>
}