@model AutoEdge.Models.Entities.Inquiry
@{
    ViewData["Title"] = "Inquiry Details";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 mb-0"><i class="fas fa-question-circle me-2"></i>Inquiry Details #@Model.Id</h1>
                    <p class="text-muted">View your inquiry details and responses</p>
                </div>
                <div>
                    <a href="@Url.Action("Inquiries")" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-1"></i>Back to My Inquiries
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Main Content -->
        <div class="col-lg-8">
            <!-- Inquiry Information -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Inquiry Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-muted">Inquiry Details</h6>
                            <p><strong>Type:</strong> @Model.InquiryType</p>
                            <p><strong>Status:</strong> 
                                @if (Model.Status == "Open")
                                {
                                    <span class="badge bg-primary">@Model.Status</span>
                                }
                                else if (Model.Status == "In Progress")
                                {
                                    <span class="badge bg-warning">@Model.Status</span>
                                }
                                else if (Model.Status == "Resolved")
                                {
                                    <span class="badge bg-success">@Model.Status</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@Model.Status</span>
                                }
                            </p>
                            <p><strong>Priority:</strong> @Model.Priority</p>
                            <p><strong>Created:</strong> @Model.CreatedDate.ToString("MMM dd, yyyy h:mm tt")</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Contact Preferences</h6>
                            <p><strong>Name:</strong> @Model.CustomerName</p>
                            <p><strong>Email:</strong> @Model.CustomerEmail</p>
                            <p><strong>Phone:</strong> @Model.CustomerPhone</p>
                            <p><strong>Preferred Contact:</strong> @Model.PreferredContactMethod</p>
                        </div>
                    </div>
                    
                    <div class="mt-3">
                        <h6 class="text-muted">Message</h6>
                        <div class="bg-light p-3 rounded">
                            @Model.Message
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(Model.Response))
                    {
                        <div class="mt-3">
                            <h6 class="text-muted">Our Response</h6>
                            <div class="bg-success bg-opacity-10 p-3 rounded border-start border-success border-3">
                                @Model.Response
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Vehicle Information -->
            @if (Model.Vehicle != null)
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="fas fa-car me-2"></i>Vehicle Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-12">
                                <h4>@Model.Vehicle.Year @Model.Vehicle.Make @Model.Vehicle.Model</h4>
                                <p class="text-success h5">@Model.Vehicle.SellingPrice.ToString("C")</p>
                                
                                <div class="row">
                                    <div class="col-md-6">
                                        <p><strong>VIN:</strong> @Model.Vehicle.VIN</p>
                                        <p><strong>Mileage:</strong> @Model.Vehicle.Mileage.ToString("N0") miles</p>
                                        <p><strong>Engine:</strong> @Model.Vehicle.EngineType</p>
                                        <p><strong>Transmission:</strong> @Model.Vehicle.Transmission</p>
                                    </div>
                                    <div class="col-md-6">
                                        <p><strong>Exterior Color:</strong> @Model.Vehicle.ExteriorColor</p>
                                        <p><strong>Interior Color:</strong> @Model.Vehicle.InteriorColor</p>
                                        <p><strong>Condition:</strong> @Model.Vehicle.Condition</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mt-3">
                            <a href="@Url.Action("Details", "VehicleBrowse", new { id = Model.VehicleId })" 
                               class="btn btn-outline-primary">
                                <i class="fas fa-eye me-1"></i>View Full Vehicle Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Quick Actions -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="fas fa-bolt me-2"></i>Quick Actions</h5>
                </div>
                <div class="card-body">
                    @if (Model.Status != "Closed")
                    {
                        <a href="@Url.Action("UpdateInquiry", new { id = Model.Id })" 
                           class="btn btn-primary w-100 mb-2">
                            <i class="fas fa-edit me-1"></i>Update Inquiry
                        </a>
                    }
                    
                    @if (Model.Vehicle != null)
                    {
                        <a href="@Url.Action("Details", "VehicleBrowse", new { id = Model.VehicleId })" 
                           class="btn btn-outline-info w-100 mb-2">
                            <i class="fas fa-car me-1"></i>View Vehicle
                        </a>
                    }
                    
                    <a href="@Url.Action("Inquiries")" class="btn btn-outline-secondary w-100">
                        <i class="fas fa-list me-1"></i>All My Inquiries
                    </a>
                </div>
            </div>

            <!-- Inquiry Summary -->
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="fas fa-chart-bar me-2"></i>Summary</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Inquiry ID:</span>
                        <strong>#@Model.Id</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Type:</span>
                        <strong>@Model.InquiryType</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Status:</span>
                        <strong>@Model.Status</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Created:</span>
                        <strong>@Model.CreatedDate.ToString("MMM dd")</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>