@model AutoEdge.Models.Entities.Document
@{
    ViewData["Title"] = "Document Details";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">Document Details</h2>
                <a href="@Url.Action("Documents")" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Back to Documents
                </a>
            </div>

            <div class="row">
                <div class="col-lg-8">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="fas fa-file me-2"></i>@Model.DocumentType.Name
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <h6 class="text-muted">File Information</h6>
                                    <table class="table table-sm table-borderless">
                                        <tr>
                                            <td><strong>File Name:</strong></td>
                                            <td>@Model.FileName</td>
                                        </tr>
                                        <tr>
                                            <td><strong>File Size:</strong></td>
                                            <td>@((Model.FileSizeBytes / 1024.0 / 1024.0).ToString("F2")) MB</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Content Type:</strong></td>
                                            <td>@Model.ContentType</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Upload Date:</strong></td>
                                            <td>@Model.CreatedDate.ToString("MMMM dd, yyyy 'at' h:mm tt")</td>
                                        </tr>
                                    </table>
                                </div>
                                <div class="col-md-6">
                                    <h6 class="text-muted">Review Information</h6>
                                    <table class="table table-sm table-borderless">
                                        <tr>
                                            <td><strong>Status:</strong></td>
                                            <td>
                                                @switch (Model.Status)
                                                {
                                                    case "Pending":
                                                        <span class="badge bg-warning text-dark fs-6"><i class="fas fa-clock me-1"></i>Pending Review</span>
                                                        break;
                                                    case "Approved":
                                                        <span class="badge bg-success fs-6"><i class="fas fa-check me-1"></i>Approved</span>
                                                        break;
                                                    case "Rejected":
                                                        <span class="badge bg-danger fs-6"><i class="fas fa-times me-1"></i>Rejected</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary fs-6">@Model.Status</span>
                                                        break;
                                                }
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Review Date:</strong></td>
                                            <td>
                                                @if (Model.ReviewDate.HasValue)
                                                {
                                                    @Model.ReviewDate.Value.ToString("MMMM dd, yyyy 'at' h:mm tt")
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Not reviewed yet</span>
                                                }
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Reviewed By:</strong></td>
                                            <td>
                                                @if (Model.Reviewer != null)
                                                {
                                                    @Model.Reviewer.FirstName @Model.Reviewer.LastName
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Not assigned</span>
                                                }
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(Model.Description))
                            {
                                <hr>
                                <h6 class="text-muted">Description</h6>
                                <p class="mb-0">@Model.Description</p>
                            }

                            @if (!string.IsNullOrEmpty(Model.ValidationNotes))
                            {
                                <hr>
                                <h6 class="text-muted">Review Notes</h6>
                                <div class="alert @(Model.Status == "Approved" ? "alert-success" : Model.Status == "Rejected" ? "alert-danger" : "alert-info")">
                                    @Model.ValidationNotes
                                </div>
                            }

                            @if (Model.IsOcrProcessed && !string.IsNullOrEmpty(Model.ExtractedText))
                            {
                                <hr>
                                <h6 class="text-muted">Extracted Text (OCR)</h6>
                                <div class="bg-light p-3 rounded">
                                    <pre class="mb-0" style="white-space: pre-wrap;">@Model.ExtractedText</pre>
                                </div>
                                @if (!string.IsNullOrEmpty(Model.OcrValidationResults))
                                {
                                    <div class="mt-2">
                                        <small class="text-muted">OCR Validation: @Model.OcrValidationResults</small>
                                    </div>
                                }
                            }
                        </div>
                        <div class="card-footer">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <a href="@Model.FilePath" target="_blank" class="btn btn-primary">
                                        <i class="fas fa-download me-2"></i>Download File
                                    </a>
                                    <a href="@Model.FilePath" target="_blank" class="btn btn-outline-secondary">
                                        <i class="fas fa-eye me-2"></i>View File
                                    </a>
                                </div>
                                @if (Model.Status != "Approved")
                                {
                                    <button type="button" class="btn btn-outline-danger" onclick="deleteDocument(@Model.Id)">
                                        <i class="fas fa-trash me-2"></i>Delete Document
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header">
                            <h6 class="card-title mb-0">
                                <i class="fas fa-info-circle me-2"></i>Document Type Information
                            </h6>
                        </div>
                        <div class="card-body">
                            <h6 class="text-muted">Description</h6>
                            <p class="small">@Model.DocumentType.Description</p>
                            
                            <h6 class="text-muted mt-3">Requirements</h6>
                            <p class="small">@Model.DocumentType.Requirements</p>
                            
                            <h6 class="text-muted mt-3">File Specifications</h6>
                            <ul class="list-unstyled small">
                                <li><strong>Allowed Types:</strong> @Model.DocumentType.AllowedFileTypes</li>
                                <li><strong>Max Size:</strong> @(Model.DocumentType.MaxFileSizeBytes / 1024 / 1024) MB</li>
                            </ul>
                        </div>
                    </div>

                    @if (Model.Status == "Pending")
                    {
                        <div class="card mt-3">
                            <div class="card-body text-center">
                                <i class="fas fa-clock fa-2x text-warning mb-2"></i>
                                <h6>Pending Review</h6>
                                <p class="small text-muted mb-0">Your document is in the review queue. You'll be notified once it's been processed.</p>
                            </div>
                        </div>
                    }
                    else if (Model.Status == "Rejected")
                    {
                        <div class="card mt-3">
                            <div class="card-body text-center">
                                <i class="fas fa-times-circle fa-2x text-danger mb-2"></i>
                                <h6>Document Rejected</h6>
                                <p class="small text-muted mb-3">Please review the notes above and upload a corrected version.</p>
                                <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#reuploadModal">
                                    <i class="fas fa-upload me-1"></i>Upload New Version
                                </button>
                            </div>
                        </div>
                    }
                    else if (Model.Status == "Approved")
                    {
                        <div class="card mt-3">
                            <div class="card-body text-center">
                                <i class="fas fa-check-circle fa-2x text-success mb-2"></i>
                                <h6>Document Approved</h6>
                                <p class="small text-muted mb-0">This document has been verified and approved for your vehicle purchase process.</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Delete document function
        function deleteDocument(documentId) {
            if (confirm('Are you sure you want to delete this document? This action cannot be undone.')) {
                $.ajax({
                    url: '@Url.Action("DeleteDocument")',
                    type: 'POST',
                    data: { id: documentId },
                    success: function(response) {
                        if (response.success) {
                            window.location.href = '@Url.Action("Documents")';
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function() {
                        alert('An error occurred while deleting the document.');
                    }
                });
            }
        }
    </script>
}