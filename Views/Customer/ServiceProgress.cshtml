@model AutoEdge.Models.Entities.ServiceBooking
@{
    ViewData["Title"] = "Service Progress";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="fas fa-tools me-2"></i>Service Progress</h2>
                <a href="/Customer/Dashboard" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
                </a>
            </div>

            <!-- Service Information -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Service Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Booking Reference:</strong> @Model.Reference</p>
                            <p><strong>Service Type:</strong> <span class="badge bg-primary">@Model.ServiceType</span></p>
                            <p><strong>Vehicle:</strong> @Model.Make @Model.Model (@Model.Year)</p>
                            <p><strong>Scheduled Date:</strong> @Model.PreferredDate.ToString("MMM dd, yyyy")</p>
                            <p><strong>Scheduled Time:</strong> @Model.PreferredStart.ToString("HH:mm")</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Status:</strong> 
                                @if (Model.IsServiceStarted)
                                {
                                    <span class="badge bg-primary">
                                        <i class="fas fa-tools me-1"></i>Service In Progress
                                    </span>
                                }
                                else if (Model.IsCheckedIn)
                                {
                                    <span class="badge bg-info">
                                        <i class="fas fa-clock me-1"></i>Waiting for Service
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">
                                        <i class="fas fa-exclamation-triangle me-1"></i>Not Checked In
                                    </span>
                                }
                            </p>
                            <p><strong>Delivery Method:</strong> @Model.DeliveryMethod</p>
                            <p><strong>Estimated Cost:</strong> $@Model.EstimatedCost.ToString("F2")</p>
                            <p><strong>Estimated Duration:</strong> @Model.EstimatedDurationMin minutes</p>
                            @if (Model.IsCheckedIn)
                            {
                                <p><strong>Checked In:</strong> <span class="text-success"><i class="fas fa-check-circle me-1"></i>Yes</span></p>
                                <p><strong>Check-in Time:</strong> @Model.CheckedInDate?.ToString("MMM dd, yyyy HH:mm")</p>
                            }
                            else
                            {
                                <p><strong>Checked In:</strong> <span class="text-warning"><i class="fas fa-clock me-1"></i>Not yet</span></p>
                            }
                            @if (Model.IsServiceStarted)
                            {
                                <p><strong>Service Started:</strong> <span class="text-primary"><i class="fas fa-play-circle me-1"></i>Yes</span></p>
                                <p><strong>Service Start Time:</strong> @Model.ServiceStartedDate?.ToString("MMM dd, yyyy HH:mm")</p>
                            }
                            else
                            {
                                <p><strong>Service Started:</strong> <span class="text-muted"><i class="fas fa-pause-circle me-1"></i>Not yet</span></p>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.ServiceJob?.ServiceChecklist != null)
            {
                var checklist = Model.ServiceJob.ServiceChecklist;
                
                <!-- Progress Overview -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-chart-line me-2"></i>Service Progress</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <h6>Progress</h6>
                                <div class="progress mb-3" style="height: 25px;">
                                    @{
                                        var progressWidth = checklist.ProgressPercentage >= 100 ? 100.0 : Math.Min(checklist.ProgressPercentage, 100);
                                    }
                                    <div class="progress-bar @(checklist.ProgressPercentage >= 100 ? "bg-success" : checklist.ProgressPercentage > 0 ? "bg-primary" : "bg-secondary")" 
                                         role="progressbar" 
                                         style="width: @(progressWidth >= 100 ? "100" : progressWidth.ToString("F1"))% !important; 
                                                min-width: @(progressWidth >= 100 ? "100" : progressWidth.ToString("F1"))% !important;" 
                                         aria-valuenow="@checklist.ProgressPercentage" 
                                         aria-valuemin="0" 
                                         aria-valuemax="100">
                                        @checklist.ProgressPercentage.ToString("F1")%
                                    </div>
                                </div>
                                <p class="text-muted">
                                    @checklist.CompletedItemsCount of @checklist.TotalItemsCount tasks completed
                                </p>
                            </div>
                            <div class="col-md-6">
                                <h6>Cost Summary</h6>
                                <div class="row">
                                    <div class="col-6">
                                        <small class="text-muted">Estimated:</small><br>
                                        <strong>$@checklist.TotalEstimatedCost.ToString("F2")</strong>
                                    </div>
                                    <div class="col-6">
                                        <small class="text-muted">Actual (so far):</small><br>
                                        <strong class="@(checklist.TotalActualCost > checklist.TotalEstimatedCost ? "text-danger" : "text-success")">
                                            $@checklist.TotalActualCost.ToString("F2")
                                        </strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Service Checklist -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-clipboard-list me-2"></i>Service Checklist</h5>
                    </div>
                    <div class="card-body">
                        @if (checklist.Items.Any())
                        {
                            <div class="list-group">
                                @foreach (var item in checklist.Items.OrderBy(i => i.Id))
                                {
                                    <div class="list-group-item @(item.IsCompleted ? "list-group-item-success" : "")">
                                        <div class="d-flex w-100 justify-content-between align-items-center">
                                            <div class="flex-grow-1">
                                                <h6 class="mb-1 @(item.IsCompleted ? "text-decoration-line-through" : "")">
                                                    @item.TaskName
                                                    @if (item.IsCompleted)
                                                    {
                                                        <i class="fas fa-check-circle text-success ms-2"></i>
                                                    }
                                                </h6>
                                                @if (!string.IsNullOrEmpty(item.Description))
                                                {
                                                    <p class="mb-1 text-muted">@item.Description</p>
                                                }
                                                @if (!string.IsNullOrEmpty(item.Notes))
                                                {
                                                    <p class="mb-1"><strong>Notes:</strong> @item.Notes</p>
                                                }
                                                @if (item.CompletedAt.HasValue)
                                                {
                                                    <small class="text-muted">
                                                        Completed: @item.CompletedAt.Value.ToString("MMM dd, yyyy HH:mm")
                                                    </small>
                                                }
                                            </div>
                                            <div class="text-end">
                                                @if (item.EstimatedCost.HasValue)
                                                {
                                                    <div class="mb-1">
                                                        <small class="text-muted">Est: $@item.EstimatedCost.Value.ToString("F2")</small>
                                                    </div>
                                                }
                                                @if (item.ActualCost.HasValue)
                                                {
                                                    <div>
                                                        <strong class="@(item.ActualCost > item.EstimatedCost ? "text-danger" : "text-success")">
                                                            $@item.ActualCost.Value.ToString("F2")
                                                        </strong>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-4">
                                <i class="fas fa-clipboard-list fa-3x text-muted mb-3"></i>
                                <p class="text-muted">No checklist items available yet.</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Service Photos -->
                @if (checklist.Photos.Any())
                {
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="fas fa-camera me-2"></i>Service Photos</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                @foreach (var photo in checklist.Photos.OrderBy(p => p.PhotoType))
                                {
                                    <div class="col-md-4 mb-3">
                                        <div class="card">
                                            <img src="@photo.FilePath" class="card-img-top" alt="@photo.PhotoType" style="height: 200px; object-fit: cover;">
                                            <div class="card-body">
                                                <h6 class="card-title">@photo.PhotoType</h6>
                                                @if (!string.IsNullOrEmpty(photo.Description))
                                                {
                                                    <p class="card-text">@photo.Description</p>
                                                }
                                                <small class="text-muted">
                                                    Taken: @photo.TakenAt.ToString("MMM dd, yyyy HH:mm")
                                                </small>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }

                <!-- Service Status -->
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Service Status</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong>Started:</strong> @checklist.StartedAt.ToString("MMM dd, yyyy HH:mm")</p>
                                <p><strong>Status:</strong> 
                                    @if (checklist.IsCompleted)
                                    {
                                        <span class="badge bg-success">Completed</span>
                                        <br><small class="text-muted">Completed: @checklist.CompletedAt?.ToString("MMM dd, yyyy HH:mm")</small>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary">In Progress</span>
                                    }
                                </p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Mechanic:</strong> @Model.ServiceJob.Mechanic.Name</p>
                                <p><strong>Total Duration:</strong> 
                                    @if (checklist.TotalActualDurationMinutes > 0)
                                    {
                                        <span>@checklist.TotalActualDurationMinutes minutes (actual)</span>
                                    }
                                    else
                                    {
                                        <span>@checklist.TotalEstimatedDurationMinutes minutes (estimated)</span>
                                    }
                                </p>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(checklist.Notes))
                        {
                            <div class="mt-3">
                                <strong>Service Notes:</strong>
                                <p class="mt-1">@checklist.Notes</p>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="card">
                    <div class="card-body text-center py-5">
                        <i class="fas fa-clock fa-3x text-muted mb-3"></i>
                        <h5>Service Not Started Yet</h5>
                        <p class="text-muted">Your service has not been started by the technician yet.</p>
                        <p class="text-muted">Please wait for the technician to begin work on your vehicle.</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
