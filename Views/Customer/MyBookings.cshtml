@model IEnumerable<AutoEdge.Models.Entities.ServiceBooking>
@using AutoEdge.Models.Entities
@{
    ViewData["Title"] = "My Service Bookings";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="fas fa-calendar-check me-2"></i>My Service Bookings</h2>
                <a href="/Bookings/Create" class="btn btn-primary">
                    <i class="fas fa-plus me-2"></i>Book New Service
                </a>
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="row">
                    @foreach (var booking in Model)
                    {
                        <div class="col-md-6 col-lg-4 mb-4">
                            <div class="card h-100 @GetStatusCardClass(booking.Status)">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <h6 class="mb-0">
                                        <i class="fas fa-wrench me-2"></i>@booking.ServiceType
                                    </h6>
                                    <span class="badge @GetStatusBadgeClass(booking.Status)">
                                        @booking.Status
                                    </span>
                                </div>
                                <div class="card-body">
                                    <h5 class="card-title">@booking.Make @booking.Model (@booking.Year)</h5>
                                    <p class="card-text">
                                        <strong>Reference:</strong> <code>@booking.Reference</code><br/>
                                        <strong>Scheduled:</strong> @booking.PreferredDate.ToString("MMM dd, yyyy") at @booking.PreferredStart.ToString("HH:mm")<br/>
                                        <strong>Duration:</strong> @booking.EstimatedDurationMin minutes<br/>
                                        <strong>Cost:</strong> $@booking.EstimatedCost.ToString("F2")<br/>
                                        <strong>Method:</strong> @booking.DeliveryMethod<br/>
                                        @if (booking.ServiceJob?.Mechanic != null)
                                        {
                                            <strong>Assigned Mechanic:</strong> @booking.ServiceJob.Mechanic.Name<br/>
                                        }
                                        @if (!string.IsNullOrEmpty(booking.Notes))
                                        {
                                            <strong>Notes:</strong> @booking.Notes<br/>
                                        }
                                    </p>
                                    
                                    @if (booking.IsCheckedIn)
                                    {
                                        <div class="alert alert-success mb-3">
                                            <i class="fas fa-check-circle me-2"></i>
                                            <strong>Checked In!</strong><br/>
                                            <small>Checked in on: @booking.CheckedInDate?.ToString("MMM dd, yyyy HH:mm")</small>
                                        </div>
                                    }
                                    
                                    @if (booking.ServiceJob?.IsCompleted == true)
                                    {
                                        <div class="alert alert-info mb-3">
                                            <i class="fas fa-tools me-2"></i>
                                            <strong>Service Completed!</strong>
                                        </div>
                                    }
                                </div>
                                <div class="card-footer">
                                    <small class="text-muted">
                                        Created: @booking.CreatedAtUtc.ToString("MMM dd, yyyy HH:mm")
                                    </small>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-calendar-times fa-3x text-muted mb-3"></i>
                    <h4 class="text-muted">No Service Bookings Found</h4>
                    <p class="text-muted">You haven't made any service bookings yet.</p>
                    <a href="/Bookings/Create" class="btn btn-primary">
                        <i class="fas fa-plus me-2"></i>Book Your First Service
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@functions {
    string GetStatusCardClass(ServiceBookingStatus status)
    {
        return status switch
        {
            ServiceBookingStatus.Confirmed => "border-success",
            ServiceBookingStatus.Pending => "border-warning",
            ServiceBookingStatus.Completed => "border-info",
            ServiceBookingStatus.Canceled => "border-danger",
            _ => "border-secondary"
        };
    }

    string GetStatusBadgeClass(ServiceBookingStatus status)
    {
        return status switch
        {
            ServiceBookingStatus.Confirmed => "bg-success",
            ServiceBookingStatus.Pending => "bg-warning",
            ServiceBookingStatus.Completed => "bg-info",
            ServiceBookingStatus.Canceled => "bg-danger",
            _ => "bg-secondary"
        };
    }
}
