@model IEnumerable<AutoEdge.Models.Entities.Inquiry>
@{
    ViewData["Title"] = "My Inquiries";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 mb-0">My Inquiries</h1>
                    <p class="text-muted">Track and manage your vehicle inquiries</p>
                </div>
                <div>
                    <a href="@Url.Action("Index", "VehicleBrowse")" class="btn btn-primary">
                        <i class="fas fa-plus"></i> New Inquiry
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <form method="get" class="row g-3">
                        <div class="col-md-3">
                            <label for="status" class="form-label">Status</label>
                            <select class="form-select" id="status" name="status">
                                <option value="">All Statuses</option>
                                <option value="Open" selected="@(ViewBag.CurrentStatus == "Open")">Open</option>
                                <option value="InProgress" selected="@(ViewBag.CurrentStatus == "InProgress")">In Progress</option>
                                <option value="Closed" selected="@(ViewBag.CurrentStatus == "Closed")">Closed</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="dateFrom" class="form-label">From Date</label>
                            <input type="date" class="form-control" id="dateFrom" name="dateFrom" value="@ViewBag.DateFrom">
                        </div>
                        <div class="col-md-3">
                            <label for="dateTo" class="form-label">To Date</label>
                            <input type="date" class="form-control" id="dateTo" name="dateTo" value="@ViewBag.DateTo">
                        </div>
                        <div class="col-md-3">
                            <label for="search" class="form-label">Search</label>
                            <input type="text" class="form-control" id="search" name="search" placeholder="Vehicle or message..." value="@ViewBag.SearchTerm">
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-search"></i> Filter
                            </button>
                            <a href="@Url.Action("Inquiries")" class="btn btn-outline-secondary">
                                <i class="fas fa-times"></i> Clear
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Inquiries List -->
    <div class="row">
        <div class="col-12">
            @if (Model != null && Model.Any())
            {
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Inquiries (@ViewBag.TotalCount)</h5>
                        <div class="btn-group" role="group">
                            <input type="radio" class="btn-check" name="viewMode" id="listView" autocomplete="off" checked>
                            <label class="btn btn-outline-primary" for="listView">
                                <i class="fas fa-list"></i>
                            </label>
                            <input type="radio" class="btn-check" name="viewMode" id="cardView" autocomplete="off">
                            <label class="btn btn-outline-primary" for="cardView">
                                <i class="fas fa-th"></i>
                            </label>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <!-- List View -->
                        <div id="listViewContent" class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Vehicle</th>
                                        <th>Message</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var inquiry in Model)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    @if (inquiry.Vehicle?.VehicleImages != null && inquiry.Vehicle.VehicleImages.Any())
                        {
                            var firstImage = inquiry.Vehicle.VehicleImages.First().ImagePath;
                                                        <img src="@firstImage" alt="Vehicle" class="rounded me-2" style="width: 50px; height: 40px; object-fit: cover;">
                                                    }
                                                    else
                                                    {
                                                        <div class="bg-light rounded me-2 d-flex align-items-center justify-content-center" style="width: 50px; height: 40px;">
                                                            <i class="fas fa-car text-muted"></i>
                                                        </div>
                                                    }
                                                    <div>
                                                        <div class="fw-bold">@inquiry.Vehicle?.Year @inquiry.Vehicle?.Make @inquiry.Vehicle?.Model</div>
                                                        <small class="text-muted">@inquiry.Vehicle?.SellingPrice.ToString("C")</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="text-truncate" style="max-width: 200px;" title="@inquiry.Message">
                                                    @inquiry.Message
                                                </div>
                                            </td>
                                            <td>
                                                <div>@inquiry.CreatedDate.ToString("MMM dd, yyyy")</div>
                                                <small class="text-muted">@inquiry.CreatedDate.ToString("h:mm tt")</small>
                                            </td>
                                            <td>
                                                <span class="badge bg-@(inquiry.Status == "Open" ? "primary" : inquiry.Status == "InProgress" ? "warning" : "success")">@inquiry.Status</span>
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a href="@Url.Action("InquiryDetails", new { id = inquiry.Id })" class="btn btn-sm btn-outline-primary" title="View Details">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    @if (inquiry.Status != "Closed")
                                                    {
                                                        <a href="@Url.Action("UpdateInquiry", new { id = inquiry.Id })" class="btn btn-sm btn-outline-warning" title="Update">
                                                            <i class="fas fa-edit"></i>
                                                        </a>
                                                    }
                                                    <a href="@Url.Action("Details", "VehicleBrowse", new { id = inquiry.VehicleId })" class="btn btn-sm btn-outline-info" title="View Vehicle">
                                                        <i class="fas fa-car"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Card View -->
                        <div id="cardViewContent" class="row g-3 p-3" style="display: none;">
                            @foreach (var inquiry in Model)
                            {
                                <div class="col-lg-4 col-md-6">
                                    <div class="card h-100 shadow-sm">
                                        @if (inquiry.Vehicle?.VehicleImages != null && inquiry.Vehicle.VehicleImages.Any())
                        {
                            var firstImage = inquiry.Vehicle.VehicleImages.First().ImagePath;
                                            <img src="@firstImage" class="card-img-top" alt="Vehicle" style="height: 200px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                                <i class="fas fa-car fa-3x text-muted"></i>
                                            </div>
                                        }
                                        <div class="card-body">
                                            <h6 class="card-title">@inquiry.Vehicle?.Year @inquiry.Vehicle?.Make @inquiry.Vehicle?.Model</h6>
                                            <p class="card-text text-muted small">@(inquiry.Message?.Length > 100 ? inquiry.Message.Substring(0, 100) + "..." : inquiry.Message)</p>
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <small class="text-muted">
                                                    <i class="fas fa-clock me-1"></i>@inquiry.CreatedDate.ToString("MMM dd, yyyy")
                                                </small>
                                                <span class="badge bg-@(inquiry.Status == "Open" ? "primary" : inquiry.Status == "InProgress" ? "warning" : "success")">@inquiry.Status</span>
                                            </div>
                                        </div>
                                        <div class="card-footer bg-transparent">
                                            <div class="btn-group w-100" role="group">
                                                <a href="@Url.Action("InquiryDetails", new { id = inquiry.Id })" class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-eye"></i> Details
                                                </a>
                                                @if (inquiry.Status != "Closed")
                                                {
                                                    <a href="@Url.Action("UpdateInquiry", new { id = inquiry.Id })" class="btn btn-sm btn-outline-warning">
                                                        <i class="fas fa-edit"></i> Update
                                                    </a>
                                                }
                                                <a href="@Url.Action("Details", "VehicleBrowse", new { id = inquiry.VehicleId })" class="btn btn-sm btn-outline-info">
                                                    <i class="fas fa-car"></i> Vehicle
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Pagination -->
                @if (ViewBag.TotalPages > 1)
                {
                    <nav aria-label="Inquiries pagination" class="mt-4">
                        <ul class="pagination justify-content-center">
                            @if (ViewBag.CurrentPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("Inquiries", new { page = ViewBag.CurrentPage - 1, status = ViewBag.CurrentStatus, dateFrom = ViewBag.DateFrom, dateTo = ViewBag.DateTo, search = ViewBag.SearchTerm })">
                                        <i class="fas fa-chevron-left"></i>
                                    </a>
                                </li>
                            }

                            @for (int i = Math.Max(1, ViewBag.CurrentPage - 2); i <= Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2); i++)
                            {
                                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("Inquiries", new { page = i, status = ViewBag.CurrentStatus, dateFrom = ViewBag.DateFrom, dateTo = ViewBag.DateTo, search = ViewBag.SearchTerm })">@i</a>
                                </li>
                            }

                            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("Inquiries", new { page = ViewBag.CurrentPage + 1, status = ViewBag.CurrentStatus, dateFrom = ViewBag.DateFrom, dateTo = ViewBag.DateTo, search = ViewBag.SearchTerm })">
                                        <i class="fas fa-chevron-right"></i>
                                    </a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="card">
                    <div class="card-body text-center py-5">
                        <i class="fas fa-question-circle fa-4x text-muted mb-4"></i>
                        <h4>No Inquiries Found</h4>
                        <p class="text-muted mb-4">You haven't made any vehicle inquiries yet, or no inquiries match your current filters.</p>
                        <div class="d-flex justify-content-center gap-2">
                            <a href="@Url.Action("Index", "VehicleBrowse")" class="btn btn-primary">
                                <i class="fas fa-search"></i> Browse Vehicles
                            </a>
                            @if (!string.IsNullOrEmpty(ViewBag.CurrentStatus) || !string.IsNullOrEmpty(ViewBag.SearchTerm) || !string.IsNullOrEmpty(ViewBag.DateFrom))
                            {
                                <a href="@Url.Action("Inquiries")" class="btn btn-outline-secondary">
                                    <i class="fas fa-times"></i> Clear Filters
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // View mode toggle
        document.getElementById('listView').addEventListener('change', function() {
            if (this.checked) {
                document.getElementById('listViewContent').style.display = 'block';
                document.getElementById('cardViewContent').style.display = 'none';
            }
        });

        document.getElementById('cardView').addEventListener('change', function() {
            if (this.checked) {
                document.getElementById('listViewContent').style.display = 'none';
                document.getElementById('cardViewContent').style.display = 'block';
            }
        });

        // Auto-submit form on filter change
        document.getElementById('status').addEventListener('change', function() {
            this.form.submit();
        });
    </script>

    <style>
        .table-responsive {
            border-radius: 0.375rem;
        }
        
        .card {
            transition: transform 0.2s ease-in-out;
        }
        
        .card:hover {
            transform: translateY(-2px);
        }
        
        .text-truncate {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
    </style>
}