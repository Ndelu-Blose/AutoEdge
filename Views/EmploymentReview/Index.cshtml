@model IEnumerable<AutoEdge.Models.Entities.PreEmploymentDocumentation>

@{
    ViewData["Title"] = "Employment Documentation Review";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-clipboard-check mr-2"></i>
                        Employment Documentation Review
                    </h3>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle mr-2"></i>
                            @TempData["SuccessMessage"]
                            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                    }

                    <div class="table-responsive">
                        <table class="table table-bordered table-striped" id="reviewTable">
                            <thead class="thead-dark">
                                <tr>
                                    <th>Employee</th>
                                    <th>Position</th>
                                    <th>Department</th>
                                    <th>Submitted Date</th>
                                    <th>Status</th>
                                    <th>Review Date</th>
                                    <th>Reviewed By</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var doc in Model)
                                {
                                    <tr>
                                        <td>
                                            <strong>@doc.EmploymentOffer.Application.FirstName @doc.EmploymentOffer.Application.LastName</strong><br>
                                            <small class="text-muted">@doc.EmploymentOffer.Application.Email</small>
                                        </td>
                                        <td>@doc.EmploymentOffer.JobTitle</td>
                                        <td>@doc.EmploymentOffer.Department</td>
                                        <td>@doc.CompletedDate?.ToString("dd MMM yyyy HH:mm")</td>
                                        <td>
                                            @if (doc.Approved)
                                            {
                                                <span class="badge badge-success">Approved</span>
                                            }
                                            else if (doc.AdminReviewed && !doc.Approved)
                                            {
                                                <span class="badge badge-danger">Rejected</span>
                                            }
                                            else if (!string.IsNullOrEmpty(doc.CorrectionRequests))
                                            {
                                                <span class="badge badge-warning">Corrections Requested</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-primary">Pending Review</span>
                                            }
                                        </td>
                                        <td>
                                            @if (doc.AdminReviewedDate.HasValue)
                                            {
                                                @doc.AdminReviewedDate.Value.ToString("dd MMM yyyy")
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not reviewed</span>
                                            }
                                        </td>
                                        <td>
                                            @if (doc.Reviewer != null)
                                            {
                                                @doc.Reviewer.FirstName @doc.Reviewer.LastName
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not assigned</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <a asp-action="Details" asp-route-id="@doc.DocumentationId" 
                                                   class="btn btn-info btn-sm" title="Review Documentation">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                @if (!doc.AdminReviewed)
                                                {
                                                    <button type="button" class="btn btn-success btn-sm" 
                                                            onclick="approveDocumentation(@doc.DocumentationId)" title="Approve">
                                                        <i class="fas fa-check"></i>
                                                    </button>
                                                    <button type="button" class="btn btn-warning btn-sm" 
                                                            onclick="requestCorrections(@doc.DocumentationId)" title="Request Corrections">
                                                        <i class="fas fa-edit"></i>
                                                    </button>
                                                    <button type="button" class="btn btn-danger btn-sm" 
                                                            onclick="rejectDocumentation(@doc.DocumentationId)" title="Reject">
                                                        <i class="fas fa-times"></i>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Approval Modal -->
<div class="modal fade" id="approvalModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Approve Documentation</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <form id="approvalForm" method="post">
                <div class="modal-body">
                    <input type="hidden" id="approvalDocId" name="id" />
                    <div class="form-group">
                        <label for="adminNotes">Approval Notes (Optional)</label>
                        <textarea class="form-control" id="adminNotes" name="adminNotes" rows="3" 
                                  placeholder="Add any notes about the approval..."></textarea>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="scheduleOnboarding" name="scheduleOnboarding">
                        <label class="form-check-label" for="scheduleOnboarding">
                            Schedule onboarding session
                        </label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Approve Documentation</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Corrections Modal -->
<div class="modal fade" id="correctionsModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Request Corrections</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <form id="correctionsForm" method="post">
                <div class="modal-body">
                    <input type="hidden" id="correctionsDocId" name="id" />
                    <div class="form-group">
                        <label for="correctionRequests">What corrections are needed? <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="correctionRequests" name="correctionRequests" rows="5" 
                                  placeholder="Please specify what needs to be corrected..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">Send Correction Request</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Rejection Modal -->
<div class="modal fade" id="rejectionModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Reject Documentation</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <form id="rejectionForm" method="post">
                <div class="modal-body">
                    <input type="hidden" id="rejectionDocId" name="id" />
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle mr-2"></i>
                        <strong>Warning:</strong> This action will permanently reject the documentation and end the onboarding process.
                    </div>
                    <div class="form-group">
                        <label for="rejectionReason">Reason for rejection <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="rejectionReason" name="rejectionReason" rows="5" 
                                  placeholder="Please provide a detailed reason for rejection..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Reject Documentation</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#reviewTable').DataTable({
                "responsive": true,
                "lengthChange": false,
                "autoWidth": false,
                "order": [[3, "desc"]], // Sort by submitted date descending
                "pageLength": 25
            });
        });

        function approveDocumentation(docId) {
            $('#approvalDocId').val(docId);
            $('#approvalForm').attr('action', '@Url.Action("Approve", "EmploymentReview")');
            $('#approvalModal').modal('show');
        }

        function requestCorrections(docId) {
            $('#correctionsDocId').val(docId);
            $('#correctionsForm').attr('action', '@Url.Action("RequestCorrections", "EmploymentReview")');
            $('#correctionsModal').modal('show');
        }

        function rejectDocumentation(docId) {
            $('#rejectionDocId').val(docId);
            $('#rejectionForm').attr('action', '@Url.Action("Reject", "EmploymentReview")');
            $('#rejectionModal').modal('show');
        }
    </script>
}
