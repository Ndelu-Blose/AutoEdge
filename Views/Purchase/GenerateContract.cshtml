@model AutoEdge.Models.Entities.Purchase
@{
    ViewData["Title"] = "Contract Preview";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-file-contract me-2"></i>
                        Contract Preview - @ViewBag.ContractNumber
                    </h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        Please review your contract carefully before proceeding to payment.
                    </div>

                    <!-- Contract Content -->
                    <div class="contract-preview border p-4 mb-4" style="background-color: #f8f9fa;">
                        @Html.Raw(ViewBag.ContractHtml)
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-flex justify-content-between">
                        <div>
                            <a href="@Url.Action("DownloadContract", new { id = Model.Id })" 
                               class="btn btn-outline-primary">
                                <i class="fas fa-download me-2"></i>
                                Download Contract
                            </a>
                        </div>
                        <div>
                            <a href="@Url.Action("PurchaseStatus", new { id = Model.Id })" 
                               class="btn btn-secondary me-2">
                                <i class="fas fa-arrow-left me-2"></i>
                                Back to Status
                            </a>
                            @* <a href="@Url.Action("SelectPayment", new { id = Model.Id })" 
                               class="btn btn-success">
                                <i class="fas fa-credit-card me-2"></i>
                                Proceed to Payment
                            </a> *@
                        </div>
                    </div>
                </div>
            </div>

            <!-- Purchase Summary -->
            <div class="card mt-4">
                <div class="card-header">
                    <h5 class="mb-0">Purchase Summary</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Vehicle Details</h6>
                            <p class="mb-1"><strong>@Model.Vehicle.Year @Model.Vehicle.Make @Model.Vehicle.Model</strong></p>
                            <p class="mb-1">VIN: @Model.Vehicle.VIN</p>
                            <p class="mb-1">Mileage: @Model.Vehicle.Mileage.ToString("N0") miles</p>
                        </div>
                        <div class="col-md-6">
                            <h6>Purchase Information</h6>
                            <p class="mb-1">Purchase Date: @Model.CreatedDate.ToString("MMMM dd, yyyy")</p>
                            <p class="mb-1">Status: <span class="badge bg-info">@Model.Status</span></p>
                            <p class="mb-1">Price: <strong>$@Model.Vehicle.SellingPrice.ToString("N2")</strong></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.contract-preview {
    max-height: 600px;
    overflow-y: auto;
    font-family: 'Times New Roman', serif;
    line-height: 1.6;
}

.contract-preview h1, .contract-preview h2, .contract-preview h3 {
    color: #333;
    margin-top: 20px;
    margin-bottom: 10px;
}

.contract-preview p {
    margin-bottom: 10px;
    text-align: justify;
}

.contract-preview .signature-section {
    margin-top: 40px;
    border-top: 1px solid #ddd;
    padding-top: 20px;
}
</style>